#!/bin/bash

VERSION="v14.0.0"
CYAN='\033[0;36m'; NC='\033[0m'; RED='\033[0;31m'; GREEN='\033[0;32m'; BLUE='\033[0;34m'

echo -e "${CYAN}ChromeOS Kernel Patch Script — Version ${VERSION}${NC}"

WORKDIR="/tmp/kernel_patch"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

# Detect vbutil
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] No vbutil_kernel or futility found!${NC}"
    exit 1
fi
echo -e "${GREEN}[*] Using tool: $VBUTIL${NC}"

# Dump kernels
echo -e "${BLUE}[*] Dumping KERN-A and KERN-B...${NC}"
sudo dd if=$KERN_A of=kernel_A.bin bs=4M status=progress
sudo dd if=$KERN_B of=kernel_B.bin bs=4M status=progress

# Flags
FLAGS=(0 0 0 0 0 0 0)
NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
DESCRIPTIONS=("Enable developer/debug mode" "Turn off rootfs verification" "Allow unsigned kernel modules" "Disable module locking" "Disable extra kernel security checks" "Turn off SELinux enforcement" "Ignore dm-verity errors on boot")

CMDLINE_FILE="$WORKDIR/cmdline.txt"
touch "$CMDLINE_FILE"

show_menu() {
    echo ""
    echo -e "${CYAN}ChromeOS Kernel Patch Menu — Version ${VERSION}${NC}"
    echo "Toggle flags ON/OFF:"
    echo "-----------------------------------"
    for i in {0..6}; do
        status="OFF"; color=$RED
        [ "${FLAGS[$i]}" -eq 1 ] && status="ON" && color=$GREEN
        echo -e "${color}$((i+1))) [${status}] ${NAMES[$i]} - ${DESCRIPTIONS[$i]}${NC}"
    done
    echo ""
    echo "m - Manual edit of cmdline"
    echo "p - Proceed with repack"
    echo "e - Exit without changes"
    echo "-----------------------------------"
}

# VT2-safe menu loop using full line input
while true; do
    show_menu
    echo -n "Choice: "
    read -r choice
    choice=$(echo "$choice" | tr -d '[:space:]')  # trim spaces

    if [[ -z "$choice" ]]; then
        continue
    fi

    changed=0
    case "$choice" in
        1) FLAGS[0]=$((1-FLAGS[0])) ; changed=1 ;;
        2) FLAGS[1]=$((1-FLAGS[1])) ; changed=1 ;;
        3) FLAGS[2]=$((1-FLAGS[2])) ; changed=1 ;;
        4) FLAGS[3]=$((1-FLAGS[3])) ; changed=1 ;;
        5) FLAGS[4]=$((1-FLAGS[4])) ; changed=1 ;;
        6) FLAGS[5]=$((1-FLAGS[5])) ; changed=1 ;;
        7) FLAGS[6]=$((1-FLAGS[6])) ; changed=1 ;;
        m) nano "$CMDLINE_FILE" ; changed=1 ;;
        p) break ;;
        e) echo -e "${RED}[!] Exiting script.${NC}"; exit 0 ;;
        *) continue ;;
    esac

done

# Generate cmdline.txt
> "$CMDLINE_FILE"
for i in {0..6}; do
    if [ "${FLAGS[$i]}" -eq 1 ]; then
        key="${NAMES[$i]}"
        if [ "$key" == "dm_verity.error_behavior" ]; then
            echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE"
        else
            echo -n "$key " >> "$CMDLINE_FILE"
        fi
    fi
done
echo "" >> "$CMDLINE_FILE"

echo -e "${GREEN}[*] Final cmdline:${NC}"
cat "$CMDLINE_FILE"

# Repack kernels
for KERN_BIN in kernel_A.bin kernel_B.bin; do
    OUT_BIN="new_${KERN_BIN}"
    echo -e "${BLUE}[*] Repacking $KERN_BIN...${NC}"
    $VBUTIL --repack "$KERN_BIN" \
        --config "$CMDLINE_FILE" \
        --outfile "$OUT_BIN" \
        --keyblock "$KEYBLOCK" \
        --signprivate "$PRIVKEY"
done

# Flash kernels
echo -e "${BLUE}[*] Flashing KERN-A and KERN-B...${NC}"
sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
sync

echo -e "${GREEN}[✔] Kernel patched successfully! Reboot to apply changes.${NC}"
