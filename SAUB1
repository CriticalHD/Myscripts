#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

LSB="/etc/lsb-release"
DEAD_SERVER="http://127.0.0.1/noupdate"

if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Please run this script with sudo.${NC}"
    exit 1
fi

get_status() {
    current_op=$(update_engine_client --status 2>/dev/null | grep "CURRENT_OP" | cut -d'=' -f2 | tr -d '[:space:]')
    [ -z "$current_op" ] && current_op="UNKNOWN"

    case "$current_op" in
        UPDATE_STATUS_IDLE)                op_display="${GREEN}IDLE${NC}" ;;
        UPDATE_STATUS_UPDATED_NEED_REBOOT) op_display="${RED}REBOOT PENDING${NC}" ;;
        UPDATE_STATUS_DOWNLOADING)         op_display="${YELLOW}DOWNLOADING${NC}" ;;
        UPDATE_STATUS_CHECKING_FOR_UPDATE) op_display="${YELLOW}CHECKING...${NC}" ;;
        UPDATE_STATUS_UPDATE_AVAILABLE)    op_display="${YELLOW}UPDATE AVAILABLE${NC}" ;;
        UPDATE_STATUS_VERIFYING)           op_display="${YELLOW}VERIFYING${NC}" ;;
        UPDATE_STATUS_FINALIZING)          op_display="${YELLOW}FINALIZING${NC}" ;;
        *)                                 op_display="${BLUE}${current_op}${NC}" ;;
    esac

    current_server=$(grep "CHROMEOS_AUSERVER" "$LSB" 2>/dev/null | cut -d'=' -f2)
    if echo "$current_server" | grep -q "127.0.0.1"; then
        SAUB_state="${GREEN}ENABLED${NC}"
    else
        SAUB_state="${RED}DISABLED${NC}"
    fi
}

show_menu() {
    get_status
    clear
    echo -e "${CYAN}==================================================${NC}"
    echo -e "${CYAN}            UPDATE MANAGEMENT UTILITY              ${NC}"
    echo -e "${CYAN}        Version: 3.2 | Author: CriticalHD         ${NC}"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " STATUS: ${op_display}"
    echo -e " SAUB:  ${SAUB_state}"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " ${YELLOW}1)${NC} Enable SAUB"
    echo -e " ${YELLOW}2)${NC} Disable SAUB"
    echo -e " ${YELLOW}3)${NC} View Credits"
    echo -e " ${YELLOW}e)${NC} Exit"
    echo -e "${CYAN}--------------------------------------------------${NC}"
    echo -ne "${BLUE}Select an option: ${NC}"
}


RW_BIND_ACTIVE=0

remount_rw() {
    RW_BIND_ACTIVE=0

    if mount -o remount,rw / 2>/dev/null && touch /.test 2>/dev/null; then
        rm -f /.test
        echo -e "${GREEN}Rootfs remounted read-write (standard).${NC}"
        return 0
    fi

    echo -e "${YELLOW}Standard remount blocked by dm-verity. Using bind-mount strategy...${NC}"

    local scratch="/mnt/stateful_partition/.saub/etc_scratch"
    mkdir -p "$scratch"

    cp -a /etc/. "$scratch/" 2>/dev/null

    if mount --bind "$scratch" /etc 2>/dev/null; then
        RW_BIND_ACTIVE=1
        echo -e "${GREEN}Rootfs writable via bind-mount (dm-verity preserved).${NC}"
        return 0
    fi

    echo -e "${RED}Both remount strategies failed. Cannot write to rootfs.${NC}"
    return 1
}

remount_ro() {
    if [ "$RW_BIND_ACTIVE" -eq 1 ]; then
        # Unmount the bind so dm-verity rootfs is exposed again
        umount /etc 2>/dev/null
        RW_BIND_ACTIVE=0
        echo -e "${GREEN}Bind-mount released. dm-verity rootfs restored.${NC}"
    else
        mount -o remount,ro / 2>/dev/null
        echo -e "${GREEN}Rootfs remounted read-only.${NC}"
    fi
}

# ── SAUB actions ───────────────────────────────────────────────────────────────
enable_SAUB() {
    echo -e "\n${YELLOW}Checking if SAUB already enabled...${NC}"
    current_server=$(grep "CHROMEOS_AUSERVER" "$LSB" 2>/dev/null | cut -d'=' -f2)
    if echo "$current_server" | grep -q "127.0.0.1"; then
        echo -e "${YELLOW}SAUB is already enabled.${NC}"
        echo -ne "${BLUE}Press Enter to continue...${NC}"
        read -r < /dev/tty
        return
    fi

    echo -e "${YELLOW}Attempting to remount rootfs as read-write...${NC}"
    if ! remount_rw; then
        echo -e "${RED}Could not get write access to rootfs. Aborting.${NC}"
        echo -ne "${BLUE}Press Enter to continue...${NC}"
        read -r < /dev/tty
        return
    fi

    echo -e "${YELLOW}Backing up original AUSERVER to RW_VPD...${NC}"
    vpd -i RW_VPD -s "old_auserver=$current_server"

    echo -e "${YELLOW}Redirecting CHROMEOS_AUSERVER to dead endpoint...${NC}"
    sed -i "s|CHROMEOS_AUSERVER=.*|CHROMEOS_AUSERVER=$DEAD_SERVER|" "$LSB"

    echo -e "${YELLOW}Stopping update-engine and purging cache...${NC}"
    stop update-engine >/dev/null 2>&1
    rm -rf /var/lib/update_engine/prefs/*
    /usr/sbin/chromeos-setgoodkernel >/dev/null 2>&1

    echo -e "${YELLOW}Restoring rootfs protection...${NC}"
    remount_ro

    echo -e "${YELLOW}Restarting update-engine...${NC}"
    start update-engine >/dev/null 2>&1

    new_server=$(grep "CHROMEOS_AUSERVER" "$LSB" 2>/dev/null | cut -d'=' -f2)
    if echo "$new_server" | grep -q "127.0.0.1"; then
        echo -e "${GREEN}DONE. Updates blocked until next powerwash.${NC}"
    else
        echo -e "${RED}WARNING: lsb-release may not have updated correctly.${NC}"
    fi
    echo -ne "${BLUE}Press Enter to continue...${NC}"
    read -r < /dev/tty
}

disable_SAUB() {
    echo -e "\n${YELLOW}Attempting to remount rootfs as read-write...${NC}"
    if ! remount_rw; then
        echo -e "${RED}Could not get write access to rootfs. Aborting.${NC}"
        echo -ne "${BLUE}Press Enter to continue...${NC}"
        read -r < /dev/tty
        return
    fi

    old_server=$(vpd -i RW_VPD -l 2>/dev/null | grep '"old_auserver"' | cut -d'"' -f4)
    if [ -z "$old_server" ]; then
        echo -e "${YELLOW}No backup found in RW_VPD. Restoring to default Google server.${NC}"
        old_server="https://tools.google.com/service/update2"
    fi

    echo -e "${YELLOW}Restoring AUSERVER to: $old_server${NC}"
    sed -i "s|CHROMEOS_AUSERVER=.*|CHROMEOS_AUSERVER=$old_server|" "$LSB"

    echo -e "${YELLOW}Removing backup from RW_VPD...${NC}"
    vpd -i RW_VPD -d "old_auserver" 2>/dev/null

    echo -e "${YELLOW}Stopping update-engine and purging cache...${NC}"
    stop update-engine >/dev/null 2>&1
    rm -rf /var/lib/update_engine/prefs/*

    echo -e "${YELLOW}Restoring rootfs protection...${NC}"
    remount_ro

    echo -e "${YELLOW}Restarting update-engine...${NC}"
    start update-engine >/dev/null 2>&1

    echo -e "${GREEN}DONE. Updates restored.${NC}"
    echo -ne "${BLUE}Press Enter to continue...${NC}"
    read -r < /dev/tty
}

show_credits() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}                CREDITS                   ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    echo -e "Concept:   SAUB"
    echo -e "Scripting: CriticalHD/neonnebula"
    echo -e "Features:  lsb-release AUSERVER block + VPD backup"
    echo -e "${CYAN}==========================================${NC}"
    echo -ne "${BLUE}Press Enter to continue...${NC}"
    read -r < /dev/tty
}

while true; do
    show_menu
    read -r choice < /dev/tty
    case "$choice" in
        1) enable_SAUB ;;
        2) disable_SAUB ;;
        3) show_credits ;;
        e|E) echo -e "\n${BLUE}Exiting...${NC}"; exit 0 ;;
        *) echo -e "\n${RED}Invalid option.${NC}"; sleep 1 ;;
    esac
done
