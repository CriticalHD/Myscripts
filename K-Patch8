#!/usr/bin/env bash
set -e

# =======================
# VT2 Full K-Patch Script
# =======================

# Colors
COLOR_RED="\033[0;31m"
COLOR_GREEN="\033[0;32m"
COLOR_YELLOW="\033[1;33m"
COLOR_CYAN="\033[1;36m"
COLOR_RED_B='\033[1;31m'
COLOR_RESET="\033[0m"

# Folders
VBOOT_BASE='/usr/share/vboot'
DEFAULT_KEYS_FOLDER="$VBOOT_BASE/devkeys"
DEFAULT_BACKUP_FOLDER='/mnt/stateful_partition/backups'
[ ! -d "$DEFAULT_BACKUP_FOLDER" ] && mkdir -p "$DEFAULT_BACKUP_FOLDER"

# Logging
log_info() { printf "${COLOR_GREEN}Info: %b${COLOR_RESET}\n" "$*"; }
log_warn() { printf "${COLOR_YELLOW}Warning: %b${COLOR_RESET}\n" "$*"; }
log_error() { printf "${COLOR_RED_B}Error: %b${COLOR_RESET}\n" "$*"; }
fail() { log_error "$*"; exit 1; }
[ "$EUID" -ne 0 ] && fail "Please run as root"

# =======================
# Patchable Flags
# =======================
declare -A FLAGS=(
  [1]="Remove RootFS Verification"
  [2]="Enable Developer Mode / Dev Keys"
  [3]="Enable Early Console / Serial"
  [4]="Disable SELinux / Security Flags"
  [5]="Custom GBB Flags (hex)"
  [6]="Enable Recovery Partition Modifications"
  [7]="Modify TPM / Rollback Enforcement"
  [8]="Modify Hardware ID / allow cross-device boot"
  [9]="Modify Recovery UI behavior"
  [10]="Enable Legacy Boot / fastboot"
)

# Default values
PATCH_ROOTFS=false
PATCH_DEV_KEYS=false
PATCH_DEBUG=false
PATCH_SELINUX=false
PATCH_RECOVERY=false
PATCH_TPM=false
PATCH_HWID=false
PATCH_RECUI=false
PATCH_LEGACY=false
GBB_FLAGS=""
KERNEL_PARTITIONS="2 4"

# =======================
# Configure Flags via Menu
# =======================
configure_flags() {
    echo -e "${COLOR_YELLOW}=== K-Patch Full Menu ===${COLOR_RESET}"
    echo
    echo -e "${COLOR_CYAN}Select numbers separated by spaces and press Enter:${COLOR_RESET}"

    for i in $(seq 1 ${#FLAGS[@]}); do
        echo -e "${COLOR_GREEN}$i)${COLOR_RESET} ${FLAGS[$i]}"
    done
    echo

    read -p "Enter selection: " selections

    for sel in $selections; do
        case $sel in
            1) PATCH_ROOTFS=true ;;
            2) PATCH_DEV_KEYS=true ;;
            3) PATCH_DEBUG=true ;;
            4) PATCH_SELINUX=true ;;
            5) read -p "Enter custom GBB flags in hex (e.g., 0x9a31): " GBB_FLAGS ;;
            6) PATCH_RECOVERY=true ;;
            7) PATCH_TPM=true ;;
            8) PATCH_HWID=true ;;
            9) PATCH_RECUI=true ;;
            10) PATCH_LEGACY=true ;;
            *) log_warn "Ignoring invalid selection: $sel" ;;
        esac
    done

    read -p "Kernel partitions to patch (default 2 4): " ans
    KERNEL_PARTITIONS="${ans:-2 4}"
}

# =======================
# Backup Firmware
# =======================
backup_firmware() {
    log_info "Backing up full firmware..."
    flashrom -p host -r "$DEFAULT_BACKUP_FOLDER/full_backup.bin"
    log_info "Backup saved to $DEFAULT_BACKUP_FOLDER/full_backup.bin"
}

# =======================
# Patch Firmware / GBB
# =======================
patch_firmware() {
    backup_firmware

    $PATCH_DEV_KEYS && log_info "Applying dev keys..." && make_dev_firmware.sh --keys "$DEFAULT_KEYS_FOLDER" --force_backup true

    local gbb_opts=""
    $PATCH_ROOTFS && gbb_opts="$gbb_opts --remove_rootfs_verification"
    $PATCH_RECOVERY && gbb_opts="$gbb_opts --allow_recovery_mod"
    $PATCH_LEGACY && gbb_opts="$gbb_opts --enable_legacy_boot"
    $PATCH_TPM && gbb_opts="$gbb_opts --disable_tpm_rollback"
    $PATCH_HWID && gbb_opts="$gbb_opts --nomod_hwid"
    $PATCH_RECUI && gbb_opts="$gbb_opts --custom_rec_ui"

    # Apply GBB flags if SELinux or custom GBB
    [ "$PATCH_SELINUX" = true ] || [ -n "$GBB_FLAGS" ] && log_info "Flashing GBB flags $GBB_FLAGS" && futility gbb -s --flash --flags="${GBB_FLAGS:-0x9a31}"

    # Apply combined options
    if [ -n "$gbb_opts" ]; then
        log_info "Applying GBB options: $gbb_opts"
        make_dev_ssd.sh $gbb_opts
    fi
}

# =======================
# Patch Kernel
# =======================
patch_kernel() {
    local opts="--keys $DEFAULT_KEYS_FOLDER"
    $PATCH_ROOTFS && opts="$opts --remove_rootfs_verification"
    $PATCH_DEBUG && opts="$opts --enable_earlycon true --enable_console true"
    opts="$opts --partitions $KERNEL_PARTITIONS"

    log_info "Patching kernel with options: $opts"
    make_dev_ssd.sh $opts
}

# =======================
# Main
# =======================
main() {
    configure_flags

    echo -e "${COLOR_RED_B}Warning: This can brick your device!${COLOR_RESET}"
    read -p "Continue? (y/N): " confirm
    [[ ! "$confirm" =~ ^[Yy]$ ]] && { echo "Aborting..."; exit 1; }

    patch_firmware
    patch_kernel
    log_info "Done! Firmware and kernel patched with selected flags."
}

main
