#!/bin/bash

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
RESET='\033[0m'

SSH_DIR="/home/chronos/user/.ssh"
KEY="$SSH_DIR/id_rsa"
STARTUP="/etc/init/sudocrosh-ssh.conf"
SHORTCUT="/usr/local/bin/sudocrosh"

print_banner() {
  echo -e "${MAGENTA}${BOLD}"
  echo "  ███████╗██╗   ██╗██████╗  ██████╗  ██████╗██████╗  ██████╗ ███████╗██╗  ██╗"
  echo "  ██╔════╝██║   ██║██╔══██╗██╔═══██╗██╔════╝██╔══██╗██╔═══██╗██╔════╝██║  ██║"
  echo "  ███████╗██║   ██║██║  ██║██║   ██║ ██║     ██████╔╝██║   ██║███████╗███████║"
  echo "  ╚════██║██║   ██║██║  ██║██║   ██║ ██║     ██╔══██╗██║   ██║╚════██║██╔══██║"
  echo "  ███████║╚██████╔╝██████╔╝╚██████╔╝╚██████╗██║  ██║╚██████╔╝███████║██║  ██║"
  echo "  ╚══════╝ ╚═════╝ ╚═════╝  ╚═════╝  ╚═════╝╚═╝  ╚═╝ ╚═════╝ ╚══════╝╚═╝  ╚═╝"
  echo -e "${RESET}"
  echo -e "${CYAN}${BOLD}        SSH-based sudo enabler for ChromeOS crosh — Dev Mode${RESET}"
  echo -e "${YELLOW}        ─────────────────────────────────────────────────────${RESET}"
  echo ""
}

step() { echo -e "${CYAN}${BOLD}[→]${RESET} ${BOLD}$1${RESET}"; }
ok()   { echo -e "${GREEN}${BOLD}[✓]${RESET} $1"; }
warn() { echo -e "${YELLOW}${BOLD}[!]${RESET} $1"; }
err()  { echo -e "${RED}${BOLD}[✗]${RESET} $1"; exit 1; }

print_banner

step "Setting up SSH directory..."
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"
ok "SSH directory ready at $SSH_DIR"

step "Generating SSH keypair..."
ssh-keygen -t rsa -N "" -f "$KEY" -q 2>/dev/null || true
ok "Keypair generated at $KEY"

step "Authorizing key..."
cat "$KEY.pub" > "$SSH_DIR/authorized_keys"
chmod 600 "$SSH_DIR/authorized_keys"
ok "Key authorized"

step "Generating SSH host keys..."
sudo ssh-keygen -A
ok "Host keys generated in /etc/ssh/"

step "Starting SSH daemon..."
sudo /usr/sbin/sshd && ok "sshd started successfully" || err "Failed to start sshd"

step "Installing boot persistence..."
sudo tee "$STARTUP" > /dev/null <<'EOF'
description "sudocrosh SSH sudo enabler"
start on started system-services
script
  ssh-keygen -A
  /usr/sbin/sshd
end script
EOF
ok "Boot persistence installed at $STARTUP"

step "Installing sudocrosh shortcut..."
sudo tee "$SHORTCUT" > /dev/null <<'EOF'
#!/bin/bash
ssh localhost -l chronos -i /home/chronos/user/.ssh/id_rsa -o StrictHostKeyChecking=no
EOF
sudo chmod +x "$SHORTCUT"
ok "Shortcut installed at $SHORTCUT"

echo ""
echo -e "${GREEN}${BOLD}╔══════════════════════════════════════════╗${RESET}"
echo -e "${GREEN}${BOLD}║           Setup Complete !                       ║${RESET}"
echo -e "${GREEN}${BOLD}╚══════════════════════════════════════════╝${RESET}"
echo ""
echo -e "  From now on, just type in ${CYAN}${BOLD}crosh shell${RESET}:"
echo ""
echo -e "    ${MAGENTA}${BOLD}sudocrosh${RESET}"
echo ""
echo -e "  That's it — ${GREEN}full sudo access${RESET}, no VT2 needed!"
echo ""
warn "ChromeOS updates may wipe persistence. Re-run from VT2 if sudo stops working."
echo ""
