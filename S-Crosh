#!/bin/bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
RESET='\033[0m'

SSH_DIR="/home/chronos/user/.ssh"
KEY="$SSH_DIR/id_rsa"
STARTUP="/etc/init/sudocrosh-ssh.conf"
SHORTCUT="/usr/local/bin/sudocrosh"

step() { echo -e "${CYAN}${BOLD}[вҶ’]${RESET} ${BOLD}$1${RESET}"; }
ok()   { echo -e "${GREEN}${BOLD}[вң“]${RESET} $1"; }
warn() { echo -e "${YELLOW}${BOLD}[!]${RESET} $1"; }
err()  { echo -e "${RED}${BOLD}[вң—]${RESET} $1"; exit 1; }

echo -e "${MAGENTA}${BOLD}"
echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—"
echo "  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘"
echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘"
echo "  в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘"
echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘"
echo "  в•ҡв•җв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ"
echo -e "${RESET}"
echo -e "${CYAN}${BOLD}        SSH-based sudo enabler for ChromeOS crosh вҖ” Dev Mode${RESET}"
echo -e "${YELLOW}        в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${RESET}"
echo ""

step "Setting up SSH directory..."
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"
ok "SSH directory ready"

step "Generating SSH keypair..."
if [ ! -f "$KEY" ]; then
  ssh-keygen -t rsa -N "" -f "$KEY" -q
  ok "Keypair generated"
else
  ok "Keypair already exists, skipping"
fi

step "Authorizing key..."
cat "$KEY.pub" > "$SSH_DIR/authorized_keys"
chmod 600 "$SSH_DIR/authorized_keys"
ok "Key authorized"

step "Generating host keys in /tmp..."
sudo ssh-keygen -t rsa -N "" -f /tmp/ssh_host_rsa_key -q 2>/dev/null || true
sudo ssh-keygen -t ecdsa -N "" -f /tmp/ssh_host_ecdsa_key -q 2>/dev/null || true
sudo ssh-keygen -t ed25519 -N "" -f /tmp/ssh_host_ed25519_key -q 2>/dev/null || true
ok "Host keys generated in /tmp/"

step "Starting SSH daemon..."
sudo /usr/sbin/sshd \
  -o HostKey=/tmp/ssh_host_rsa_key \
  -o HostKey=/tmp/ssh_host_ecdsa_key \
  -o HostKey=/tmp/ssh_host_ed25519_key \
  -o AuthorizedKeysFile=/home/chronos/user/.ssh/authorized_keys \
  && ok "sshd started successfully" || err "Failed to start sshd"

step "Installing boot persistence..."
sudo tee "$STARTUP" > /dev/null <<'EOF'
description "sudocrosh SSH sudo enabler"
start on started system-services
script
  ssh-keygen -t rsa -N "" -f /tmp/ssh_host_rsa_key
  ssh-keygen -t ecdsa -N "" -f /tmp/ssh_host_ecdsa_key
  ssh-keygen -t ed25519 -N "" -f /tmp/ssh_host_ed25519_key
  /usr/sbin/sshd \
    -o HostKey=/tmp/ssh_host_rsa_key \
    -o HostKey=/tmp/ssh_host_ecdsa_key \
    -o HostKey=/tmp/ssh_host_ed25519_key \
    -o AuthorizedKeysFile=/home/chronos/user/.ssh/authorized_keys
end script
EOF
ok "Boot persistence installed"

step "Installing sudocrosh shortcut..."
sudo tee "$SHORTCUT" > /dev/null <<'EOF'
#!/bin/bash
ssh localhost -l chronos -i /home/chronos/user/.ssh/id_rsa -o StrictHostKeyChecking=no
EOF
sudo chmod +x "$SHORTCUT"
ok "Shortcut installed"

echo ""
echo -e "${GREEN}${BOLD}в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${RESET}"
echo -e "${GREEN}${BOLD}в•‘           Setup Complete! рҹҺү             в•‘${RESET}"
echo -e "${GREEN}${BOLD}в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${RESET}"
echo ""
echo -e "  From now on, just type in ${CYAN}${BOLD}crosh shell${RESET}:"
echo ""
echo -e "    ${MAGENTA}${BOLD}sudocrosh${RESET}"
echo ""
echo -e "  That's it вҖ” ${GREEN}full sudo access${RESET}, no VT2 needed!"
echo ""
warn "ChromeOS updates may wipe persistence. Re-run from VT2 if sudo stops working."
echo ""
