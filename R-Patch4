#!/bin/bash

VERSION="v3.1.0"
AUTHOR="CriticalHD/neonnebula"

CYAN='\033[0;36m'
WHITE='\033[1;37m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

get_tpmver() {
    tpmc tpmver 2>/dev/null
}

# Convert integer → little endian bytes
to_le_bytes() {
    local val=$1
    printf "%02x %02x %02x %02x" \
        $(( val & 0xFF )) \
        $(( (val >> 8) & 0xFF )) \
        $(( (val >> 16) & 0xFF )) \
        $(( (val >> 24) & 0xFF ))
}

write_kernver_safe() {
    echo
    echo -e "${YELLOW}Enter rollback value (0-7 recommended):${NC}"
    read -r value < /dev/tty

    if [[ ! "$value" =~ ^[0-9]+$ ]]; then
        echo -e "${RED}Invalid number${NC}"
        sleep 1
        return
    fi

    BYTES=$(to_le_bytes "$value")

    echo
    echo -e "${CYAN}[*] About to write:${NC}"
    echo -e "Value: ${WHITE}$value${NC}"
    echo -e "Bytes: ${WHITE}$BYTES${NC}"
    echo -e "${RED}This can affect boot behavior!${NC}"
    echo

    read -p "Confirm write? (y/N): " confirm < /dev/tty

    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && return

    echo -e "${CYAN}[*] Writing to TPM (0x1008)...${NC}"

    OUTPUT=$(tpmc write 0x1008 $BYTES 2>&1)

    echo
    echo -e "${GREEN}Done.${NC}"
    echo "Output:"
    echo "$OUTPUT"

    echo
    read -p "Press Enter..." < /dev/tty
}

while true; do
    clear

    echo -e "${CYAN}======================================${NC}"
    echo -e "${WHITE}        R-Patch ${VERSION}${NC}"
    echo -e "${YELLOW}    by ${AUTHOR}${NC}"
    echo -e "${CYAN}======================================${NC}"
    echo

    echo -e "${BLUE}TPM Info:${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo -e "TPM Ver: ${WHITE}$(get_tpmver)${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo

    echo -e "${CYAN}[1] Set Rollback Value (Safe)${NC}"
    echo -e "${CYAN}[Q] Quit${NC}"
    echo

    read -r -p "Choice: " choice < /dev/tty

    case "$choice" in
        1) write_kernver_safe ;;
        [Qq]) exit 0 ;;
    esac
done
