#!/bin/bash

# --- Color Definitions ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Root Check
if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}Please run this script with sudo.${NC}"
  exit 1
fi

get_status() {
    current_op=$(update_engine_client --status 2>/dev/null | grep "CURRENT_OP" | cut -d'=' -f2)
    [ -z "$current_op" ] && current_op="IDLE"

    if [[ "$current_op" == "UPDATE_STATUS_IDLE" ]]; then
        op_display="${GREEN}$current_op${NC}"
    elif [[ "$current_op" == "UPDATE_STATUS_UPDATED_NEED_REBOOT" ]]; then
        op_display="${RED}REBOOT PENDING${NC}"
    else
        op_display="${YELLOW}$current_op${NC}"
    fi

    vpd_val=$(vpd -i RW_VPD -l 2>/dev/null | grep "omahaserver" | cut -d'"' -f2)
    if [ -z "$vpd_val" ]; then
        niaub_state="${RED}DISABLED${NC}"
    else
        niaub_state="${GREEN}ENABLED${NC}"
    fi
}

render() {
    clear
    echo -e "${CYAN}==================================================${NC}"
    echo -e "${CYAN}            NIAUB MANAGEMENT UTILITY              ${NC}"
    echo -e "${CYAN}            Version: 2.0 | Author: CriticalHD         ${NC}"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " STATUS: $op_display"
    echo -e " NIAUB:  $niaub_state"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " ${YELLOW}1)${NC} Enable NIAUB"
    echo -e " ${YELLOW}2)${NC} Disable NIAUB"
    echo -e " ${YELLOW}3)${NC} View Credits"
    echo -e " ${YELLOW}4)${NC} Exit"
    echo -e "${CYAN}--------------------------------------------------${NC}"
}

show_credits() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}                CREDITS                   ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    echo -e "Concept:   NIAUB (Omaha VPD Trick)"
    echo -e "Scripting: Gemini AI"
    echo -e "Features:  Partition Reset + Cache Purge"
    echo -e "${CYAN}==========================================${NC}"
    read -p "Press Enter to return to menu..."
    get_status
    render
}

# Initial Boot
get_status
render

while true; do
    read -r -p " Selection: " choice
    case "$choice" in
        1)
            echo -e "${YELLOW}Applying block...${NC}"
            vpd -i RW_VPD -s "omahaserver=http://127.0.0.1"
            dump_vpd_log --force
            stop update-engine >/dev/null 2>&1
            rm -rf /var/lib/update_engine/prefs/*
            /usr/sbin/chromeos-setgoodkernel >/dev/null 2>&1
            start update-engine >/dev/null 2>&1
            get_status
            render
            ;;
        2)
            echo -e "${YELLOW}Removing block...${NC}"
            vpd -i RW_VPD -d "omahaserver"
            dump_vpd_log --force
            stop update-engine >/dev/null 2>&1
            rm -rf /var/lib/update_engine/prefs/*
            start update-engine >/dev/null 2>&1
            get_status
            render
            ;;
        3)
            show_credits
            ;;
        4|e|E)
            echo -e "${BLUE}Exiting...${NC}"
            exit 0
            ;;
        "")
            # Keeps the menu from re-drawing if you just hit Enter
            continue
            ;;
        *)
            echo -e "${RED}Invalid selection.${NC}"
            ;;
    esac
done
