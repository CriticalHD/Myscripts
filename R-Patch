#!/bin/bash

INDEX="0x1008"
WORKDIR="/mnt/stateful_partition/rpatch_work"
PATCH_FLAG="$WORKDIR/.fw_patched"
DEVKEYS="/usr/share/vboot/devkeys"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m"

stop_tpm_daemon() {
    [[ "$TPM_VER" == "1.2" ]] && sudo initctl stop tcsd 2>/dev/null \
                               || sudo initctl stop trunksd 2>/dev/null
}

start_tpm_daemon() {
    [[ "$TPM_VER" == "1.2" ]] && sudo initctl start tcsd 2>/dev/null \
                               || sudo initctl start trunksd 2>/dev/null
}

get_info() {
    TPM_VER=$(tpmc tpmver 2>/dev/null | tr -d '\n')
    [[ -z "$TPM_VER" ]] && TPM_VER="?"
    if [[ "$TPM_VER" == "1.2" ]]; then
        GSC_TYPE="preCr50"
    else
        GSC_TYPE=$(gsctool -a -I 2>/dev/null | grep -qi AllowUnverifiedRo && echo "ti50" || echo "cr50")
    fi
    stop_tpm_daemon
    local raw=$(tpmc read $INDEX 9 2>/dev/null)
    local fb=$(echo "$raw" | awk '{print $1}')
    case "$fb" in
        "02") STRUCT_VER="V0" ;;
        "10") STRUCT_VER="V1" ;;
        *)    STRUCT_VER="?"  ;;
    esac
    local b=($raw)
    if [[ "$STRUCT_VER" == "V0" ]]; then
        local lo=$((16#${b[5]:-0})) hi=$((16#${b[7]:-0}))
        local val=$(( lo | (hi << 16) ))
        KV_NUM=$( [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF )) )
    elif [[ "$STRUCT_VER" == "V1" ]]; then
        local lo=$((16#${b[4]:-0})) hi=$((16#${b[6]:-0}))
        local val=$(( lo | (hi << 16) ))
        KV_NUM=$( [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF )) )
    else
        KV_NUM="?"
    fi
    local vf=$(tpmc getvf 2>/dev/null)
    if echo "$vf" | grep -q "phEnable 1"; then
        PH_STATUS="${GREEN}Enabled${NC}"
    elif echo "$vf" | grep -q "phEnable 0"; then
        PH_STATUS="${RED}Disabled${NC}"
    else
        PH_STATUS="${YELLOW}Unknown${NC}"
    fi
    start_tpm_daemon
}

is_fw_patched() { [[ -f "$PATCH_FLAG" ]]; }

draw_header() {
    clear
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}  ${BOLD}R-Patch v6.9${NC}  ${CYAN}·  CriticalHD${NC}"
    echo -e "${CYAN}================================${NC}"
    if is_fw_patched; then
        echo -e " Firmware  : ${GREEN}PATCHED${NC}"
    else
        echo -e " Firmware  : ${RED}NOT PATCHED${NC}"
    fi
    echo -e " TPM       : ${CYAN}${TPM_VER}${NC}"
    echo -e " GSC       : ${CYAN}${GSC_TYPE}${NC}"
    echo -e " Kernver   : ${YELLOW}KV${KV_NUM}${NC}"
    echo -e " Struct    : ${CYAN}${STRUCT_VER}${NC}"
    echo -e " Plat.Hier : $(echo -e $PH_STATUS)"
    echo -e "${CYAN}================================${NC}"
    echo
}

to_le32() {
    local v=$1
    printf "%02x %02x %02x %02x" \
        $((v & 0xFF)) $(((v>>8) & 0xFF)) $(((v>>16) & 0xFF)) $(((v>>24) & 0xFF))
}

crc8() {
    local data=("$@") crc=0
    for byte in "${data[@]}"; do
        local b=$((16#$byte))
        for ((i=0;i<8;i++)); do
            local mix=$(( (crc ^ b) & 1 ))
            crc=$(( crc >> 1 ))
            (( mix )) && crc=$(( crc ^ 0x8C ))
            b=$(( b >> 1 ))
        done
    done
    printf "%02x" $crc
}

build_struct() {
    local ver=$1 kv=$2
    if [[ "$ver" == "V0" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local full=("02" "4c" "57" "52" "47" "${kv_b[@]}" "00" "00" "00" "00")
        full[11]=$(crc8 "${full[@]:0:11}")
    elif [[ "$ver" == "V1" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local ec=()
        for ((i=0;i<32;i++)); do ec+=("00"); done
        local full=("10" "28" "00" "00" "${kv_b[@]}" "${ec[@]}")
        full[2]=$(crc8 "${full[@]:3}")
    else
        echo -e "${RED}Unknown struct version${NC}"; return 1
    fi
    echo "${full[@]}"
}

change_rollback() {
    if ! is_fw_patched; then
        echo -e "${RED}Patch firmware first (option 2).${NC}"
        read -r </dev/tty; return
    fi
    echo -e "${CYAN}Current: KV${KV_NUM} (${STRUCT_VER})${NC}"
    echo
    echo -e " ${YELLOW}0${NC}) KV0 — boots all versions"
    echo -e " ${YELLOW}1${NC}) KV1 — boots all versions"
    echo -e " ${YELLOW}2${NC}) KV2 — boots R112+"
    echo -e " ${YELLOW}3${NC}) KV3 — boots R120+"
    echo -e " ${YELLOW}4${NC}) KV4 — boots R125+"
    echo -e " ${YELLOW}5${NC}) KV5 — boots R133+"
    echo -e " ${YELLOW}6${NC}) KV6 — boots R138+"
    echo -e " ${YELLOW}7${NC}) KV7 — boots R144+"
    echo -e " ${YELLOW}B${NC}) Back"
    echo -n "> "; read -r kv </dev/tty
    [[ "$kv" =~ ^[Bb]$ ]] && return
    [[ ! "$kv" =~ ^[0-7]$ ]] && { echo -e "${RED}Invalid.${NC}"; sleep 1; return; }
    local kv_val
    [[ "$kv" == "0" ]] && kv_val=0 || kv_val=$(( 0x00010000 + kv ))
    local bytes=($(build_struct "$STRUCT_VER" "$kv_val"))
    [[ $? -ne 0 ]] && return
    echo -e "${YELLOW}Set kernver to KV${kv}? (y/N):${NC} "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return
    stop_tpm_daemon
    tpmc write $INDEX "${bytes[@]}"
    local rc=$?
    start_tpm_daemon
    if [[ $rc -eq 0 ]]; then
        echo -e "${GREEN}Done. KV set to ${kv}.${NC}"
        get_info
    else
        echo -e "${RED}Write failed (code $rc).${NC}"
        echo -e "${YELLOW}Check platform hierarchy status in header.${NC}"
    fi
    read -r </dev/tty
}

# Key insight: tlcl_disable_platform_hierarchy is a SMALL function.
# It passes args in REGISTERS not stack (x86-64 calling convention):
#   edi = hc.enable = 0x4000000C  -> BF 0C 00 00 40
#   esi = hc.state  = 0           -> preceded by XOR esi,esi or MOV esi,0
# The stack stores we found are from marshal_hierarchy_control which is a
# DIFFERENT function that handles all hierarchy types.
# We need: BF 0C 00 00 40 (MOV edi,0x4000000C) with state=0 nearby.
scan_fw() {
    local file="$1"
    python3 - "$file" <<'PYEOF'
import sys
with open(sys.argv[1],'rb') as f: d=f.read()
print(f"  File: {sys.argv[1]} ({len(d)} bytes)")

# Search for all register-load patterns of 0x4000000C
# These are what a small leaf function would use (args in regs)
patterns = [
    (bytes([0xBF,0x0C,0x00,0x00,0x40]), "MOV edi,0x4000000C"),
    (bytes([0xBE,0x0C,0x00,0x00,0x40]), "MOV esi,0x4000000C"),
    (bytes([0xB8,0x0C,0x00,0x00,0x40]), "MOV eax,0x4000000C"),
    (bytes([0xB9,0x0C,0x00,0x00,0x40]), "MOV ecx,0x4000000C"),
    (bytes([0xBA,0x0C,0x00,0x00,0x40]), "MOV edx,0x4000000C"),
    # REX variants for 64-bit
    (bytes([0x41,0xBF,0x0C,0x00,0x00,0x40]), "MOV r15d,0x4000000C"),
    (bytes([0x41,0xBE,0x0C,0x00,0x00,0x40]), "MOV r14d,0x4000000C"),
]

for pat, label in patterns:
    hits = [i for i in range(len(d)-len(pat)) if d[i:i+len(pat)]==pat]
    if hits:
        print(f"  {label}: {len(hits)} hit(s)")
        for i in hits:
            ctx = d[max(0,i-16):i+32]
            print(f"    0x{i:08x}: {ctx.hex(' ')}")
            # Show what's nearby — look for zero-state indicators
            pre  = d[max(0,i-16):i]
            post = d[i+len(pat):i+len(pat)+16]
            # XOR reg,reg patterns
            xors = {0xC0:'eax',0xC9:'ecx',0xD2:'edx',0xF6:'esi',0xFF:'edi',0xDB:'ebx'}
            for j in range(len(pre)-1):
                if pre[j]==0x31 and pre[j+1] in xors:
                    print(f"      PRE: XOR {xors[pre[j+1]]},{xors[pre[j+1]]} at -{len(pre)-j} (state=0 indicator)")
            for j in range(len(post)-1):
                if post[j]==0x31 and post[j+1] in xors:
                    print(f"      POST: XOR {xors[post[j+1]]},{xors[post[j+1]]} at +{len(pat)+j} (state=0 indicator)")
            # MOV reg,0
            for j in range(len(post)-4):
                if post[j] in (0xBF,0xBE,0xB8,0xB9,0xBA) and post[j+1]==0x00 and post[j+2]==0x00 and post[j+3]==0x00 and post[j+4]==0x00:
                    print(f"      POST: MOV reg,0 at +{len(pat)+j} (state=0)")
PYEOF
}

patch_region() {
    local file="$1" out="$2"
    python3 - "$file" "$out" <<'PYEOF'
import sys
with open(sys.argv[1],'rb') as f: d=bytearray(f.read())
n=0

# Patterns: MOV reg, 0x4000000C (register-based calling convention)
reg_patterns = [
    bytes([0xBF,0x0C,0x00,0x00,0x40]),  # MOV edi
    bytes([0xBE,0x0C,0x00,0x00,0x40]),  # MOV esi
    bytes([0xB8,0x0C,0x00,0x00,0x40]),  # MOV eax
    bytes([0xB9,0x0C,0x00,0x00,0x40]),  # MOV ecx
    bytes([0xBA,0x0C,0x00,0x00,0x40]),  # MOV edx
]

xors = {0xC0:'eax',0xC9:'ecx',0xD2:'edx',0xF6:'esi',0xFF:'edi',0xDB:'ebx'}
# Map XOR second byte to MOV reg8,1 replacement
xor_to_mov1 = {
    0xC0: bytes([0xB0,0x01]),  # MOV al,1
    0xC9: bytes([0xB1,0x01]),  # MOV cl,1
    0xD2: bytes([0xB2,0x01]),  # MOV dl,1
    0xF6: bytes([0xB6,0x01]),  # MOV sil,1 (needs REX but same size)
    0xFF: bytes([0xB7,0x01]),  # MOV dil,1
    0xDB: bytes([0xB3,0x01]),  # MOV bl,1
}

for pat in reg_patterns:
    for i in range(len(d)-len(pat)):
        if d[i:i+len(pat)]==pat:
            pre  = d[max(0,i-16):i]
            post = d[i+len(pat):i+len(pat)+16]

            # Look for XOR reg,reg in pre (state=0 zeroing before enable load)
            patched=False
            for j in range(len(pre)-1):
                if pre[j]==0x31 and pre[j+1] in xor_to_mov1:
                    abs_j=max(0,i-16)+j
                    replacement=xor_to_mov1[pre[j+1]]
                    d[abs_j]=replacement[0]
                    d[abs_j+1]=replacement[1]
                    n+=1; patched=True
                    print(f"  PATCHED(XOR->MOV8 1) @0x{abs_j:08x} near enable@0x{i:08x}")
                    break

            if not patched:
                # Look for MOV reg,0 in post (state=0 after enable load)
                for j in range(len(post)-4):
                    if post[j] in (0xBF,0xBE,0xB8,0xB9,0xBA) and post[j+1]==0x00 and post[j+2:j+5]==b'\x00\x00\x00':
                        abs_j=i+len(pat)+j
                        d[abs_j+1]=0x01
                        n+=1; patched=True
                        print(f"  PATCHED(MOV reg,0->1) @0x{abs_j:08x} near enable@0x{i:08x}")
                        break

            if not patched:
                # Look for XOR reg,reg in post
                for j in range(len(post)-1):
                    if post[j]==0x31 and post[j+1] in xor_to_mov1:
                        abs_j=i+len(pat)+j
                        replacement=xor_to_mov1[post[j+1]]
                        d[abs_j]=replacement[0]
                        d[abs_j+1]=replacement[1]
                        n+=1; patched=True
                        print(f"  PATCHED(XOR->MOV8 1 post) @0x{abs_j:08x} near enable@0x{i:08x}")
                        break

# Fallback: full BE TPM packet
patA=bytes([0x40,0x00,0x00,0x0C,0x00,0x00,0x00,0x09,0x40,0x00,0x00,0x09,
            0x00,0x00,0x01,0x00,0x00,0x40,0x00,0x00,0x0C,0x00])
for i in range(len(d)-len(patA)):
    if d[i:i+len(patA)]==patA:
        d[i+len(patA)-1]=0x01; n+=1
        print(f"  PATCHED(TPM packet) @0x{i:08x}")

print(f"  Total patches: {n}")
if n==0:
    print(f"  No patchable pattern found in {sys.argv[1]}")
with open(sys.argv[2],'wb') as f: f.write(d)
PYEOF
}

patch_firmware() {
    echo -e "${YELLOW}Patches firmware to keep platform hierarchy enabled.${NC}"
    echo -e "${RED}Brick risk. Ensure SPI WP is off.${NC}"
    echo -n "Continue? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    if ! command -v python3 &>/dev/null; then
        echo -e "${RED}python3 not found. Run dev_install manually first.${NC}"
        read -r </dev/tty; return
    fi

    echo -e "${CYAN}[1/5] Preparing workspace...${NC}"
    mkdir -p "$WORKDIR"
    if ! mount | grep -q "stateful_partition.*rw"; then
        sudo mount -o remount,rw,exec /mnt/stateful_partition 2>/dev/null
        [[ $? -ne 0 ]] && { echo -e "${RED}      Cannot remount stateful rw.${NC}"; read -r </dev/tty; return; }
    fi
    echo -e "${GREEN}      Ready.${NC}"

    echo -e "${CYAN}[2/5] Checking SPI write protection...${NC}"
    local wp=$(flashrom -p internal --wp-status 2>/dev/null)
    if echo "$wp" | grep -qi "Protection mode: hardware"; then
        echo -e "${RED}      Hardware WP ON. Disable first.${NC}"
        read -r </dev/tty; return
    elif echo "$wp" | grep -qi "disabled\|WP: status: 0\|Protection mode: disabled"; then
        echo -e "${GREEN}      WP off.${NC}"
    else
        echo -e "${YELLOW}      WP unclear. Continue? (y/N):${NC} "; read -r c </dev/tty
        [[ "$c" != "y" && "$c" != "Y" ]] && return
    fi

    echo -e "${CYAN}[3/5] Reading firmware...${NC}"
    flashrom -p internal -r "$WORKDIR/fw.bin" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}      Dump failed.${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}      Done.${NC}"

    echo -e "${CYAN}[4/5] Scanning and patching...${NC}"
    cd "$WORKDIR"
    futility dump_fmap -x fw.bin FW_MAIN_A FW_MAIN_B 2>/dev/null
    if [[ ! -f "$WORKDIR/FW_MAIN_A" || ! -f "$WORKDIR/FW_MAIN_B" ]]; then
        echo -e "${RED}      Region extraction failed.${NC}"
        read -r </dev/tty; return
    fi

    local found_patch=0
    for region in FW_MAIN_A FW_MAIN_B; do
        echo -e "${YELLOW}      Scanning ${region}...${NC}"
        scan_fw "$WORKDIR/$region"
        local patch_out
        patch_out=$(patch_region "$WORKDIR/$region" "$WORKDIR/${region}.p" 2>&1)
        echo "$patch_out"
        if echo "$patch_out" | grep -q "PATCHED"; then
            found_patch=1
        fi
        cp "$WORKDIR/${region}.p" "$WORKDIR/$region"
    done

    if [[ $found_patch -eq 0 ]]; then
        echo -e "${RED}      No patchable pattern found.${NC}"
        echo -e "${YELLOW}      (f) Force  (R) Return${NC}"
        echo -n "      > "; read -r fc </dev/tty
        [[ "$fc" != "f" && "$fc" != "F" ]] && return
    fi

    futility load_fmap "$WORKDIR/fw.bin" \
        "FW_MAIN_A:$WORKDIR/FW_MAIN_A" \
        "FW_MAIN_B:$WORKDIR/FW_MAIN_B" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}      Reassembly failed.${NC}"
        echo -e "${YELLOW}      (f) Force  (R) Return${NC}"
        echo -n "      > "; read -r fc </dev/tty
        [[ "$fc" != "f" && "$fc" != "F" ]] && return
    fi
    echo -e "${GREEN}      Reassembled.${NC}"

    echo -e "${CYAN}[5/5] Signing...${NC}"
    futility sign \
        --signprivate "$DEVKEYS/firmware_data_key.vbprivk" \
        --keyblock "$DEVKEYS/firmware.keyblock" \
        --kernelkey "$DEVKEYS/kernel_subkey.vbpubk" \
        --version 1 \
        "$WORKDIR/fw.bin" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${YELLOW}      futility sign failed, trying make_dev_firmware.sh...${NC}"
        /usr/share/vboot/bin/make_dev_firmware.sh --nomod_hwid --nomod_gbb 2>/dev/null
        if [[ $? -ne 0 ]]; then
            echo -e "${RED}      Signing failed.${NC}"
            echo -e "${YELLOW}      (f) Force unsigned  (R) Return${NC}"
            echo -n "      > "; read -r fc </dev/tty
            [[ "$fc" != "f" && "$fc" != "F" ]] && return
        fi
    fi
    echo -e "${GREEN}      Signed.${NC}"

    echo
    echo -e "${RED}Point of no return.${NC}"
    echo -n "Flash? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && { echo "Aborted."; read -r </dev/tty; return; }

    flashrom -p internal -w "$WORKDIR/fw.bin" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}      Flash failed.${NC}"; read -r </dev/tty; return
    fi

    touch "$PATCH_FLAG"
    echo -e "${GREEN}      Done! Reboot to apply.${NC}"
    read -r </dev/tty
}

show_credits() {
    clear
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}          R-Patch v6.9${NC}"
    echo -e "${CYAN}================================${NC}"
    echo -e " ${BOLD}Code${NC}       : CriticalHD"
    echo -e " ${BOLD}AI Assist${NC}  : Claude (Anthropic)"
    echo -e " ${BOLD}KVS Ref${NC}    : kxtzownsu"
    echo -e " ${BOLD}CrOS Tools${NC} : Google (tpmc, futility, flashrom)"
    echo -e " ${BOLD}Thanks${NC}     : codenerd67, Sh1mmer team"
    echo -e "${CYAN}================================${NC}"
    echo
    echo "Press Enter to return..."
    read -r </dev/tty
}

get_info

while true; do
    draw_header
    if is_fw_patched; then
        echo -e " ${YELLOW}1)${NC} Change Rollback"
    else
        echo -e " ${RED}1) Change Rollback [patch firmware first]${NC}"
    fi
    echo -e " ${YELLOW}2)${NC} Patch Firmware"
    echo -e " ${YELLOW}3)${NC} Credits"
    echo -e " ${YELLOW}E)${NC} Exit"
    echo -n "> "; read -r choice </dev/tty
    case "$choice" in
        1) change_rollback ;;
        2) patch_firmware ;;
        3) show_credits ;;
        [Ee]) exit 0 ;;
        *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
    esac
done
