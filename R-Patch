#!/bin/bash

# ─── Constants ───────────────────────────────────────────────────────────────
INDEX="0x1008"
WORKDIR="/mnt/stateful_partition/rpatch_work"
PATCH_FLAG="$WORKDIR/.fw_patched"
DEVKEYS="/usr/share/vboot/devkeys"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m"

# ─── TPM Daemon ──────────────────────────────────────────────────────────────
stop_tpm_daemon() {
    [[ "$TPM_VER" == "1.2" ]] && sudo initctl stop tcsd 2>/dev/null \
                               || sudo initctl stop trunksd 2>/dev/null
}

start_tpm_daemon() {
    [[ "$TPM_VER" == "1.2" ]] && sudo initctl start tcsd 2>/dev/null \
                               || sudo initctl start trunksd 2>/dev/null
}

# ─── System Info ─────────────────────────────────────────────────────────────
get_info() {
    TPM_VER=$(tpmc tpmver 2>/dev/null | tr -d '\n')
    [[ -z "$TPM_VER" ]] && TPM_VER="?"

    if [[ "$TPM_VER" == "1.2" ]]; then
        GSC_TYPE="preCr50"
    else
        GSC_TYPE=$(gsctool -a -I 2>/dev/null | grep -qi AllowUnverifiedRo && echo "ti50" || echo "cr50")
    fi

    stop_tpm_daemon

    local raw=$(tpmc read $INDEX 9 2>/dev/null)
    local fb=$(echo "$raw" | awk '{print $1}')
    case "$fb" in
        "02") STRUCT_VER="V0" ;;
        "10") STRUCT_VER="V1" ;;
        *)    STRUCT_VER="?"  ;;
    esac

    local b=($raw)
    if [[ "$STRUCT_VER" == "V0" ]]; then
        local lo=$((16#${b[5]:-0})) hi=$((16#${b[7]:-0}))
        local val=$(( lo | (hi << 16) ))
        KV_NUM=$( [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF )) )
    elif [[ "$STRUCT_VER" == "V1" ]]; then
        local lo=$((16#${b[4]:-0})) hi=$((16#${b[6]:-0}))
        local val=$(( lo | (hi << 16) ))
        KV_NUM=$( [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF )) )
    else
        KV_NUM="?"
    fi

    local vf=$(tpmc getvf 2>/dev/null)
    if echo "$vf" | grep -q "phEnable 1"; then
        PH_STATUS="${GREEN}Enabled${NC}"
    elif echo "$vf" | grep -q "phEnable 0"; then
        PH_STATUS="${RED}Disabled${NC}"
    else
        PH_STATUS="${YELLOW}Unknown${NC}"
    fi

    start_tpm_daemon
}

is_fw_patched() { [[ -f "$PATCH_FLAG" ]]; }

# ─── Header ──────────────────────────────────────────────────────────────────
draw_header() {
    clear
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}  ${BOLD}R-Patch v6.4${NC}  ${CYAN}·  CriticalHD${NC}"
    echo -e "${CYAN}================================${NC}"
    if is_fw_patched; then
        echo -e " Firmware  : ${GREEN}PATCHED${NC}"
    else
        echo -e " Firmware  : ${RED}NOT PATCHED${NC}"
    fi
    echo -e " TPM       : ${CYAN}${TPM_VER}${NC}"
    echo -e " GSC       : ${CYAN}${GSC_TYPE}${NC}"
    echo -e " Kernver   : ${YELLOW}KV${KV_NUM}${NC}"
    echo -e " Struct    : ${CYAN}${STRUCT_VER}${NC}"
    echo -e " Plat.Hier : $(echo -e $PH_STATUS)"
    echo -e "${CYAN}================================${NC}"
    echo
}

# ─── CRC / Struct ────────────────────────────────────────────────────────────
to_le32() {
    local v=$1
    printf "%02x %02x %02x %02x" \
        $((v & 0xFF)) $(((v>>8) & 0xFF)) $(((v>>16) & 0xFF)) $(((v>>24) & 0xFF))
}

crc8() {
    local data=("$@") crc=0
    for byte in "${data[@]}"; do
        local b=$((16#$byte))
        for ((i=0;i<8;i++)); do
            local mix=$(( (crc ^ b) & 1 ))
            crc=$(( crc >> 1 ))
            (( mix )) && crc=$(( crc ^ 0x8C ))
            b=$(( b >> 1 ))
        done
    done
    printf "%02x" $crc
}

build_struct() {
    local ver=$1 kv=$2
    if [[ "$ver" == "V0" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local full=("02" "4c" "57" "52" "47" "${kv_b[@]}" "00" "00" "00" "00")
        full[11]=$(crc8 "${full[@]:0:11}")
    elif [[ "$ver" == "V1" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local ec=()
        for ((i=0;i<32;i++)); do ec+=("00"); done
        local full=("10" "28" "00" "00" "${kv_b[@]}" "${ec[@]}")
        full[2]=$(crc8 "${full[@]:3}")
    else
        echo -e "${RED}Unknown struct version${NC}"; return 1
    fi
    echo "${full[@]}"
}

# ─── Kernver Switcher ────────────────────────────────────────────────────────
change_rollback() {
    if ! is_fw_patched; then
        echo -e "${RED}Patch firmware first (option 2).${NC}"
        read -r </dev/tty; return
    fi
    echo -e "${CYAN}Current: KV${KV_NUM} (${STRUCT_VER})${NC}"
    echo
    echo -e " ${YELLOW}0${NC}) KV0 — boots all versions"
    echo -e " ${YELLOW}1${NC}) KV1 — boots all versions"
    echo -e " ${YELLOW}2${NC}) KV2 — boots R112+"
    echo -e " ${YELLOW}3${NC}) KV3 — boots R120+"
    echo -e " ${YELLOW}4${NC}) KV4 — boots R125+"
    echo -e " ${YELLOW}5${NC}) KV5 — boots R133+"
    echo -e " ${YELLOW}6${NC}) KV6 — boots R138+"
    echo -e " ${YELLOW}7${NC}) KV7 — boots R144+"
    echo -e " ${YELLOW}B${NC}) Back"
    echo -n "> "; read -r kv </dev/tty
    [[ "$kv" =~ ^[Bb]$ ]] && return
    [[ ! "$kv" =~ ^[0-7]$ ]] && { echo -e "${RED}Invalid.${NC}"; sleep 1; return; }

    local kv_val
    [[ "$kv" == "0" ]] && kv_val=0 || kv_val=$(( 0x00010000 + kv ))

    local bytes=($(build_struct "$STRUCT_VER" "$kv_val"))
    [[ $? -ne 0 ]] && return

    echo -e "${YELLOW}Set kernver to KV${kv}? (y/N):${NC} "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    stop_tpm_daemon
    tpmc write $INDEX "${bytes[@]}"
    local rc=$?
    start_tpm_daemon

    if [[ $rc -eq 0 ]]; then
        echo -e "${GREEN}Done. KV set to ${kv}.${NC}"
        get_info
    else
        echo -e "${RED}Write failed (code $rc).${NC}"
        echo -e "${YELLOW}Check platform hierarchy status in header.${NC}"
    fi
    read -r </dev/tty
}

# ─── Firmware Scanner ────────────────────────────────────────────────────────
scan_fw() {
    local file="$1"
    python3 - "$file" <<'PYEOF'
import sys
with open(sys.argv[1],'rb') as f: d=f.read()

# TPM_RH_PLATFORM = 0x4000000C
# TPM_CC_HIERARCHY_CONTROL = 0x00000121
# On x86-64, values stored as little-endian immediates in mov instructions

patterns = {
    "TPM_RH_PLATFORM BE":   bytes([0x40,0x00,0x00,0x0C]),
    "TPM_RH_PLATFORM LE":   bytes([0x0C,0x00,0x00,0x40]),
    "TPM_CC_HIER_CTRL BE":  bytes([0x00,0x00,0x01,0x21]),
    "TPM_CC_HIER_CTRL LE":  bytes([0x21,0x01,0x00,0x00]),
    # x86: mov dword [rsp+N], 0x4000000c  -> C7 44 24 XX 0C 00 00 40
    "MOV[rsp+N]=PH":        bytes([0xC7,0x44,0x24]),
    # x86: mov dword [rbp-N], 0x4000000c -> C7 45 XX 0C 00 00 40
    "MOV[rbp-N]=PH":        bytes([0xC7,0x45]),
}

for label,pat in patterns.items():
    hits=[]
    for i in range(len(d)-len(pat)-4):
        chunk=d[i:i+len(pat)]
        if chunk==pat:
            # For mov patterns, check if 0x4000000c follows the offset byte
            if label in ("MOV[rsp+N]=PH","MOV[rbp-N]=PH"):
                after=d[i+len(pat)+1:i+len(pat)+5]
                if after==bytes([0x0C,0x00,0x00,0x40]):
                    hits.append(i)
            else:
                hits.append(i)
    print(f"  {label}: {len(hits)} hit(s)")
    for i in hits[:5]:
        print(f"    0x{i:08x}: ...{d[max(0,i-8):i].hex(' ')} | {d[i:i+20].hex(' ')}")
PYEOF
}

# ─── Firmware Patcher ────────────────────────────────────────────────────────
patch_region() {
    local file="$1" out="$2"
    python3 - "$file" "$out" <<'PYEOF'
import sys
with open(sys.argv[1],'rb') as f: d=bytearray(f.read())
n=0

# ── Pattern A: full big-endian TPM packet with password session ──
patA=bytes([
    0x40,0x00,0x00,0x0C,       # authHandle=TPM_RH_PLATFORM
    0x00,0x00,0x00,0x09,       # session size
    0x40,0x00,0x00,0x09,       # TPM_RS_PW
    0x00,0x00,0x01,0x00,0x00,  # nonce+attrs+auth
    0x40,0x00,0x00,0x0C,       # enable=TPM_RH_PLATFORM
    0x00                        # state=0 -> patch to 1
])
for i in range(len(d)-len(patA)):
    if d[i:i+len(patA)]==patA:
        d[i+len(patA)-1]=0x01; n+=1
        print(f"  PatA hit 0x{i:08x} — patched state byte")

# ── Pattern B: mov dword [rsp+N], 0x4000000c followed by state write ──
# C7 44 24 XX 0C 00 00 40  (enable=TPM_RH_PLATFORM stored on stack)
# The state byte (0x00) is typically stored in a nearby mov byte instruction
# We find the enable store, then look ahead for: C6 44 24 YY 00 (mov byte [rsp+Y], 0)
# and patch that 0x00 to 0x01
for i in range(len(d)-20):
    if (d[i]==0xC7 and d[i+1]==0x44 and d[i+2]==0x24 and
            d[i+4:i+8]==bytes([0x0C,0x00,0x00,0x40])):
        # Found enable=TPM_RH_PLATFORM on stack, now look ahead up to 32 bytes
        # for the state byte store: C6 44 24 XX 00
        for j in range(i+8, min(i+40, len(d)-5)):
            if (d[j]==0xC6 and d[j+1]==0x44 and d[j+2]==0x24 and d[j+4]==0x00):
                d[j+4]=0x01; n+=1
                print(f"  PatB hit 0x{i:08x} (enable) + 0x{j:08x} (state) — patched")
                break

# ── Pattern C: mov dword [rbp-N], 0x4000000c ──
# C7 45 XX 0C 00 00 40
for i in range(len(d)-20):
    if (d[i]==0xC7 and d[i+1]==0x45 and
            d[i+3:i+7]==bytes([0x0C,0x00,0x00,0x40])):
        # Look ahead for state byte: C6 45 XX 00
        for j in range(i+7, min(i+40, len(d)-4)):
            if (d[j]==0xC6 and d[j+1]==0x45 and d[j+3]==0x00):
                d[j+3]=0x01; n+=1
                print(f"  PatC hit 0x{i:08x} (enable) + 0x{j:08x} (state) — patched")
                break

# ── Pattern D: mov edi/esi/eax, 0x4000000c (register load) ──
# BF/BE/B8 0C 00 00 40
for prefix in [0xBF, 0xBE, 0xB8]:
    pat=bytes([prefix,0x0C,0x00,0x00,0x40])
    for i in range(len(d)-20):
        if d[i:i+5]==pat:
            # State is likely xor'd or mov'd to 0 nearby — look for xor or mov 0
            # xor reg,reg near the enable load is a common pattern for state=0
            # Most likely: xor edx,edx (31 D2) or mov edx,0 (BA 00 00 00 00)
            ctx=d[i:i+30]
            print(f"  PatD hit 0x{i:08x} prefix=0x{prefix:02x} — context: {ctx.hex(' ')}")
            # Report only — auto-patching register loads needs disassembly

if n==0:
    print(f"  No auto-patchable pattern found in {sys.argv[1]}")
    print(f"  Check PatD hits above for manual analysis")

with open(sys.argv[2],'wb') as f: f.write(d)
PYEOF
}

patch_firmware() {
    echo -e "${YELLOW}Patches firmware to keep platform hierarchy enabled.${NC}"
    echo -e "${RED}Brick risk. Ensure SPI WP is off.${NC}"
    echo -n "Continue? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    if ! command -v python3 &>/dev/null; then
        echo -e "${RED}python3 not found. Run dev_install manually first.${NC}"
        read -r </dev/tty; return
    fi

    echo -e "${CYAN}[1/5] Preparing workspace...${NC}"
    mkdir -p "$WORKDIR"
    if ! mount | grep -q "stateful_partition.*rw"; then
        sudo mount -o remount,rw,exec /mnt/stateful_partition 2>/dev/null
        [[ $? -ne 0 ]] && { echo -e "${RED}      Cannot remount stateful rw.${NC}"; read -r </dev/tty; return; }
    fi
    echo -e "${GREEN}      Ready.${NC}"

    echo -e "${CYAN}[2/5] Checking SPI write protection...${NC}"
    local wp=$(flashrom -p internal --wp-status 2>/dev/null)
    if echo "$wp" | grep -qi "Protection mode: hardware"; then
        echo -e "${RED}      Hardware WP is ON. Disable it first.${NC}"
        read -r </dev/tty; return
    elif echo "$wp" | grep -qi "disabled\|WP: status: 0\|Protection mode: disabled"; then
        echo -e "${GREEN}      WP off.${NC}"
    else
        echo -e "${YELLOW}      WP status unclear. Continue? (y/N):${NC} "; read -r c </dev/tty
        [[ "$c" != "y" && "$c" != "Y" ]] && return
    fi

    echo -e "${CYAN}[3/5] Reading firmware...${NC}"
    flashrom -p internal -r "$WORKDIR/fw.bin" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}      Dump failed.${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}      Done.${NC}"

    echo -e "${CYAN}[4/5] Scanning and patching...${NC}"
    cd "$WORKDIR"
    futility dump_fmap -x fw.bin FW_MAIN_A FW_MAIN_B 2>/dev/null
    if [[ ! -f "$WORKDIR/FW_MAIN_A" || ! -f "$WORKDIR/FW_MAIN_B" ]]; then
        echo -e "${RED}      Region extraction failed.${NC}"
        read -r </dev/tty; return
    fi

    local found_patch=0
    for region in FW_MAIN_A FW_MAIN_B; do
        echo -e "${YELLOW}      Scanning ${region}...${NC}"
        scan_fw "$WORKDIR/$region"
        local patch_out=$(patch_region "$WORKDIR/$region" "$WORKDIR/${region}.p" 2>&1)
        echo "$patch_out"
        echo "$patch_out" | grep -q "patched" && found_patch=1
        cp "$WORKDIR/${region}.p" "$WORKDIR/$region"
    done

    if [[ $found_patch -eq 0 ]]; then
        echo -e "${RED}      No auto-patch applied.${NC}"
        echo -e "${YELLOW}      (f) Force flash anyway  (R) Return${NC}"
        echo -n "      > "; read -r fc </dev/tty
        [[ "$fc" != "f" && "$fc" != "F" ]] && return
    fi

    futility load_fmap "$WORKDIR/fw.bin" \
        "FW_MAIN_A:$WORKDIR/FW_MAIN_A" \
        "FW_MAIN_B:$WORKDIR/FW_MAIN_B" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}      Reassembly failed.${NC}"
        echo -e "${YELLOW}      (f) Force  (R) Return${NC}"
        echo -n "      > "; read -r fc </dev/tty
        [[ "$fc" != "f" && "$fc" != "F" ]] && return
    fi
    echo -e "${GREEN}      Reassembled.${NC}"

    echo -e "${CYAN}[5/5] Signing...${NC}"
    futility sign \
        --signprivate "$DEVKEYS/firmware_data_key.vbprivk" \
        --keyblock "$DEVKEYS/firmware.keyblock" \
        --kernelkey "$DEVKEYS/kernel_subkey.vbpubk" \
        --version 1 \
        "$WORKDIR/fw.bin" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${YELLOW}      futility sign failed, trying make_dev_firmware.sh...${NC}"
        /usr/share/vboot/bin/make_dev_firmware.sh --nomod_hwid --nomod_gbb 2>/dev/null
        if [[ $? -ne 0 ]]; then
            echo -e "${RED}      Signing failed.${NC}"
            echo -e "${YELLOW}      (f) Force flash unsigned  (R) Return${NC}"
            echo -n "      > "; read -r fc </dev/tty
            [[ "$fc" != "f" && "$fc" != "F" ]] && return
        fi
    fi
    echo -e "${GREEN}      Signed.${NC}"

    echo
    echo -e "${RED}Point of no return.${NC}"
    echo -n "Flash? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && { echo "Aborted."; read -r </dev/tty; return; }

    flashrom -p internal -w "$WORKDIR/fw.bin" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}      Flash failed.${NC}"
        read -r </dev/tty; return
    fi

    touch "$PATCH_FLAG"
    echo -e "${GREEN}      Done! Reboot to apply.${NC}"
    read -r </dev/tty
}

# ─── Credits ─────────────────────────────────────────────────────────────────
show_credits() {
    clear
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}          R-Patch v6.4${NC}"
    echo -e "${CYAN}================================${NC}"
    echo -e " ${BOLD}Code${NC}       : CriticalHD"
    echo -e " ${BOLD}AI Assist${NC}  : Claude (Anthropic)"
    echo -e " ${BOLD}KVS Ref${NC}    : kxtzownsu"
    echo -e " ${BOLD}CrOS Tools${NC} : Google (tpmc, futility, flashrom)"
    echo -e " ${BOLD}Thanks${NC}     : codenerd67, Sh1mmer team"
    echo -e "${CYAN}================================${NC}"
    echo
    echo "Press Enter to return..."
    read -r </dev/tty
}

# ─── Init + Loop ─────────────────────────────────────────────────────────────
get_info

while true; do
    draw_header
    if is_fw_patched; then
        echo -e " ${YELLOW}1)${NC} Change Rollback"
    else
        echo -e " ${RED}1) Change Rollback [patch firmware first]${NC}"
    fi
    echo -e " ${YELLOW}2)${NC} Patch Firmware"
    echo -e " ${YELLOW}3)${NC} Credits"
    echo -e " ${YELLOW}E)${NC} Exit"
    echo -n "> "; read -r choice </dev/tty
    case "$choice" in
        1) change_rollback ;;
        2) patch_firmware ;;
        3) show_credits ;;
        [Ee]) exit 0 ;;
        *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
    esac
done
