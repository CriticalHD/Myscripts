#!/bin/bash

VERSION="v1.3.1"
AUTHOR="CriticalHD/neonnebula"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

get_kernver() {
    RAW=$(tpmc read 0x1008 9 2>/dev/null)

    if [[ -z "$RAW" ]]; then
        KERNVER="Unknown"
        return
    fi

    BYTES=$(echo "$RAW" | tail -n1 | grep -oE '([0-9a-fA-F]{2} ){3}[0-9a-fA-F]{2}')

    if [[ -z "$BYTES" ]]; then
        KERNVER="ParseError"
        return
    fi

    read -r b1 b2 b3 b4 <<< "$BYTES"
    VALUE=$(( 0x$b1 | (0x$b2 << 8) | (0x$b3 << 16) | (0x$b4 << 24) ))

    KERNVER=$(printf "0x%08x" "$VALUE")
}

while true; do
    clear

    get_kernver

    echo -e "${CYAN}======================================${NC}"
    echo -e "${WHITE}        R-Patch ${VERSION}${NC}"
    echo -e "${YELLOW}    by ${AUTHOR}${NC}"
    echo -e "${CYAN}======================================${NC}"
    echo

    echo -e "${BLUE}TPM Kernver:${NC} ${WHITE}${KERNVER}${NC}"
    echo

    echo -e "${GREEN}Options:${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo -e "${CYAN}[R] Refresh${NC}"
    echo -e "${CYAN}[Q] Quit${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo

    
    read -r -p "Enter choice: " choice < /dev/tty

    # Prevent empty spam loop
    if [[ -z "$choice" ]]; then
        continue
    fi

    case "$choice" in
        [Qq])
            echo -e "${CYAN}Exiting R-Patch...${NC}"
            exit 0
            ;;
        [Rr])
            continue
            ;;
        *)
            echo -e "${RED}Invalid option!${NC}"
            sleep 1.2
            ;;
    esac
done
