#!/bin/bash

VERSION="v1.3.0"
AUTHOR="CriticalHD/neonnebula"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

get_kernver() {
    RAW=$(tpmc read 0x1008 9 2>/dev/null)

    if [[ -z "$RAW" ]]; then
        KERNVER="Unknown"
        return
    fi

    # Extract last 4 bytes (little endian like KVS)
    # Example format handling similar to his C code
    BYTES=$(echo "$RAW" | tail -n1 | grep -oE '([0-9a-fA-F]{2} ){3}[0-9a-fA-F]{2}')

    if [[ -z "$BYTES" ]]; then
        KERNVER="ParseError"
        return
    fi

    read -r b1 b2 b3 b4 <<< "$BYTES"

    # Convert to integer (little endian)
    VALUE=$(( 0x$b1 | (0x$b2 << 8) | (0x$b3 << 16) | (0x$b4 << 24) ))

    KERNVER_HEX=$(printf "0x%08x" "$VALUE")
    KERNVER="$KERNVER_HEX"
}

while true; do
    clear

    echo -e "${CYAN}[*] Reading TPM kernver (0x1008)...${NC}"
    get_kernver

    # Header
    echo -e "${CYAN}======================================${NC}"
    echo -e "${WHITE}        R-Patch ${VERSION}${NC}"
    echo -e "${YELLOW}    by ${AUTHOR}${NC}"
    echo -e "${CYAN}======================================${NC}"
    echo

    echo -e "${BLUE}TPM Kernver (Parsed):${NC} ${WHITE}${KERNVER}${NC}"
    echo

    echo -e "${GREEN}Options:${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo -e "${CYAN}[R] Refresh${NC}"
    echo -e "${CYAN}[Q] Quit${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo

    read -r -p "Enter choice: " choice

    [[ -z "$choice" ]] && continue

    if [[ "$choice" =~ ^[Qq]$ ]]; then
        echo -e "${CYAN}Exiting R-Patch...${NC}"
        exit 0
    fi

    if [[ "$choice" =~ ^[Rr]$ ]]; then
        continue
    fi

    echo -e "${RED}Invalid option!${NC}"
    sleep 1.2
done
