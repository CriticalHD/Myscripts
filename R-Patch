#!/bin/bash

INDEX="0x1008"
WORKDIR="/mnt/stateful_partition/rpatch_work"
PATCH_FLAG="$WORKDIR/.fw_patched"
DEVKEYS="/usr/share/vboot/devkeys"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m"

stop_tpm_daemon() {
    [[ "$TPM_VER" == "1.2" ]] && sudo initctl stop tcsd 2>/dev/null \
                               || sudo initctl stop trunksd 2>/dev/null
}

start_tpm_daemon() {
    [[ "$TPM_VER" == "1.2" ]] && sudo initctl start tcsd 2>/dev/null \
                               || sudo initctl start trunksd 2>/dev/null
}

get_info() {
    TPM_VER=$(tpmc tpmver 2>/dev/null | tr -d '\n')
    [[ -z "$TPM_VER" ]] && TPM_VER="?"
    if [[ "$TPM_VER" == "1.2" ]]; then
        GSC_TYPE="preCr50"
    else
        GSC_TYPE=$(gsctool -a -I 2>/dev/null | grep -qi AllowUnverifiedRo && echo "ti50" || echo "cr50")
    fi
    stop_tpm_daemon
    local raw=$(tpmc read $INDEX 9 2>/dev/null)
    local fb=$(echo "$raw" | awk '{print $1}')
    case "$fb" in
        "02") STRUCT_VER="V0" ;;
        "10") STRUCT_VER="V1" ;;
        *)    STRUCT_VER="?"  ;;
    esac
    local b=($raw)
    if [[ "$STRUCT_VER" == "V0" ]]; then
        local lo=$((16#${b[5]:-0})) hi=$((16#${b[7]:-0}))
        local val=$(( lo | (hi << 16) ))
        KV_NUM=$( [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF )) )
    elif [[ "$STRUCT_VER" == "V1" ]]; then
        local lo=$((16#${b[4]:-0})) hi=$((16#${b[6]:-0}))
        local val=$(( lo | (hi << 16) ))
        KV_NUM=$( [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF )) )
    else
        KV_NUM="?"
    fi
    local vf=$(tpmc getvf 2>/dev/null)
    if echo "$vf" | grep -q "phEnable 1"; then
        PH_STATUS="${GREEN}Enabled${NC}"
    elif echo "$vf" | grep -q "phEnable 0"; then
        PH_STATUS="${RED}Disabled${NC}"
    else
        PH_STATUS="${YELLOW}Unknown${NC}"
    fi
    start_tpm_daemon
}

is_fw_patched() { [[ -f "$PATCH_FLAG" ]]; }

draw_header() {
    clear
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}  ${BOLD}R-Patch v6.7${NC}  ${CYAN}·  CriticalHD${NC}"
    echo -e "${CYAN}================================${NC}"
    if is_fw_patched; then
        echo -e " Firmware  : ${GREEN}PATCHED${NC}"
    else
        echo -e " Firmware  : ${RED}NOT PATCHED${NC}"
    fi
    echo -e " TPM       : ${CYAN}${TPM_VER}${NC}"
    echo -e " GSC       : ${CYAN}${GSC_TYPE}${NC}"
    echo -e " Kernver   : ${YELLOW}KV${KV_NUM}${NC}"
    echo -e " Struct    : ${CYAN}${STRUCT_VER}${NC}"
    echo -e " Plat.Hier : $(echo -e $PH_STATUS)"
    echo -e "${CYAN}================================${NC}"
    echo
}

to_le32() {
    local v=$1
    printf "%02x %02x %02x %02x" \
        $((v & 0xFF)) $(((v>>8) & 0xFF)) $(((v>>16) & 0xFF)) $(((v>>24) & 0xFF))
}

crc8() {
    local data=("$@") crc=0
    for byte in "${data[@]}"; do
        local b=$((16#$byte))
        for ((i=0;i<8;i++)); do
            local mix=$(( (crc ^ b) & 1 ))
            crc=$(( crc >> 1 ))
            (( mix )) && crc=$(( crc ^ 0x8C ))
            b=$(( b >> 1 ))
        done
    done
    printf "%02x" $crc
}

build_struct() {
    local ver=$1 kv=$2
    if [[ "$ver" == "V0" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local full=("02" "4c" "57" "52" "47" "${kv_b[@]}" "00" "00" "00" "00")
        full[11]=$(crc8 "${full[@]:0:11}")
    elif [[ "$ver" == "V1" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local ec=()
        for ((i=0;i<32;i++)); do ec+=("00"); done
        local full=("10" "28" "00" "00" "${kv_b[@]}" "${ec[@]}")
        full[2]=$(crc8 "${full[@]:3}")
    else
        echo -e "${RED}Unknown struct version${NC}"; return 1
    fi
    echo "${full[@]}"
}

change_rollback() {
    if ! is_fw_patched; then
        echo -e "${RED}Patch firmware first (option 2).${NC}"
        read -r </dev/tty; return
    fi
    echo -e "${CYAN}Current: KV${KV_NUM} (${STRUCT_VER})${NC}"
    echo
    echo -e " ${YELLOW}0${NC}) KV0 — boots all versions"
    echo -e " ${YELLOW}1${NC}) KV1 — boots all versions"
    echo -e " ${YELLOW}2${NC}) KV2 — boots R112+"
    echo -e " ${YELLOW}3${NC}) KV3 — boots R120+"
    echo -e " ${YELLOW}4${NC}) KV4 — boots R125+"
    echo -e " ${YELLOW}5${NC}) KV5 — boots R133+"
    echo -e " ${YELLOW}6${NC}) KV6 — boots R138+"
    echo -e " ${YELLOW}7${NC}) KV7 — boots R144+"
    echo -e " ${YELLOW}B${NC}) Back"
    echo -n "> "; read -r kv </dev/tty
    [[ "$kv" =~ ^[Bb]$ ]] && return
    [[ ! "$kv" =~ ^[0-7]$ ]] && { echo -e "${RED}Invalid.${NC}"; sleep 1; return; }
    local kv_val
    [[ "$kv" == "0" ]] && kv_val=0 || kv_val=$(( 0x00010000 + kv ))
    local bytes=($(build_struct "$STRUCT_VER" "$kv_val"))
    [[ $? -ne 0 ]] && return
    echo -e "${YELLOW}Set kernver to KV${kv}? (y/N):${NC} "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return
    stop_tpm_daemon
    tpmc write $INDEX "${bytes[@]}"
    local rc=$?
    start_tpm_daemon
    if [[ $rc -eq 0 ]]; then
        echo -e "${GREEN}Done. KV set to ${kv}.${NC}"
        get_info
    else
        echo -e "${RED}Write failed (code $rc).${NC}"
        echo -e "${YELLOW}Check platform hierarchy status in header.${NC}"
    fi
    read -r </dev/tty
}

scan_fw() {
    local file="$1"
    python3 - "$file" <<'PYEOF'
import sys
with open(sys.argv[1],'rb') as f: d=f.read()
print(f"  File: {sys.argv[1]} ({len(d)} bytes)")

# Find all MOV [rsp+N], 0x4000000C (enable field stores)
# and show full 64-byte context so we can see state patterns
enable_pat=bytes([0x0C,0x00,0x00,0x40])  # LE value after C7 44 24 N

hits=[]
for i in range(len(d)-8):
    if d[i]==0xC7 and d[i+1]==0x44 and d[i+2]==0x24 and d[i+4:i+8]==enable_pat:
        hits.append((i, d[i+3]))

print(f"  MOV [rsp+N], 0x4000000C: {len(hits)} hits")
for addr, off in hits:
    # Show 16 bytes before and 32 bytes after
    ctx = d[max(0,addr-16):addr+40]
    print(f"  0x{addr:08x} [rsp+0x{off:02x}]: {ctx.hex(' ')}")
    # Look for state patterns within 32 bytes after enable store
    window = d[addr+8:addr+40]
    # b9 XX 00 00 00 = mov ecx, state_val
    for j in range(len(window)-4):
        if window[j]==0xB9 and window[j+2]==0x00 and window[j+3]==0x00 and window[j+4]==0x00:
            print(f"    -> MOV ecx,{window[j+1]} at +{j+8}: state={window[j+1]} ({'DISABLE' if window[j+1]==0 else 'ENABLE'})")
    # 31 XX = xor reg,reg (zeroing)
    for j in range(len(window)-1):
        if window[j]==0x31:
            print(f"    -> XOR at +{j+8}: {window[j:j+2].hex(' ')} (zeroing reg)")
    # C6 44 24 XX 00 = mov byte [rsp+XX], 0
    for j in range(len(window)-4):
        if window[j]==0xC6 and window[j+1]==0x44 and window[j+2]==0x24:
            print(f"    -> MOV byte [rsp+0x{window[j+3]:02x}],{window[j+4]} at +{j+8}: state={window[j+4]}")
PYEOF
}

patch_region() {
    local file="$1" out="$2"
    python3 - "$file" "$out" <<'PYEOF'
import sys

with open(sys.argv[1], 'rb') as f:
    d = bytearray(f.read())
n = 0

# TPM_RH_PLATFORM constant (0x4000000C) in Little Endian
enable_val = bytes([0x0C, 0x00, 0x00, 0x40])

for i in range(len(d) - 12):
    # Locate the TPM Platform Hierarchy constant
    if d[i:i+4] == enable_val or (d[i] == 0xC7 and d[i+1] == 0x44 and d[i+2] == 0x24 and d[i+4:i+8] == enable_val):
        
        # We found a potential site. Look ahead ~48 bytes for the 'disable' signal (0x00).
        # We search for the instruction that sets the 'state' argument to 0.
        window_start = i
        window_end = i + 64
        window = d[window_start:window_end]
        patched = False

        # Strategy 1: MOV ecx, 0 (B9 00 00 00 00) -> Change to MOV ecx, 1
        for j in range(len(window) - 5):
            if window[j] == 0xB9 and window[j+1] == 0x00 and window[j+2] == 0x00 and window[j+3] == 0x00 and window[j+4] == 0x00:
                d[window_start + j + 1] = 0x01
                n += 1; patched = True; break
        if patched: continue

        # Strategy 2: XOR ecx, ecx (31 C9) or XOR eax, eax (31 C0) -> Replace with MOV reg, 1
        # XOR is 2 bytes. MOV reg8, 1 is also 2 bytes. This preserves binary alignment.
        for j in range(len(window) - 2):
            if window[j] == 0x31 and window[j+1] == 0xC9: # xor ecx, ecx
                d[window_start + j] = 0xB1     # mov cl
                d[window_start + j + 1] = 0x01 # 1
                n += 1; patched = True; break
            elif window[j] == 0x31 and window[j+1] == 0xC0: # xor eax, eax
                d[window_start + j] = 0xB0     # mov al
                d[window_start + j + 1] = 0x01 # 1
                n += 1; patched = True; break
        if patched: continue

        # Strategy 3: MOV byte [rsp+offset], 0x00 -> Change to 0x01
        # Common when arguments are passed on the stack
        for j in range(len(window) - 5):
            if window[j] == 0xC6 and window[j+1] == 0x44 and window[j+2] == 0x24 and window[j+4] == 0x00:
                d[window_start + j + 4] = 0x01
                n += 1; patched = True; break
        if patched: continue

        # Strategy 4: MOV edx, 0 (BA 00 00 00 00) -> Change to MOV edx, 1
        # Often used for the 3rd or 4th argument in x86_64 calling conventions
        for j in range(len(window) - 5):
            if window[j] == 0xBA and window[j+1] == 0x00 and window[j+2] == 0x00 and window[j+3] == 0x00 and window[j+4] == 0x00:
                d[window_start + j + 1] = 0x01
                n += 1; patched = True; break

# Final Fallback: Literal TPM Packet sequence
# This matches the raw buffer for Tpm2TpmEnableNvram calls
patA = bytes([0x40, 0x00, 0x00, 0x0C, 0x00, 0x00, 0x00, 0x09, 0x40, 0x00, 0x00, 0x09])
for i in range(len(d) - 32):
    if d[i:i+12] == patA:
        # Check if we see a trailing 0x00 in the hierarchy enable field
        if d[i+21] == 0x00:
            d[i+21] = 0x01
            n += 1

print(f"  Applied {n} byte-level patches.")
with open(sys.argv[2], 'wb') as f:
    f.write(d)
PYEOF
}

patch_firmware() {
    echo -e "${YELLOW}Patches firmware to keep platform hierarchy enabled.${NC}"
    echo -e "${RED}Brick risk. Ensure SPI WP is off.${NC}"
    echo -n "Continue? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    if ! command -v python3 &>/dev/null; then
        echo -e "${RED}python3 not found. Run dev_install manually first.${NC}"
        read -r </dev/tty; return
    fi

    echo -e "${CYAN}[1/5] Preparing workspace...${NC}"
    mkdir -p "$WORKDIR"
    if ! mount | grep -q "stateful_partition.*rw"; then
        sudo mount -o remount,rw,exec /mnt/stateful_partition 2>/dev/null
        [[ $? -ne 0 ]] && { echo -e "${RED}      Cannot remount stateful rw.${NC}"; read -r </dev/tty; return; }
    fi
    echo -e "${GREEN}      Ready.${NC}"

    echo -e "${CYAN}[2/5] Checking SPI write protection...${NC}"
    local wp=$(flashrom -p internal --wp-status 2>/dev/null)
    if echo "$wp" | grep -qi "Protection mode: hardware"; then
        echo -e "${RED}      Hardware WP ON. Disable first.${NC}"
        read -r </dev/tty; return
    elif echo "$wp" | grep -qi "disabled\|WP: status: 0\|Protection mode: disabled"; then
        echo -e "${GREEN}      WP off.${NC}"
    else
        echo -e "${YELLOW}      WP unclear. Continue? (y/N):${NC} "; read -r c </dev/tty
        [[ "$c" != "y" && "$c" != "Y" ]] && return
    fi

    echo -e "${CYAN}[3/5] Reading firmware...${NC}"
    flashrom -p internal -r "$WORKDIR/fw.bin" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}      Dump failed.${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}      Done.${NC}"

    echo -e "${CYAN}[4/5] Scanning and patching...${NC}"
    cd "$WORKDIR"
    futility dump_fmap -x fw.bin FW_MAIN_A FW_MAIN_B 2>/dev/null
    if [[ ! -f "$WORKDIR/FW_MAIN_A" || ! -f "$WORKDIR/FW_MAIN_B" ]]; then
        echo -e "${RED}      Region extraction failed.${NC}"
        read -r </dev/tty; return
    fi

    local found_patch=0
    for region in FW_MAIN_A FW_MAIN_B; do
        echo -e "${YELLOW}      Scanning ${region}...${NC}"
        scan_fw "$WORKDIR/$region"
        local patch_out
        patch_out=$(patch_region "$WORKDIR/$region" "$WORKDIR/${region}.p" 2>&1)
        echo "$patch_out"
        if echo "$patch_out" | grep -q "PATCHED"; then
            found_patch=1
        fi
        cp "$WORKDIR/${region}.p" "$WORKDIR/$region"
    done

    if [[ $found_patch -eq 0 ]]; then
        echo -e "${RED}      No patchable pattern found.${NC}"
        echo -e "${YELLOW}      (f) Force  (R) Return${NC}"
        echo -n "      > "; read -r fc </dev/tty
        [[ "$fc" != "f" && "$fc" != "F" ]] && return
    fi

    futility load_fmap "$WORKDIR/fw.bin" \
        "FW_MAIN_A:$WORKDIR/FW_MAIN_A" \
        "FW_MAIN_B:$WORKDIR/FW_MAIN_B" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}      Reassembly failed.${NC}"
        echo -e "${YELLOW}      (f) Force  (R) Return${NC}"
        echo -n "      > "; read -r fc </dev/tty
        [[ "$fc" != "f" && "$fc" != "F" ]] && return
    fi
    echo -e "${GREEN}      Reassembled.${NC}"

    echo -e "${CYAN}[5/5] Signing...${NC}"
    futility sign \
        --signprivate "$DEVKEYS/firmware_data_key.vbprivk" \
        --keyblock "$DEVKEYS/firmware.keyblock" \
        --kernelkey "$DEVKEYS/kernel_subkey.vbpubk" \
        --version 1 \
        "$WORKDIR/fw.bin" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${YELLOW}      futility sign failed, trying make_dev_firmware.sh...${NC}"
        /usr/share/vboot/bin/make_dev_firmware.sh --nomod_hwid --nomod_gbb 2>/dev/null
        if [[ $? -ne 0 ]]; then
            echo -e "${RED}      Signing failed.${NC}"
            echo -e "${YELLOW}      (f) Force unsigned  (R) Return${NC}"
            echo -n "      > "; read -r fc </dev/tty
            [[ "$fc" != "f" && "$fc" != "F" ]] && return
        fi
    fi
    echo -e "${GREEN}      Signed.${NC}"

    echo
    echo -e "${RED}Point of no return.${NC}"
    echo -n "Flash? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && { echo "Aborted."; read -r </dev/tty; return; }

    flashrom -p internal -w "$WORKDIR/fw.bin" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}      Flash failed.${NC}"; read -r </dev/tty; return
    fi

    touch "$PATCH_FLAG"
    echo -e "${GREEN}      Done! Reboot to apply.${NC}"
    read -r </dev/tty
}

show_credits() {
    clear
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}          R-Patch v6.7${NC}"
    echo -e "${CYAN}================================${NC}"
    echo -e " ${BOLD}Code${NC}       : CriticalHD"
    echo -e " ${BOLD}KVS Ref${NC}    : kxtzownsu"
    echo -e " ${BOLD}CrOS Tools${NC} : Google (tpmc, futility, flashrom)"
    echo -e " ${BOLD}Thanks${NC}     : codenerd67, Sh1mmer team"
    echo -e "${CYAN}================================${NC}"
    echo
    echo "Press Enter to return..."
    read -r </dev/tty
}

get_info

while true; do
    draw_header
    if is_fw_patched; then
        echo -e " ${YELLOW}1)${NC} Change Rollback"
    else
        echo -e " ${RED}1) Change Rollback [patch firmware first]${NC}"
    fi
    echo -e " ${YELLOW}2)${NC} Patch Firmware"
    echo -e " ${YELLOW}3)${NC} Credits"
    echo -e " ${YELLOW}E)${NC} Exit"
    echo -n "> "; read -r choice </dev/tty
    case "$choice" in
        1) change_rollback ;;
        2) patch_firmware ;;
        3) show_credits ;;
        [Ee]) exit 0 ;;
        *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
    esac
done
