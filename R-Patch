#!/bin/bash

PATCH_FLAG="/var/rpatch_fw_patched"
INDEX="0x1008"
WORKDIR="/tmp/rpatch_work"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m"

stop_tpm_daemon() {
    if [[ "$TPM_VER" == "1.2" ]]; then
        sudo initctl stop tcsd 2>/dev/null
    else
        sudo initctl stop trunksd 2>/dev/null
    fi
}

start_tpm_daemon() {
    if [[ "$TPM_VER" == "1.2" ]]; then
        sudo initctl start tcsd 2>/dev/null
    else
        sudo initctl start trunksd 2>/dev/null
    fi
}

parse_kernver() {
    local raw="$1" struct="$2"
    local b=($raw)
    if [[ "$struct" == "V0" ]]; then
        local lo=$((16#${b[5]:-0})) hi=$((16#${b[7]:-0}))
        local val=$(( lo | (hi << 16) ))
        [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF ))
    elif [[ "$struct" == "V1" ]]; then
        local lo=$((16#${b[4]:-0})) hi=$((16#${b[6]:-0}))
        local val=$(( lo | (hi << 16) ))
        [[ $val -eq 0 ]] && echo "0" || echo $(( val & 0xFFFF ))
    else
        echo "?"
    fi
}

get_info() {
    TPM_VER=$(tpmc tpmver 2>/dev/null | tr -d '\n')
    [[ -z "$TPM_VER" ]] && TPM_VER="?"
    if [[ "$TPM_VER" == "1.2" ]]; then
        GSC_TYPE="preCr50"
    else
        GSC_TYPE=$(gsctool -a -I 2>/dev/null | grep -qi AllowUnverifiedRo && echo "ti50" || echo "cr50")
    fi
    stop_tpm_daemon
    local raw=$(tpmc read $INDEX 9 2>/dev/null)
    local fb=$(echo "$raw" | awk '{print $1}')
    case "$fb" in
        "02") STRUCT_VER="V0" ;;
        "10") STRUCT_VER="V1" ;;
        *)    STRUCT_VER="?"  ;;
    esac
    KV_NUM=$(parse_kernver "$raw" "$STRUCT_VER")
    start_tpm_daemon
}

is_fw_patched() { [[ -f "$PATCH_FLAG" ]]; }

to_le32() {
    local v=$1
    printf "%02x %02x %02x %02x" \
        $((v & 0xFF)) $(((v>>8) & 0xFF)) $(((v>>16) & 0xFF)) $(((v>>24) & 0xFF))
}

crc8() {
    local data=("$@") crc=0
    for byte in "${data[@]}"; do
        local b=$((16#$byte))
        for ((i=0;i<8;i++)); do
            local mix=$(( (crc ^ b) & 1 ))
            crc=$(( crc >> 1 ))
            (( mix )) && crc=$(( crc ^ 0x8C ))
            b=$(( b >> 1 ))
        done
    done
    printf "%02x" $crc
}

build_struct() {
    local ver=$1 kv=$2
    if [[ "$ver" == "V0" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local full=("02" "4c" "57" "52" "47" "${kv_b[@]}" "00" "00" "00" "00")
        full[11]=$(crc8 "${full[@]:0:11}")
    elif [[ "$ver" == "V1" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local ec=()
        for ((i=0;i<32;i++)); do ec+=("00"); done
        local full=("10" "28" "00" "00" "${kv_b[@]}" "${ec[@]}")
        full[2]=$(crc8 "${full[@]:3}")
    else
        echo -e "${RED}Unknown struct version${NC}"; return 1
    fi
    echo "${full[@]}"
}

draw_header() {
    clear
    echo -e "${CYAN}================================${NC}"
    echo -e "${CYAN}  ${BOLD}R-Patch v6.0${NC}  ${CYAN}·  CriticalHD${NC}"
    echo -e "${CYAN}================================${NC}"
    if is_fw_patched; then
        echo -e " Firmware : ${GREEN}PATCHED${NC}"
    else
        echo -e " Firmware : ${RED}NOT PATCHED${NC}"
    fi
    echo -e " TPM      : ${CYAN}${TPM_VER}${NC}  GSC: ${CYAN}${GSC_TYPE}${NC}"
    echo -e " Kernver  : ${YELLOW}KV${KV_NUM}${NC}  (${STRUCT_VER})"
    echo -e "${CYAN}================================${NC}"
    echo
}

find_ph_pattern() {
    local file="$1"
    python3 - "$file" <<'PYEOF'
import sys
with open(sys.argv[1],'rb') as f: d=f.read()

# The HierarchyControl packet structure (vboot tlcl):
# 80 02 (TPM_ST_SESSIONS)
# 00 00 00 XX (size)
# 00 00 01 21 (TPM2_CC_HIERARCHY_CONTROL)
# 40 00 00 0C (authHandle=TPM_RH_PLATFORM)
# [9 byte password session: 00 00 00 09 40 00 00 09 00 00 01 00 00]
# 40 00 00 0C (enable=TPM_RH_PLATFORM)
# 00          (state=NO/disable)

# Search for the full unique pattern across both parts
# authHandle + session + enable + state
# 40 00 00 0C [session bytes] 40 00 00 0C 00
# Session is: 00 00 00 09 40 00 00 09 00 00 01 00 00 (13 bytes)
full = bytes([
    0x40,0x00,0x00,0x0C,          # authHandle=TPM_RH_PLATFORM
    0x00,0x00,0x00,0x09,          # session size
    0x40,0x00,0x00,0x09,          # TPM_RS_PW
    0x00,0x00,0x01,0x00,0x00,     # nonce+attrs+auth
    0x40,0x00,0x00,0x0C,          # enable=TPM_RH_PLATFORM
    0x00                           # state=0 (disable)
])

hits=[]
for i in range(len(d)-len(full)):
    if d[i:i+len(full)]==full:
        hits.append(i)
        print(f"  HIT at 0x{i:08x}: {d[max(0,i-4):i+len(full)+4].hex(' ')}")

# Also try shorter unique tail
tail = bytes([0x40,0x00,0x00,0x0C,0x00,0x00,0x00,0x09,0x40,0x00,0x00,0x09])
tail_hits=[]
for i in range(len(d)-len(tail)):
    if d[i:i+len(tail)]==tail:
        tail_hits.append(i)

print(f"  Full pattern hits: {len(hits)}")
print(f"  Partial session pattern hits: {len(tail_hits)}")
for i in tail_hits[:5]:
    print(f"    0x{i:08x}: {d[max(0,i-4):i+len(tail)+8].hex(' ')}")
PYEOF
}

patch_region() {
    local file="$1" out="$2"
    python3 - "$file" "$out" <<'PYEOF'
import sys
with open(sys.argv[1],'rb') as f: d=bytearray(f.read())
# Full HierarchyControl command pattern with password session
full = bytes([
    0x40,0x00,0x00,0x0C,          # authHandle=TPM_RH_PLATFORM
    0x00,0x00,0x00,0x09,          # session size
    0x40,0x00,0x00,0x09,          # TPM_RS_PW
    0x00,0x00,0x01,0x00,0x00,     # nonce+attrs+auth
    0x40,0x00,0x00,0x0C,          # enable=TPM_RH_PLATFORM
    0x00                           # state=0 (disable) <-- patch this to 0x01
])
n=0
for i in range(len(d)-len(full)):
    if d[i:i+len(full)]==full:
        # patch state byte (last byte) from 0 to 1
        d[i+len(full)-1]=0x01
        n+=1
        print(f"      Patched {sys.argv[1]} at 0x{i:08x}")
if n==0:
    print(f"      WARNING: pattern not found in {sys.argv[1]}")
with open(sys.argv[2],'wb') as f: f.write(d)
PYEOF
}

change_rollback() {
    if ! is_fw_patched; then
        echo -e "${RED}Patch firmware first (option 2).${NC}"
        read -r </dev/tty; return
    fi
    echo -e "${CYAN}Current: KV${KV_NUM} (${STRUCT_VER})${NC}"
    echo
    echo -e " ${YELLOW}0${NC}) KV0 — boots all versions"
    echo -e " ${YELLOW}1${NC}) KV1 — boots all versions"
    echo -e " ${YELLOW}2${NC}) KV2 — boots R112+"
    echo -e " ${YELLOW}3${NC}) KV3 — boots R120+"
    echo -e " ${YELLOW}4${NC}) KV4 — boots R125+"
    echo -e " ${YELLOW}5${NC}) KV5 — boots R133+"
    echo -e " ${YELLOW}6${NC}) KV6"
    echo -e " ${YELLOW}7${NC}) KV7"
    echo -e " ${YELLOW}B${NC}) Back"
    echo -n "> "; read -r kv </dev/tty
    [[ "$kv" =~ ^[Bb]$ ]] && return
    [[ ! "$kv" =~ ^[0-7]$ ]] && { echo -e "${RED}Invalid.${NC}"; sleep 1; return; }

    local kv_val
    [[ "$kv" == "0" ]] && kv_val=0 || kv_val=$(( 0x00010000 + kv ))

    local bytes=($(build_struct "$STRUCT_VER" "$kv_val"))
    [[ $? -ne 0 ]] && return

    echo -e "${YELLOW}Set kernver to KV${kv}? (y/N):${NC} "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    stop_tpm_daemon
    tpmc write $INDEX "${bytes[@]}"
    local rc=$?
    start_tpm_daemon

    if [[ $rc -eq 0 ]]; then
        echo -e "${GREEN}Kernver set to KV${kv} successfully.${NC}"
        get_info
    else
        echo -e "${RED}Write failed (code $rc).${NC}"
    fi
    read -r </dev/tty
}

patch_firmware() {
    echo -e "${YELLOW}Patches firmware to keep platform hierarchy enabled,${NC}"
    echo -e "${YELLOW}allowing kernver writes from vt2 after reboot.${NC}"
    echo
    echo -e "${RED}WARNING: Brick risk. Ensure SPI WP is off.${NC}"
    echo -n "Continue? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    mkdir -p "$WORKDIR"

    echo -e "${CYAN}[1/5] Checking for python3...${NC}"
    if ! command -v python3 &>/dev/null; then
        echo -e "${YELLOW}      Running dev_install...${NC}"
        dev_install --yes 2>/dev/null
        if ! command -v python3 &>/dev/null; then
            echo -e "${RED}      python3 not available.${NC}"
            read -r </dev/tty; return
        fi
    fi
    echo -e "${GREEN}      python3 ready.${NC}"

    echo -e "${CYAN}[2/5] Reading firmware from SPI flash...${NC}"
    flashrom -p internal -r "$WORKDIR/fw.bin" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}      Firmware dump failed!${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}      Firmware dumped successfully.${NC}"

    echo -e "${CYAN}[3/5] Locating platform hierarchy disable call...${NC}"
    cd "$WORKDIR"
    futility dump_fmap -x fw.bin FW_MAIN_A FW_MAIN_B 2>/dev/null
    if [[ ! -f "$WORKDIR/FW_MAIN_A" || ! -f "$WORKDIR/FW_MAIN_B" ]]; then
        echo -e "${RED}      Failed to extract firmware regions!${NC}"
        read -r </dev/tty; return
    fi

    # Search for TPM_RH_PLATFORM (0x4000000C) hits and show context
    echo -e "${YELLOW}      Scanning FW_MAIN_A for pattern...${NC}"
    find_ph_pattern "$WORKDIR/FW_MAIN_A"
    echo -e "${YELLOW}      Scanning FW_MAIN_B for pattern...${NC}"
    find_ph_pattern "$WORKDIR/FW_MAIN_B"

    echo -e "${CYAN}[4/5] Patching firmware regions...${NC}"
    for region in FW_MAIN_A FW_MAIN_B; do
        patch_region "$WORKDIR/$region" "$WORKDIR/${region}.p"
        cp "$WORKDIR/${region}.p" "$WORKDIR/$region"
    done

    futility load_fmap "$WORKDIR/fw.bin" \
        "FW_MAIN_A:$WORKDIR/FW_MAIN_A" \
        "FW_MAIN_B:$WORKDIR/FW_MAIN_B" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}      Failed to reassemble firmware!${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}      Regions patched and reassembled.${NC}"

    echo -e "${CYAN}[5/5] Re-signing firmware with dev keys...${NC}"
    /usr/share/vboot/bin/make_dev_firmware.sh --nomod_hwid --nomod_gbb 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}      Signing failed!${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}      Firmware signed successfully.${NC}"

    echo
    echo -e "${RED}Ready to flash. Point of no return.${NC}"
    echo -n "Flash? (y/N): "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && { echo "Aborted."; read -r </dev/tty; return; }

    flashrom -p internal -w "$WORKDIR/fw.bin" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}      Flash failed!${NC}"; read -r </dev/tty; return; }

    touch "$PATCH_FLAG"
    echo -e "${GREEN}      Done! Reboot to apply changes.${NC}"
    read -r </dev/tty
}

get_info

while true; do
    draw_header
    if is_fw_patched; then
        echo -e " ${YELLOW}1)${NC} Change Rollback"
    else
        echo -e " ${RED}1) Change Rollback [patch firmware first]${NC}"
    fi
    echo -e " ${YELLOW}2)${NC} Patch Firmware"
    echo -e " ${YELLOW}E)${NC} Exit"
    echo -n "> "; read -r choice </dev/tty
    case "$choice" in
        1) change_rollback ;;
        2) patch_firmware ;;
        [Ee]) exit 0 ;;
        *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
    esac
done

