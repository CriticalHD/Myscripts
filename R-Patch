#!/bin/bash

VERSION="v1.1.1"
AUTHOR="CriticalHD/neonnebula"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

get_current_rb() {
    # Run once, safely
    CURRENT=$(tpmc read 2>/dev/null | grep -i rollback | grep -o '[0-7]' | head -n1)
    [[ -z "$CURRENT" ]] && CURRENT="Unknown"
}

while true; do
    clear

    echo -e "${CYAN}Loading TPM info...${NC}"
    get_current_rb

    clear

    echo -e "${CYAN}======================================${NC}"
    echo -e "${WHITE}        R-Patch ${VERSION}${NC}"
    echo -e "${YELLOW}    by ${AUTHOR}${NC}"
    echo -e "${CYAN}======================================${NC}"
    echo

    echo -e "${BLUE}Current Rollback Value:${NC} ${WHITE}${CURRENT}${NC}"
    echo

    echo -e "${RED}WARNING:${NC} Changing rollback values can affect boot security!"
    echo -e "${YELLOW}Use at your own risk.${NC}"
    echo

    echo -e "${GREEN}Select Rollback Value:${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"

    for i in {0..7}; do
        if [ "$i" -eq 0 ]; then
            echo -e "${GREEN}[$i]${NC} Lowest"
        elif [ "$i" -eq 7 ]; then
            echo -e "${RED}[$i]${NC} Highest"
        else
            echo -e "${YELLOW}[$i]${NC} Intermediate"
        fi
    done

    echo -e "${BLUE}--------------------------------------${NC}"
    echo -e "${CYAN}[Q] Quit${NC}"
    echo

    read -r -p "Enter rollback value (0-7) or Q: " choice

    if [[ -z "$choice" ]]; then
        continue
    fi

    if [[ "$choice" =~ ^[Qq]$ ]]; then
        echo -e "${CYAN}Exiting R-Patch...${NC}"
        exit 0
    fi

    if [[ ! "$choice" =~ ^[0-7]$ ]]; then
        echo -e "${RED}Invalid selection!${NC}"
        sleep 1.2
        continue
    fi

    echo
    echo -e "${CYAN}[*] Setting rollback value to ${choice}...${NC}"

    if sudo tpmc --rollback set "$choice"; then
        echo -e "${GREEN}[+] Success.${NC}"
    else
        echo -e "${RED}[-] Failed.${NC}"
    fi

    echo
    read -p "Press Enter to continue..."
done
