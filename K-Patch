#!/bin/bash
set -e

# -----------------------------
# Version
# -----------------------------
VERSION="v7.0.0"
CYAN='\033[0;36m'
NC='\033[0m'
echo -e "${CYAN}ChromeOS Kernel Patch Script — Version ${VERSION}${NC}"

# -----------------------------
# Colors
# -----------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'

# -----------------------------
# Paths
# -----------------------------
WORKDIR="/tmp/kernel_patch"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_PART="/dev/mmcblk0p2"  # default KERN-A
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

# -----------------------------
# Detect vbutil
# -----------------------------
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] No vbutil_kernel or futility found!${NC}"
    exit 1
fi
echo -e "${GREEN}[*] Using tool: $VBUTIL${NC}"

# -----------------------------
# Dump kernel
# -----------------------------
echo -e "${BLUE}[*] Dumping kernel partition ($KERN_PART)...${NC}"
sudo dd if=$KERN_PART of=kernel_A.bin bs=4M status=progress

# -----------------------------
# Flags, names, and simple descriptions
# -----------------------------
FLAGS=(0 0 0 0 0 0 0)  # 0=OFF, 1=ON
NAMES=(
    "cros_debug"
    "disable_rootfs_verification"
    "module.sig_enforce"
    "lsm.module_locking"
    "security"
    "selinux"
    "dm_verity.error_behavior"
)
DESCRIPTIONS=(
    "Enable developer/debug mode"
    "Turn off rootfs verification"
    "Allow unsigned kernel modules"
    "Disable module locking"
    "Disable extra kernel security checks"
    "Turn off SELinux enforcement"
    "Ignore dm-verity errors on boot"
)

# -----------------------------
# Menu display
# -----------------------------
show_menu() {
    clear
    echo -e "${CYAN}ChromeOS Kernel Patch Menu — Version ${VERSION}${NC}"
    echo "Select flags to toggle ON/OFF:"
    echo "-----------------------------------"
    for i in "${!NAMES[@]}"; do
        status="${FLAGS[$i]}"
        if [ "$status" -eq 1 ]; then
            color=$GREEN
            stat_text="ON "
        else
            color=$RED
            stat_text="OFF"
        fi
        echo -e "${color}$((i+1))) [${stat_text}]${NC} ${NAMES[$i]} - ${DESCRIPTIONS[$i]}"
    done
    echo ""
    echo "m - Manual edit of cmdline"
    echo "p - Proceed with repack"
    echo "e - Exit without changes"
    echo "-----------------------------------"
    echo -n "Choice: "
}

# -----------------------------
# Interactive menu loop
# -----------------------------
while true; do
    show_menu
    read choice  # plain read works in VT2

    case "$choice" in
        1) FLAGS[0]=$((1-FLAGS[0])) ;;
        2) FLAGS[1]=$((1-FLAGS[1])) ;;
        3) FLAGS[2]=$((1-FLAGS[2])) ;;
        4) FLAGS[3]=$((1-FLAGS[3])) ;;
        5) FLAGS[4]=$((1-FLAGS[4])) ;;
        6) FLAGS[5]=$((1-FLAGS[5])) ;;
        7) FLAGS[6]=$((1-FLAGS[6])) ;;
        m)
            echo -e "${YELLOW}[*] Opening manual edit...${NC}"
            nano cmdline.txt
            ;;
        p)
            echo -e "${GREEN}[*] Proceeding with repack...${NC}"
            break
            ;;
        e)
            echo -e "${RED}[!] Exiting script.${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}[!] Invalid option, choose 1-7, m, p, or e.${NC}"
            sleep 1
            ;;
    esac
done

# -----------------------------
# Generate cmdline.txt
# -----------------------------
CMDLINE_FILE="$WORKDIR/cmdline.txt"
> "$CMDLINE_FILE"

for i in "${!NAMES[@]}"; do
    if [ "${FLAGS[$i]}" -eq 1 ]; then
        key="${NAMES[$i]}"
        if [ "$key" == "dm_verity.error_behavior" ]; then
            echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE"
        else
            echo -n "$key " >> "$CMDLINE_FILE"
        fi
    fi
done
echo "" >> "$CMDLINE_FILE"

echo -e "${GREEN}[*] Final cmdline:${NC}"
cat "$CMDLINE_FILE"

# -----------------------------
# Repack kernel
# -----------------------------
echo -e "${BLUE}[*] Repacking kernel using --repack...${NC}"
$VBUTIL --repack kernel_A.bin \
    --config "$CMDLINE_FILE" \
    --outfile new_kernel.bin \
    --keyblock "$KEYBLOCK" \
    --signprivate "$PRIVKEY"

# -----------------------------
# Flash kernel
# -----------------------------
echo -e "${BLUE}[*] Flashing new kernel to $KERN_PART...${NC}"
sudo dd if=new_kernel.bin of=$KERN_PART bs=4M status=progress
sync

echo -e "${GREEN}[✔] Kernel patched successfully! Reboot to apply changes.${NC}"
