#!/bin/bash
set -e

echo "[*] ChromeOS Kernel Patcher v4 — Detecting tools..."

# Detect tool
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo "[!] No vbutil_kernel or futility found"
    exit 1
fi

echo "[*] Using: $VBUTIL"

# Kernel partition (KERN-A by default)
KERN_PART="/dev/mmcblk0p2"
WORKDIR="/tmp/kernel_work"

mkdir -p $WORKDIR
cd $WORKDIR

echo "[*] Dumping kernel partition..."
sudo dd if=$KERN_PART of=kernel.bin

echo "[*] Extracting kernel + config..."
$VBUTIL --verify kernel.bin --verbose \
    --dump_kernel_config=config.txt \
    --dump_vmlinuz=vmlinuz.bin

echo "[*] Current kernel flags:"
cat config.txt

# Prepare new cmdline
cp config.txt new_cmdline.txt

cat >> new_cmdline.txt <<EOF

cros_debug=1
disable_rootfs_verification
module.sig_enforce=0
lsm.module_locking=0
security=none
selinux=0
dm_verity.error_behavior=ignore
EOF

echo "[!] Edit flags if needed: $WORKDIR/new_cmdline.txt"
read -p "Press ENTER to continue with these flags..."

# Dev keys (must exist)
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

echo "[*] Repacking kernel..."
$VBUTIL --pack new_kernel.bin \
    --keyblock $KEYBLOCK \
    --signprivate $PRIVKEY \
    --config new_cmdline.txt \
    --vmlinuz vmlinuz.bin \
    --arch x86

echo "[*] Flashing patched kernel (KERN-A)..."
sudo dd if=new_kernel.bin of=$KERN_PART
sync

echo "[✔] Done! Reboot to apply new kernel flags."
