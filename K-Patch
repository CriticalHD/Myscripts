#!/bin/bash

echo "v1"

set -e

WORKDIR="/tmp/kernel_patch"
mkdir -p $WORKDIR
cd $WORKDIR

KERN_PART="/dev/mmcblk0p2"
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

echo "[*] Dumping kernel partition..."
sudo dd if=$KERN_PART of=kernel_A.bin bs=4M status=progress

echo "[*] Extracting vmlinuz..."
vbutil_kernel --get-vmlinuz kernel_A.bin --outfile vmlinuz.bin

echo "[*] Prepare cmdline file"
CMDLINE="$WORKDIR/cmdline.txt"

echo "# Add your kernel flags below" > $CMDLINE
echo "cros_debug=1 disable_rootfs_verification module.sig_enforce=0 lsm.module_locking=0 security=none selinux=0 dm_verity.error_behavior=ignore" >> $CMDLINE

echo "[*] Edit cmdline manually if needed:"
nano $CMDLINE

echo "[*] Repacking kernel..."
vbutil_kernel --pack new_kernel.bin \
    --vmlinuz vmlinuz.bin \
    --config $CMDLINE \
    --arch x86 \
    --keyblock $KEYBLOCK \
    --signprivate $PRIVKEY

echo "[*] Flashing new kernel..."
sudo dd if=new_kernel.bin of=$KERN_PART bs=4M status=progress
sync

echo "[✔] Done! Reboot to apply flags."
