#!/bin/bash
set -e

# -----------------------------
# Version
# -----------------------------
VERSION="v4.0.0"
CYAN='\033[0;36m'
NC='\033[0m'
echo -e "${CYAN}ChromeOS Kernel Patch Script — Version ${VERSION}${NC}"

# -----------------------------
# Color definitions
# -----------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'

# -----------------------------
# Paths and partitions
# -----------------------------
WORKDIR="/tmp/kernel_patch"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_PART="/dev/mmcblk0p2"  # Default KERN-A
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

# -----------------------------
# Detect vbutil tool
# -----------------------------
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] No vbutil_kernel or futility found!${NC}"
    exit 1
fi
echo -e "${GREEN}[*] Using tool: $VBUTIL${NC}"

# -----------------------------
# Dump kernel partition
# -----------------------------
echo -e "${BLUE}[*] Dumping kernel partition ($KERN_PART)...${NC}"
sudo dd if=$KERN_PART of=kernel_A.bin bs=4M status=progress

# -----------------------------
# Prepare flags with descriptions
# -----------------------------
declare -A FLAGS
declare -A DESCRIPTIONS

FLAGS[cros_debug]=0
DESCRIPTIONS[cros_debug]="Enables ChromeOS developer debug mode"

FLAGS[disable_rootfs_verification]=0
DESCRIPTIONS[disable_rootfs_verification]="Disables verified boot checks on the root filesystem"

FLAGS[module.sig_enforce]=0
DESCRIPTIONS[module.sig_enforce]="Disables kernel module signature enforcement"

FLAGS[lsm.module_locking]=0
DESCRIPTIONS[lsm.module_locking]="Disables Linux Security Module kernel locking"

FLAGS[security]=0
DESCRIPTIONS[security]="Disables certain kernel security features (optional)"

FLAGS[selinux]=0
DESCRIPTIONS[selinux]="Disables SELinux enforcement in kernel"

FLAGS[dm_verity.error_behavior]=0
DESCRIPTIONS[dm_verity.error_behavior]="Changes behavior on dm-verity failures; 'ignore' prevents boot halt"

# -----------------------------
# Numbered menu mapping
# -----------------------------
OPTIONS=(cros_debug disable_rootfs_verification module.sig_enforce lsm.module_locking security selinux dm_verity.error_behavior)

# -----------------------------
# Show menu
# -----------------------------
show_menu() {
    clear
    echo -e "${CYAN}ChromeOS Kernel Patch Menu — Version ${VERSION}${NC}"
    echo "Select flags to toggle ON/OFF:"
    echo "-----------------------------------"
    for i in "${!OPTIONS[@]}"; do
        key="${OPTIONS[$i]}"
        status="${FLAGS[$key]}"
        if [ "$status" -eq 1 ]; then
            color=$GREEN
            stat_text="ON "
        else
            color=$RED
            stat_text="OFF"
        fi
        echo -e "${color}$((i+1))) [${stat_text}]${NC} $key - ${DESCRIPTIONS[$key]}"
    done
    echo ""
    echo "m - Manual edit of cmdline"
    echo "p - Proceed with repack"
    echo "e - Exit without changes"
    echo "-----------------------------------"
    echo -n "Choose number or option (m/p/e): "
}

# -----------------------------
# Interactive loop
# -----------------------------
while true; do
    show_menu
    read -p "Choose number or option (m/p/e): " choice
    choice=$(echo "$choice" | tr -d '[:space:]')  # Remove spaces/tabs

    # Skip empty input
    if [ -z "$choice" ]; then
        continue
    fi

    case $choice in
        1|2|3|4|5|6|7)
            index=$((choice-1))
            key="${OPTIONS[$index]}"
            FLAGS[$key]=$((1-${FLAGS[$key]}))
            ;;
        m)
            echo -e "${YELLOW}[*] Opening manual edit...${NC}"
            nano cmdline.txt
            ;;
        p)
            echo -e "${GREEN}[*] Proceeding with repack...${NC}"
            break
            ;;
        e)
            echo -e "${RED}[!] Exiting script.${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}[!] Invalid option, choose a number from 1-7, m, p, or e.${NC}"
            sleep 1
            ;;
    esac
done

# -----------------------------
# Generate cmdline.txt
# -----------------------------
CMDLINE_FILE="$WORKDIR/cmdline.txt"
> "$CMDLINE_FILE"

for key in "${OPTIONS[@]}"; do
    if [ "${FLAGS[$key]}" -eq 1 ]; then
        # dm_verity needs 'ignore' text
        if [ "$key" == "dm_verity.error_behavior" ]; then
            echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE"
        else
            echo -n "$key " >> "$CMDLINE_FILE"
        fi
    fi
done
echo "" >> "$CMDLINE_FILE"

echo -e "${GREEN}[*] Final cmdline:${NC}"
cat "$CMDLINE_FILE"

# -----------------------------
# Repack kernel
# -----------------------------
echo -e "${BLUE}[*] Repacking kernel using --repack...${NC}"
$VBUTIL --repack kernel_A.bin \
    --config "$CMDLINE_FILE" \
    --outfile new_kernel.bin \
    --keyblock "$KEYBLOCK" \
    --signprivate "$PRIVKEY"

# -----------------------------
# Flash kernel
# -----------------------------
echo -e "${BLUE}[*] Flashing new kernel to $KERN_PART...${NC}"
sudo dd if=new_kernel.bin of=$KERN_PART bs=4M status=progress
sync

echo -e "${GREEN}[✔] Kernel patched successfully! Reboot to apply changes.${NC}"
