#!/bin/bash
set -e

echo "[*] ChromeOS Kernel Patch Script — Manual Edit Version"

# -----------------------------
# 1️⃣ Detect vbutil tool
# -----------------------------
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo "[!] No vbutil_kernel or futility found!"
    exit 1
fi

echo "[*] Using tool: $VBUTIL"

# -----------------------------
# 2️⃣ Define kernel partition & workdir
# -----------------------------
KERN_PART="/dev/mmcblk0p2"   # Usually KERN-A
WORKDIR="/tmp/kernel_patch"
mkdir -p $WORKDIR
cd $WORKDIR

echo "[*] Dumping kernel partition..."
sudo dd if=$KERN_PART of=kernel.bin bs=4M status=progress

# -----------------------------
# 3️⃣ Unpack kernel
# -----------------------------
UNPACK_DIR="$WORKDIR/unpacked"
mkdir -p $UNPACK_DIR

KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

echo "[*] Unpacking kernel (compatible with all vbutil_kernel versions)..."
$VBUTIL --unpack $UNPACK_DIR \
    --input kernel.bin \
    --vblock $KEYBLOCK \
    --signprivate $PRIVKEY

echo "[*] Kernel unpacked to $UNPACK_DIR"

# -----------------------------
# 4️⃣ Edit cmdline manually
# -----------------------------
CMDLINE_FILE="$UNPACK_DIR/cmdline"

if [ ! -f "$CMDLINE_FILE" ]; then
    echo "[!] cmdline file not found in unpacked kernel!"
    exit 1
fi

echo "[*] Current kernel flags:"
cat "$CMDLINE_FILE"

echo ""
echo "[*] Now edit flags manually. Recommended additions:"
echo "  cros_debug=1"
echo "  disable_rootfs_verification"
echo "  module.sig_enforce=0"
echo "  lsm.module_locking=0"
echo "  security=none"
echo "  selinux=0"
echo "  dm_verity.error_behavior=ignore"

read -p "[*] Press ENTER to open cmdline file in nano editor..."
nano "$CMDLINE_FILE"

echo "[*] Edited flags saved."

# -----------------------------
# 5️⃣ Repack kernel
# -----------------------------
echo "[*] Repacking kernel..."
$VBUTIL --pack "$WORKDIR/new_kernel.bin" \
    --keyblock $KEYBLOCK \
    --signprivate $PRIVKEY \
    --config "$CMDLINE_FILE" \
    --vmlinuz "$UNPACK_DIR/vmlinuz" \
    --arch x86

echo "[*] Kernel repacked as $WORKDIR/new_kernel.bin"

# -----------------------------
# 6️⃣ Flash patched kernel
# -----------------------------
echo "[*] Flashing patched kernel back to $KERN_PART"
sudo dd if="$WORKDIR/new_kernel.bin" of=$KERN_PART bs=4M status=progress
sync

echo "[✔] Kernel patched successfully! Reboot to apply new flags."
