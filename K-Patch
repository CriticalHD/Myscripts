#!/bin/bash
set -e

# -----------------------------
# Version
# -----------------------------
VERSION="v11.0.0"
CYAN='\033[0;36m'
NC='\033[0m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'

echo -e "${CYAN}ChromeOS Kernel Patch Script â€” Version ${VERSION}${NC}"

# -----------------------------
# Paths
# -----------------------------
WORKDIR="/tmp/kernel_patch"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

# -----------------------------
# Detect vbutil
# -----------------------------
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] No vbutil_kernel or futility found!${NC}"
    exit 1
fi
echo -e "${GREEN}[*] Using tool: $VBUTIL${NC}"

# -----------------------------
# Dump kernels
# -----------------------------
echo -e "${BLUE}[*] Dumping KERN-A and KERN-B...${NC}"
sudo dd if=$KERN_A of=kernel_A.bin bs=4M status=progress
sudo dd if=$KERN_B of=kernel_B.bin bs=4M status=progress

# -----------------------------
# Flags, names, descriptions
# -----------------------------
FLAGS=(0 0 0 0 0 0 0)
NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
DESCRIPTIONS=(
    "Enable developer/debug mode"
    "Turn off rootfs verification"
    "Allow unsigned kernel modules"
    "Disable module locking"
    "Disable extra kernel security checks"
    "Turn off SELinux enforcement"
    "Ignore dm-verity errors on boot"
)

# -----------------------------
# Show menu
# -----------------------------
show_menu() {
    clear
    echo -e "${CYAN}ChromeOS Kernel Patch Menu â€” Version ${VERSION}${NC}"
    echo "Toggle flags ON/OFF:"
    echo "-----------------------------------"
    
    # Precompute status strings
    status0="OFF"; color0=$RED
    [ "${FLAGS[0]}" -eq 1 ] && status0="ON" && color0=$GREEN
    status1="OFF"; color1=$RED
    [ "${FLAGS[1]}" -eq 1 ] && status1="ON" && color1=$GREEN
    status2="OFF"; color2=$RED
    [ "${FLAGS[2]}" -eq 1 ] && status2="ON" && color2=$GREEN
    status3="OFF"; color3=$RED
    [ "${FLAGS[3]}" -eq 1 ] && status3="ON" && color3=$GREEN
    status4="OFF"; color4=$RED
    [ "${FLAGS[4]}" -eq 1 ] && status4="ON" && color4=$GREEN
    status5="OFF"; color5=$RED
    [ "${FLAGS[5]}" -eq 1 ] && status5="ON" && color5=$GREEN
    status6="OFF"; color6=$RED
    [ "${FLAGS[6]}" -eq 1 ] && status6="ON" && color6=$GREEN

    echo -e "${color0}1) [${status0}] ${NAMES[0]} - ${DESCRIPTIONS[0]}${NC}"
    echo -e "${color1}2) [${status1}] ${NAMES[1]} - ${DESCRIPTIONS[1]}${NC}"
    echo -e "${color2}3) [${status2}] ${NAMES[2]} - ${DESCRIPTIONS[2]}${NC}"
    echo -e "${color3}4) [${status3}] ${NAMES[3]} - ${DESCRIPTIONS[3]}${NC}"
    echo -e "${color4}5) [${status4}] ${NAMES[4]} - ${DESCRIPTIONS[4]}${NC}"
    echo -e "${color5}6) [${status5}] ${NAMES[5]} - ${DESCRIPTIONS[5]}${NC}"
    echo -e "${color6}7) [${status6}] ${NAMES[6]} - ${DESCRIPTIONS[6]}${NC}"

    echo ""
    echo "m - Manual edit of cmdline"
    echo "p - Proceed with repack"
    echo "e - Exit without changes"
    echo "-----------------------------------"
    echo -n "Choice: "
}

# -----------------------------
# Interactive menu loop
# -----------------------------
while true; do
    show_menu
    read choice  # VT2-compatible

    case "$choice" in
        1) FLAGS[0]=$((1-FLAGS[0])) ;;
        2) FLAGS[1]=$((1-FLAGS[1])) ;;
        3) FLAGS[2]=$((1-FLAGS[2])) ;;
        4) FLAGS[3]=$((1-FLAGS[3])) ;;
        5) FLAGS[4]=$((1-FLAGS[4])) ;;
        6) FLAGS[5]=$((1-FLAGS[5])) ;;
        7) FLAGS[6]=$((1-FLAGS[6])) ;;
        m) nano cmdline.txt ;;
        p) break ;;
        e) echo -e "${RED}[!] Exiting script.${NC}"; exit 0 ;;
        *) echo -e "${RED}[!] Invalid option!${NC}"; sleep 1 ;;
    esac
done

# -----------------------------
# Generate cmdline.txt
# -----------------------------
CMDLINE_FILE="$WORKDIR/cmdline.txt"
> "$CMDLINE_FILE"

for i in {0..6}; do
    if [ "${FLAGS[$i]}" -eq 1 ]; then
        key="${NAMES[$i]}"
        if [ "$key" == "dm_verity.error_behavior" ]; then
            echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE"
        else
            echo -n "$key " >> "$CMDLINE_FILE"
        fi
    fi
done
echo "" >> "$CMDLINE_FILE"

echo -e "${GREEN}[*] Final cmdline:${NC}"
cat "$CMDLINE_FILE"

# -----------------------------
# Repack kernels
# -----------------------------
for KERN_BIN in kernel_A.bin kernel_B.bin; do
    OUT_BIN="new_${KERN_BIN}"
    echo -e "${BLUE}[*] Repacking $KERN_BIN...${NC}"
    $VBUTIL --repack "$KERN_BIN" \
        --config "$CMDLINE_FILE" \
        --outfile "$OUT_BIN" \
        --keyblock "$KEYBLOCK" \
        --signprivate "$PRIVKEY"
done

# -----------------------------
# Flash kernels
# -----------------------------
echo -e "${BLUE}[*] Flashing KERN-A and KERN-B...${NC}"
sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
sync

echo -e "${GREEN}[âś”] Kernel patched successfully! Reboot to apply changes.${NC}"
