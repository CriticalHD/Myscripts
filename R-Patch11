#!/bin/bash
sudo initctl stop trunksd 2>/dev/null
sudo initctl stop tcsd 2>/dev/null
INDEX="0x1008"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
NC="\033[0m"

trim_newline() { echo -n "$1" | tr -d '\n'; }

getTpmVersion(){ output=$(tpmc tpmver 2>/dev/null); trim_newline "$output"; }
getKernver(){ output=$(tpmc read $INDEX 9 2>/dev/null); trim_newline "$output"; [[ "$output" == "" ]] && echo "UNKNOWN" || echo "$output"; }
getFWMPFlags(){ output=$(device_management_client --action=get_firmware_management_parameters 2>/dev/null | grep -i 'flags' | awk '{print $2}'); trim_newline "$output"; [[ "$output" == "" ]] && echo "UNKNOWN" || echo "$output"; }
getGSCType(){ [[ "$(tpmc tpmver 2>/dev/null)" == "1.2" ]] && echo "preCr50" || (gsctool -a -I 2>/dev/null | grep -qi AllowUnverifiedRo && echo "ti50" || echo "cr50"); }
getGSCRWVersion(){ output=$(gsctool -a -f 2>/dev/null | tail -n1 | awk '{printf $2}'); trim_newline "$output"; [[ "$output" == "" ]] && echo "UNKNOWN" || echo "$output"; }

detect_version(){
    first_byte=$(tpmc read $INDEX 1 2>/dev/null | awk '{print $1}')
    if [[ "$first_byte" == "02" ]]; then echo "V0"
    elif [[ "$first_byte" == "10" ]]; then echo "V1"
    else echo "UNKNOWN"; fi
}

to_le32(){ local val=$1; printf "%02x %02x %02x %02x" $(( val & 0xFF )) $(( (val >> 8) & 0xFF )) $(( (val >> 16) & 0xFF )) $(( (val >> 24) & 0xFF )); }
crc8(){ local data=("$@"); local crc=0; for byte in "${data[@]}"; do b=$((16#$byte)); for ((i=0;i<8;i++)); do mix=$(( (crc ^ b) & 1 )); crc=$(( crc >> 1 )); (( mix != 0 )) && crc=$(( crc ^ 0x8C )); b=$(( b >> 1 )); done; done; printf "%02x" $crc; }

build_struct(){
    version=$1; kernver=$2
    if [[ "$version" == "V0" ]]; then
        struct_version="02"; uid=("4c" "57" "52" "47"); kv=($(to_le32 "$kernver")); reserved=("00" "00" "00"); crc="00"; full=("$struct_version" "${uid[@]}" "${kv[@]}" "${reserved[@]}" "$crc"); full[11]=$(crc8 "${full[@]:0:11}")
    elif [[ "$version" == "V1" ]]; then
        struct_version="10"; struct_size="28"; crc="00"; flags="00"; kv=($(to_le32 "$kernver")); ec_hash=(); for ((i=0;i<32;i++)); do ec_hash+=("00"); done; full=("$struct_version" "$struct_size" "$crc" "$flags" "${kv[@]}" "${ec_hash[@]}"); full[2]=$(crc8 "${full[@]:3}")
    else echo -e "${RED}Unknown struct version${NC}"; return 1; fi
    echo "${full[@]}"
}

write_kernver(){
    version=$(detect_version)
    [[ "$version" == "UNKNOWN" ]] && { echo -e "${RED}Cannot detect TPM struct version${NC}"; read -r </dev/tty; return; }
    echo -e "${CYAN}Detected version: $version${NC}"
    echo -n "Enter new kernver (hex, e.g. 0x00010001): "
    read -r val </dev/tty
    [[ ! "$val" =~ ^0x[0-9a-fA-F]+$ ]] && { echo -e "${RED}Invalid number... Press enter to return${NC}"; read -r </dev/tty; return; }
    kernver=$((val))
    bytes=($(build_struct "$version" "$kernver"))
    [[ $? -ne 0 ]] && return
    echo -e "${CYAN}Constructed struct:${NC}"
    printf "%s " "${bytes[@]}"
    echo -e "\nConfirm write? (y/N): "
    read -r c </dev/tty
    [[ "$c" != "y" ]] && return
    tpmc write $INDEX "${bytes[@]}"
    echo -e "${GREEN}Write attempted.${NC} Press Enter to continue..."
    read -r </dev/tty
}

show_sysinfo(){
    echo -e "${CYAN}==============================${NC}"
    echo -e "${CYAN}        Current TPM Info${NC}"
    echo -e "${CYAN}==============================${NC}"
    echo -e "${CYAN}TPM Version: $(getTpmVersion)${NC}"
    echo -e "${CYAN}Kernver: $(getKernver)${NC}"
    echo -e "${CYAN}Struct version: $(detect_version)${NC}"
    echo -e "${CYAN}FWMP Flags: $(getFWMPFlags)${NC}"
    echo -e "${CYAN}GSC Type: $(getGSCType)${NC}"
    echo -e "${CYAN}GSC RW Version: $(getGSCRWVersion)${NC}"
    echo -e "${CYAN}==============================${NC}"
    echo "Press Enter to return to the menu..."
    read -r </dev/tty
}

# Menu Loop
while true; do
    clear
    echo -e "${CYAN}==============================${NC}"
    echo -e "${CYAN}        R-Patch v5.4${NC}"
    echo -e "${CYAN}    by CriticalHD/neonnebula${NC}"
    echo -e "${CYAN}==============================${NC}"
    echo
    echo -e "${YELLOW}1)${NC} Set kernver"
    echo -e "${YELLOW}2)${NC} Show current TPM info"
    echo -e "${YELLOW}Q)${NC} Quit"
    echo
    echo -n "Enter choice: "
    read -r choice </dev/tty
    case "$choice" in
        1) write_kernver ;;
        2) show_sysinfo ;;
        [Qq]) exit 0 ;;
        *) echo -e "${RED}Invalid choice${NC}"; sleep 1 ;;
    esac
done
