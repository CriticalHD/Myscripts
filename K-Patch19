#!/bin/bash
set -e

VERSION="v21.0.0"
CYAN='\033[0;36m'; NC='\033[0m'; RED='\033[0;31m'; GREEN='\033[0;32m'; BLUE='\033[0;34m'; B='\033[1;31m'

echo -e "${CYAN}ChromeOS K-Patch Script — Version ${VERSION}${NC}"

WORKDIR="/tmp/kpatch_work"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"
DEV_SCRIPT="/usr/share/vboot/bin/make_dev_ssd.sh"

# Detect vbutil
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] vbutil_kernel not found!${NC}"
    exit 1
fi

# =======================
# Kernel options
# =======================
KERNEL_FLAGS=(0 0 0 0 0 0 0)
KERNEL_NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
CMDLINE_FILE="$WORKDIR/cmdline.txt"
touch "$CMDLINE_FILE"

# =======================
# Firmware options
# =======================
declare -A FW_OPTIONS=(
  [1]="Enable Dev Keys"
  [2]="Enable Early Console"
  [3]="Allow Recovery Mods"
  [4]="Disable TPM Rollback"
  [5]="Ignore HWID"
)
declare -A FW_SELECTED

# =======================
# Kernel Menu
# =======================
kernel_menu() {
    while true; do
        clear
        echo -e "${CYAN}Kernel Options${NC}"
        echo "------------------"
        for i in "${!KERNEL_NAMES[@]}"; do
            mark="[ ]"
            [[ ${KERNEL_FLAGS[$i]} -eq 1 ]] && mark="[x]"
            echo -e "$((i+1))) ${KERNEL_NAMES[$i]} $mark"
        done
        echo "------------------"
        echo "m = edit cmdline | ENTER = continue"
        echo -n "Choice: "
        read -r choice < /dev/tty
        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ -z "$choice" ]] && break

        case "$choice" in
            1|2|3|4|5|6|7) idx=$((choice-1)); KERNEL_FLAGS[$idx]=$((1-KERNEL_FLAGS[$idx])) ;;
            m) nano "$CMDLINE_FILE" ;;
        esac
    done

    > "$CMDLINE_FILE"
    for i in "${!KERNEL_FLAGS[@]}"; do
        if [[ ${KERNEL_FLAGS[$i]} -eq 1 ]]; then
            key="${KERNEL_NAMES[$i]}"
            [[ "$key" == "dm_verity.error_behavior" ]] && echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE" || echo -n "$key " >> "$CMDLINE_FILE"
        fi
    done
    echo "" >> "$CMDLINE_FILE"
}

# =======================
# Firmware Menu
# =======================
firmware_menu() {
    while true; do
        clear
        echo -e "${CYAN}ChromeOS Firmware Menu${NC}"
        echo "------------------"
        for i in "${!FW_OPTIONS[@]}"; do
            mark="[ ]"
            [[ ${FW_SELECTED[$i]} == "true" ]] && mark="[x]"
            echo "$i) ${FW_OPTIONS[$i]} $mark"
        done
        echo "------------------"
        echo "ENTER = continue"
        echo -n "Choice: "
        read -r choice < /dev/tty
        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ -z "$choice" ]] && break

        if [[ "$choice" =~ ^[1-5]$ ]]; then
            [[ ${FW_SELECTED[$choice]} == "true" ]] && FW_SELECTED[$choice]=false || FW_SELECTED[$choice]=true
        fi
    done
}

# =======================
# Firmware patch (FIXED)
# =======================
patch_firmware() {
    echo -e "${GREEN}[*] Backing up firmware...${NC}"
    flashrom -p internal -r "/mnt/stateful_partition/backups/full_backup.bin"

    [[ ! -x "$DEV_SCRIPT" ]] && { echo "Missing make_dev_ssd.sh"; exit 1; }

    opts=""
    [[ ${FW_SELECTED[2]} == "true" ]] && opts="$opts --enable_earlycon --enable_console"
    [[ ${FW_SELECTED[3]} == "true" ]] && opts="$opts --allow_recovery_mod"
    [[ ${FW_SELECTED[4]} == "true" ]] && opts="$opts --disable_tpm_rollback"
    [[ ${FW_SELECTED[5]} == "true" ]] && opts="$opts --nomod_hwid"

    # DEV KEYS FIRST
    if [[ ${FW_SELECTED[1]} == "true" ]]; then
        echo -e "${BLUE}[*] Dev keys → partition 2${NC}"
        sudo "$DEV_SCRIPT" --keys /usr/share/vboot/devkeys --partitions 2 --force

        echo -e "${BLUE}[*] Dev keys → partition 4${NC}"
        sudo "$DEV_SCRIPT" --keys /usr/share/vboot/devkeys --partitions 4 --force
    fi

    # OTHER OPTIONS
    if [[ -n "$opts" ]]; then
        echo -e "${BLUE}[*] Firmware opts → partition 2${NC}"
        sudo "$DEV_SCRIPT" $opts --partitions 2 --force

        echo -e "${BLUE}[*] Firmware opts → partition 4${NC}"
        sudo "$DEV_SCRIPT" $opts --partitions 4 --force
    fi
}

# =======================
# Kernel patch
# =======================
repack_kernels() {
    echo -e "${BLUE}[*] Dumping kernels...${NC}"
    sudo dd if=$KERN_A of=kernel_A.bin bs=4M status=progress
    sudo dd if=$KERN_B of=kernel_B.bin bs=4M status=progress

    for KBIN in kernel_A.bin kernel_B.bin; do
        OUT="new_$KBIN"
        echo -e "${BLUE}[*] Repacking $KBIN...${NC}"
        $VBUTIL --repack "$KBIN" \
            --config "$CMDLINE_FILE" \
            --outfile "$OUT" \
            --keyblock "$KEYBLOCK" \
            --signprivate "$PRIVKEY"
    done

    echo -e "${BLUE}[*] Flashing kernels...${NC}"
    sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
    sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
    sync
}

# =======================
# RUN
# =======================
kernel_menu
firmware_menu

echo -e "${B}WARNING: This can brick your device${NC}"
echo -n "Continue? (y/N): "
read confirm < /dev/tty
[[ ! "$confirm" =~ ^[Yy]$ ]] && exit 1

patch_firmware
repack_kernels

echo -e "${GREEN}[✔] DONE — reboot now${NC}"
