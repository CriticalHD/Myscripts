#!/bin/bash
set -e

VERSION="v22.6.0"
AUTHOR="CriticalHD/neonnebula"

# =======================
# Colors
# =======================
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
RED='\033[0;31m'
B='\033[1;31m'
NC='\033[0m'

echo -e "${CYAN}ChromeOS K-Patch Script — Version ${VERSION} — ${AUTHOR}${NC}"

WORKDIR="/tmp/kpatch_work"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

# =======================
# Device paths / keys
# =======================
KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

SSD_SCRIPT="/usr/share/vboot/bin/make_dev_ssd.sh"
FW_SCRIPT="/usr/share/vboot/bin/make_dev_firmware.sh"

# Detect vbutil
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] vbutil_kernel not found!${NC}"
    exit 1
fi

# =======================
# Kernel options
# =======================
KERNEL_FLAGS=(0 0 0 0 0 0 0)
KERNEL_NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
KERNEL_DESCRIPTIONS=("Enable developer/debug mode" "Turn off rootfs verification" "Allow unsigned modules (DANGEROUS)" "Disable module locking (DANGEROUS)" "Disable extra kernel security (DANGEROUS)" "Disable SELinux enforcement (DANGEROUS)" "Ignore dm-verity errors on boot")
KERNEL_COLORS=("$GREEN" "$GREEN" "$YELLOW" "$YELLOW" "$YELLOW" "$YELLOW" "$GREEN")  # Safe = green, Dangerous = yellow
CMDLINE_FILE="$WORKDIR/cmdline.txt"

# =======================
# Firmware options
# =======================
declare -A FW_OPTIONS=(
  [1]="Apply Dev Firmware"
  [2]="Enable Early Console"
)
declare -A FW_SELECTED

# =======================
# Kernel Menu
# =======================
kernel_menu() {
    while true; do
        clear
        echo -e "${CYAN}ChromeOS Kernel Patch — Version ${VERSION} — ${AUTHOR}${NC}"
        echo -e "${B}Legend:${NC} ${GREEN}Safe${NC} | ${YELLOW}Dangerous / Warning${NC}"
        echo "------------------"
        for i in "${!KERNEL_NAMES[@]}"; do
            mark="[ ]"
            [[ ${KERNEL_FLAGS[$i]} -eq 1 ]] && mark="[x]"
            color="${KERNEL_COLORS[$i]}"
            echo -e "$((i+1))) ${color}${KERNEL_NAMES[$i]}${NC} $mark - ${KERNEL_DESCRIPTIONS[$i]}"
        done
        echo "------------------"
        echo -e "e = ${RED}exit${NC} | ENTER = continue"
        echo -n "Choice: "
        read -r choice < /dev/tty

        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ "$choice" == "e" ]] && exit 0
        [[ -z "$choice" ]] && break

        case "$choice" in
            1|2|3|4|5|6|7) idx=$((choice-1)); KERNEL_FLAGS[$idx]=$((1-KERNEL_FLAGS[$idx])) ;;
        esac
    done

    # Build cmdline
    > "$CMDLINE_FILE"
    for i in "${!KERNEL_FLAGS[@]}"; do
        if [[ ${KERNEL_FLAGS[$i]} -eq 1 ]]; then
            key="${KERNEL_NAMES[$i]}"
            [[ "$key" == "dm_verity.error_behavior" ]] \
                && echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE" \
                || echo -n "$key " >> "$CMDLINE_FILE"
        fi
    done
    echo "" >> "$CMDLINE_FILE"

    echo -e "${GREEN}[*] Final cmdline:${NC}"
    cat "$CMDLINE_FILE"
}

# =======================
# Firmware Menu
# =======================
firmware_menu() {
    while true; do
        clear
        echo -e "${CYAN}ChromeOS Firmware Menu — Version ${VERSION} — ${AUTHOR}${NC}"
        echo "------------------"
        for i in "${!FW_OPTIONS[@]}"; do
            mark="[ ]"
            [[ ${FW_SELECTED[$i]} == "true" ]] && mark="[x]"
            echo -e "$i) ${BLUE}${FW_OPTIONS[$i]}${NC} $mark"
        done
        echo "------------------"
        echo -e "e = ${RED}exit${NC} | ENTER = continue"
        echo -n "Choice: "
        read -r choice < /dev/tty

        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ "$choice" == "e" ]] && exit 0
        [[ -z "$choice" ]] && break

        if [[ "$choice" =~ ^[1-2]$ ]]; then
            [[ ${FW_SELECTED[$choice]} == "true" ]] && FW_SELECTED[$choice]=false || FW_SELECTED[$choice]=true
        fi
    done
}

# =======================
# Firmware patch
# =======================
patch_firmware() {
    echo -e "${GREEN}[*] Backing up firmware...${NC}"
    flashrom -p internal -r "/mnt/stateful_partition/backups/full_backup.bin"

    # Dev firmware
    if [[ ${FW_SELECTED[1]} == "true" ]]; then
        echo -e "${BLUE}[*] Applying dev firmware...${NC}"
        sudo "$FW_SCRIPT" --nomod_hwid
    fi

    # Early console
    if [[ ${FW_SELECTED[2]} == "true" ]]; then
        echo -e "${BLUE}[*] Enabling early console (partition 2)...${NC}"
        sudo "$SSD_SCRIPT" --enable_earlycon --enable_console --partitions 2 -f

        echo -e "${BLUE}[*] Enabling early console (partition 4)...${NC}"
        sudo "$SSD_SCRIPT" --enable_earlycon --enable_console --partitions 4 -f
    fi
}

# =======================
# Kernel patch (safe)
# =======================
repack_kernels() {
    echo -e "${BLUE}[*] Dumping kernels...${NC}"
    sudo dd if=$KERN_A of=kernel_A.bin bs=4M status=progress
    sudo dd if=$KERN_B of=kernel_B.bin bs=4M status=progress

    for KBIN in kernel_A.bin kernel_B.bin; do
        OUT="new_$KBIN"
        echo -e "${BLUE}[*] Repacking $KBIN...${NC}"

        $VBUTIL --repack "$OUT" \
            --oldblob "$KBIN" \
            --config "$CMDLINE_FILE" \
            --keyblock "$KEYBLOCK" \
            --signprivate "$PRIVKEY" \
            --version 1
    done

    echo -e "${BLUE}[*] Flashing kernels...${NC}"
    sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
    sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
    sync
}

# =======================
# RUN
# =======================
kernel_menu
firmware_menu

echo -e "${B}WARNING: This can brick your device${NC}"
echo -n "Continue? (y/N): "
read confirm < /dev/tty
[[ ! "$confirm" =~ ^[Yy]$ ]] && exit 1

patch_firmware
repack_kernels

echo -e "${GREEN}[✔] DONE — reboot now${NC}"
