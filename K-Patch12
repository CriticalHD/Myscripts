#!/bin/bash
set -e

VERSION="v20.0.0"
CYAN='\033[0;36m'; NC='\033[0m'; RED='\033[0;31m'; GREEN='\033[0;32m'; BLUE='\033[0;34m'

echo -e "${CYAN}ChromeOS K-Patch Script — Version ${VERSION}${NC}"

# =======================
# Workdir & kernel paths
# =======================
WORKDIR="/tmp/kpatch_work"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

# Detect vbutil
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] No vbutil_kernel or futility found!${NC}"
    exit 1
fi
echo -e "${GREEN}[*] Using tool: $VBUTIL${NC}"

# =======================
# Kernel options
# =======================
KERNEL_FLAGS=(0 0 0 0 0 0 0)
KERNEL_NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
KERNEL_DESC=("Enable developer/debug mode" "Turn off rootfs verification" "Allow unsigned kernel modules" "Disable module locking" "Disable extra kernel security checks" "Turn off SELinux enforcement" "Ignore dm-verity errors on boot")
CMDLINE_FILE="$WORKDIR/cmdline.txt"
touch "$CMDLINE_FILE"

# =======================
# Firmware/GBB options
# =======================
declare -A FW_OPTIONS=(
  [1]="Enable Developer Mode / Dev Keys"
  [2]="Enable Early Console / Serial"
  [3]="Disable SELinux / Security"
  [4]="Enable Recovery Partition Mods"
  [5]="Modify TPM / Rollback Enforcement"
  [6]="Modify Hardware ID / Allow Cross-Device Boot"
  [7]="Custom GBB Flags"
)
declare -A FW_SELECTED

FW_GBB_FLAGS=""
FW_PARTITIONS="2 4"

# =======================
# Helper: print menu
# =======================
print_menu() {
    local title="$1"
    shift
    local -n names=$1
    local -n flags=$2

    echo -e "${CYAN}${title}${NC}"
    echo "-----------------------------"
    for i in "${!names[@]}"; do
        local mark="[ ]"; [[ ${flags[$i]} -eq 1 ]] && mark="[x]"
        echo -e "${GREEN}$((i+1)))${NC} ${names[$i]} $mark"
    done
    echo "-----------------------------"
    echo "Enter number to toggle, Enter to finish, m = manual edit (kernel only), e = exit"
}

# =======================
# Kernel menu loop
# =======================
kernel_menu() {
    while true; do
        clear
        print_menu "ChromeOS Kernel Options Menu" KERNEL_NAMES KERNEL_FLAGS
        echo -n "Choice: "
        read -r choice < /dev/tty
        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ -z "$choice" ]] && break

        case "$choice" in
            1|2|3|4|5|6|7) idx=$((choice-1)); KERNEL_FLAGS[$idx]=$((1-KERNEL_FLAGS[$idx])) ;;
            m) nano "$CMDLINE_FILE" ;;
            e) echo -e "${RED}[!] Exiting.${NC}"; exit 0 ;;
            *) continue ;;
        esac
    done

    # Build cmdline
    > "$CMDLINE_FILE"
    for i in "${!KERNEL_FLAGS[@]}"; do
        if [[ ${KERNEL_FLAGS[$i]} -eq 1 ]]; then
            key="${KERNEL_NAMES[$i]}"
            [[ "$key" == "dm_verity.error_behavior" ]] && echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE" || echo -n "$key " >> "$CMDLINE_FILE"
        fi
    done
    echo "" >> "$CMDLINE_FILE"
    echo -e "${GREEN}[*] Final kernel cmdline:${NC}"
    cat "$CMDLINE_FILE"
}

# =======================
# Firmware menu loop
# =======================
firmware_menu() {
    while true; do
        clear
        echo -e "${CYAN}ChromeOS Firmware/GBB Options Menu${NC}"
        echo "-----------------------------"
        for i in "${!FW_OPTIONS[@]}"; do
            local mark="[ ]"; [[ ${FW_SELECTED[$i]} == "true" ]] && mark="[x]"
            echo -e "${GREEN}$i)${NC} ${FW_OPTIONS[$i]} $mark"
        done
        echo "-----------------------------"
        echo "Enter number to toggle, Enter to finish, e = exit"
        echo -n "Choice: "
        read -r choice < /dev/tty
        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ -z "$choice" ]] && break

        if [[ "$choice" =~ ^[1-7]$ ]]; then
            [[ ${FW_SELECTED[$choice]} == "true" ]] && FW_SELECTED[$choice]=false || FW_SELECTED[$choice]=true
        elif [[ "$choice" == "e" ]]; then
            echo -e "${RED}[!] Exiting.${NC}"; exit 0
        fi
    done

    # Prompt for custom GBB if selected
    [[ ${FW_SELECTED[7]} == "true" ]] && {
        echo -n "Enter custom GBB flags in hex (e.g., 0x9a31): "
        read FW_GBB_FLAGS < /dev/tty
    fi

    # Kernel partitions for firmware
    echo -n "Partitions to patch (default 2 4): "
    read ans < /dev/tty
    FW_PARTITIONS="${ans:-2 4}"
}

# =======================
# Backup firmware
# =======================
backup_firmware() {
    log_info "Backing up full firmware..."
    flashrom -p host -r "/mnt/stateful_partition/backups/full_backup.bin"
    log_info "Backup saved."
}

# =======================
# Patch firmware
# =======================
patch_firmware() {
    backup_firmware

    [[ ${FW_SELECTED[1]} == "true" ]] && log_info "Applying dev keys..." && make_dev_firmware.sh --keys "/usr/share/vboot/devkeys" --force_backup true

    local opts=""
    [[ ${FW_SELECTED[2]} == "true" ]] && opts="$opts --enable_earlycon true --enable_console true"
    [[ ${FW_SELECTED[4]} == "true" ]] && opts="$opts --allow_recovery_mod"
    [[ ${FW_SELECTED[5]} == "true" ]] && opts="$opts --disable_tpm_rollback"
    [[ ${FW_SELECTED[6]} == "true" ]] && opts="$opts --nomod_hwid"

    [[ -n "$FW_GBB_FLAGS" || ${FW_SELECTED[3]} == "true" ]] && log_info "Flashing GBB flags $FW_GBB_FLAGS" && futility gbb -s --flash --flags="${FW_GBB_FLAGS:-0x9a31}"

    [[ -n "$opts" ]] && log_info "Applying firmware options: $opts" && make_dev_ssd.sh $opts
}

# =======================
# Repack and flash kernels
# =======================
repack_kernels() {
    for KBIN in kernel_A.bin kernel_B.bin; do
        OUT="new_$KBIN"
        echo -e "${BLUE}[*] Repacking $KBIN...${NC}"
        $VBUTIL --repack "$KBIN" --config "$CMDLINE_FILE" --outfile "$OUT" --keyblock "$KEYBLOCK" --signprivate "$PRIVKEY"
    done

    echo -e "${BLUE}[*] Flashing kernels...${NC}"
    sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
    sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
    sync
    echo -e "${GREEN}[✔] Kernel patch complete.${NC}"
}

# =======================
# Run Script
# =======================
kernel_menu
firmware_menu

echo -e "${B}Warning: This can brick your device!${NC}"
echo -n "Continue with patching? (y/N): "
read confirm < /dev/tty
[[ ! "$confirm" =~ ^[Yy]$ ]] && { echo "Aborting."; exit 1; }

# Dump kernels
echo -e "${BLUE}[*] Dumping KERN-A and KERN-B...${NC}"
sudo dd if=$KERN_A of=kernel_A.bin bs=4M status=progress
sudo dd if=$KERN_B of=kernel_B.bin bs=4M status=progress

patch_firmware
repack_kernels

echo -e "${GREEN}[✔] All done! Reboot to apply changes.${NC}"
