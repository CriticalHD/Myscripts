#!/bin/bash

VERSION="v22.0.0"
CYAN='\033[0;36m'; NC='\033[0m'; RED='\033[0;31m'; GREEN='\033[0;32m'; BLUE='\033[0;34m'

echo -e "${CYAN}ChromeOS Kernel Patch Script — Version ${VERSION}${NC}"

WORKDIR="/tmp/kernel_patch"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"
KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

# Detect tool
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] No vbutil_kernel or futility found!${NC}"
    exit 1
fi

echo -e "${GREEN}[*] Using tool: $VBUTIL${NC}"

# Dump kernels
echo -e "${BLUE}[*] Dumping kernels...${NC}"
sudo dd if=$KERN_A of=kernel_A.bin bs=4M status=progress
sudo dd if=$KERN_B of=kernel_B.bin bs=4M status=progress

# Flags
FLAGS=(0 0 0 0 0 0 0)
NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
DESCRIPTIONS=(
"Enable developer/debug mode"
"Disable rootfs verification"
"Allow unsigned modules"
"Disable module locking"
"Disable kernel security"
"Disable SELinux"
"Ignore dm-verity errors"
)

CMDLINE_FILE="$WORKDIR/cmdline.txt"
touch "$CMDLINE_FILE"

show_menu() {
    clear
    echo -e "${CYAN}ChromeOS Kernel Patch Menu — Version ${VERSION}${NC}"
    for i in {0..6}; do
        status="OFF"; color=$RED
        [ "${FLAGS[$i]}" -eq 1 ] && status="ON" && color=$GREEN
        echo -e "${color}$((i+1))) [${status}] ${NAMES[$i]} - ${DESCRIPTIONS[$i]}${NC}"
    done
    echo "-----------------------------------"
    echo "m = edit cmdline | p = proceed | e = exit"
}

show_menu

while true; do
    printf "Choice: "
    read -r choice < /dev/tty
    choice=$(echo "$choice" | tr -d '[:space:]')
    [[ -z "$choice" ]] && continue

    case "$choice" in
        1) FLAGS[0]=$((1-FLAGS[0])) ;;
        2) FLAGS[1]=$((1-FLAGS[1])) ;;
        3) FLAGS[2]=$((1-FLAGS[2])) ;;
        4) FLAGS[3]=$((1-FLAGS[3])) ;;
        5) FLAGS[4]=$((1-FLAGS[4])) ;;
        6) FLAGS[5]=$((1-FLAGS[5])) ;;
        7) FLAGS[6]=$((1-FLAGS[6])) ;;
        m) nano "$CMDLINE_FILE" ;;
        p) break ;;
        e) exit 0 ;;
    esac

    show_menu
done

# Generate cmdline if empty
if [ ! -s "$CMDLINE_FILE" ]; then
    for i in {0..6}; do
        if [ "${FLAGS[$i]}" -eq 1 ]; then
            key="${NAMES[$i]}"
            if [ "$key" == "dm_verity.error_behavior" ]; then
                echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE"
            else
                echo -n "$key " >> "$CMDLINE_FILE"
            fi
        fi
    done
fi

echo -e "${GREEN}[*] Final cmdline:${NC}"
cat "$CMDLINE_FILE"

# -------- FIXED UNPACK + REPACK --------
repack_kernel() {
    IN="$1"
    OUT="$2"

    echo -e "${BLUE}[*] Extracting kernel from $IN...${NC}"

    $VBUTIL --verify "$IN" \
        --get-vmlinuz vmlinuz.bin \
        --get-config old_config.txt

    if [ ! -f vmlinuz.bin ]; then
        echo -e "${RED}[!] Failed to extract vmlinuz${NC}"
        exit 1
    fi

    echo -e "${BLUE}[*] Repacking...${NC}"

    $VBUTIL --repack "$OUT" \
        --oldblob "$IN" \
        --config "$CMDLINE_FILE" \
        --vmlinuz vmlinuz.bin \
        --keyblock "$KEYBLOCK" \
        --signprivate "$PRIVKEY" \
        --version 1

    if [ ! -f "$OUT" ]; then
        echo -e "${RED}[!] Repack failed${NC}"
        exit 1
    fi
}

repack_kernel kernel_A.bin new_kernel_A.bin
repack_kernel kernel_B.bin new_kernel_B.bin

# Flash
echo -e "${BLUE}[*] Flashing...${NC}"
sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
sync

echo -e "${GREEN}[✔] Success. Reboot.${NC}"
