#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}Please run this script with sudo.${NC}"
  exit
fi

get_status() {
    current_op=$(update_engine_client --status 2>/dev/null | grep "CURRENT_OP" | cut -d'=' -f2)
    [ -z "$current_op" ] && current_op="UNKNOWN"

    if [[ "$current_op" == "UPDATE_STATUS_IDLE" ]]; then
        op_display="${GREEN}$current_op${NC}"
    elif [[ "$current_op" == "UPDATE_STATUS_UPDATED_NEED_REBOOT" ]]; then
        op_display="${RED}REBOOT PENDING (Update Staged)${NC}"
    elif [[ "$current_op" == "UPDATE_STATUS_DOWNLOADING" ]]; then
        op_display="${YELLOW}$current_op${NC}"
    else
        op_display="${BLUE}$current_op${NC}"
    fi

    vpd_val=$(vpd -i RW_VPD -l | grep "omahaserver" | cut -d'"' -f2)
    if [ -z "$vpd_val" ]; then
        niaub_state="${RED}DISABLED (Default)${NC}"
    else
        niaub_state="${GREEN}ENABLED ($vpd_val)${NC}"
    fi
}

show_menu() {
    get_status
    clear
    echo -e "${CYAN}==================================================${NC}"
    echo -e "${CYAN}            NIAUB MANAGEMENT UTILITY              ${NC}"
    echo -e "${CYAN}        Version: 1.7 | Author: CriticalHD         ${NC}"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " STATUS: $op_display"
    echo -e " NIAUB:  $niaub_state"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " ${YELLOW}1)${NC} Enable NIAUB"
    echo -e " ${YELLOW}2)${NC} Disable NIAUB"
    echo -e " ${YELLOW}3)${NC} View Credits"
    echo -e " ${YELLOW}4)${NC} Exit (or press 'e')"
    echo -e "${CYAN}--------------------------------------------------${NC}"
    echo -ne "${BLUE}Select an option: ${NC}"
}

enable_niaub() {
    echo -e "\n${YELLOW}Enabling NIAUB...${NC}"
    vpd -i RW_VPD -s "omahaserver=http://127.0.0.1"
    dump_vpd_log --force
    stop update-engine >/dev/null 2>&1
    echo -e "${YELLOW}Purging cache...${NC}"
    rm -rf /var/lib/update_engine/prefs/*
    echo -e "${YELLOW}Resetting partition priority...${NC}"
    /usr/sbin/chromeos-setgoodkernel >/dev/null 2>&1
    start update-engine >/dev/null 2>&1
    echo -e "${GREEN}DONE.${NC}"
    sleep 2
}

disable_niaub() {
    echo -e "\n${YELLOW}Disabling NIAUB...${NC}"
    vpd -i RW_VPD -d "omahaserver"
    dump_vpd_log --force
    stop update-engine >/dev/null 2>&1
    rm -rf /var/lib/update_engine/prefs/*
    start update-engine >/dev/null 2>&1
    echo -e "${GREEN}DONE.${NC}"
    sleep 2
}

show_credits() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}                CREDITS                   ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    echo -e "Concept:   NIAUB"
    echo -e "Scripting: CriticalHD/neonnebula"
    echo -e "Features:  Partition reset + Cache reset + AUB"
    echo -e "${CYAN}==========================================${NC}"
    read -p "Press Enter to return to menu..."
}

while true; do
    show_menu
    read choice
    case $choice in
        1) enable_niaub ;;
        2) disable_niaub ;;
        3) show_credits ;;
        4|e|E) echo -e "${BLUE}Exiting...${NC}"; exit 0 ;;
        *) echo -e "${RED}Invalid option.${NC}"; sleep 1 ;;
    esac
done
