#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}Please run this script with sudo.${NC}"
  exit 1
fi

get_status() {
    current_op=$(update_engine_client --status 2>/dev/null | grep "CURRENT_OP" | cut -d'=' -f2 | tr -d '[:space:]')
    [ -z "$current_op" ] && current_op="UNKNOWN"

    case "$current_op" in
        UPDATE_STATUS_IDLE)                op_display="${GREEN}IDLE${NC}" ;;
        UPDATE_STATUS_UPDATED_NEED_REBOOT) op_display="${RED}REBOOT PENDING${NC}" ;;
        UPDATE_STATUS_DOWNLOADING)         op_display="${YELLOW}DOWNLOADING${NC}" ;;
        UPDATE_STATUS_CHECKING_FOR_UPDATE) op_display="${YELLOW}CHECKING...${NC}" ;;
        UPDATE_STATUS_UPDATE_AVAILABLE)    op_display="${YELLOW}UPDATE AVAILABLE${NC}" ;;
        UPDATE_STATUS_VERIFYING)           op_display="${YELLOW}VERIFYING${NC}" ;;
        UPDATE_STATUS_FINALIZING)          op_display="${YELLOW}FINALIZING${NC}" ;;
        *)                                 op_display="${BLUE}${current_op}${NC}" ;;
    esac

    # Check VPD block
    vpd_val=$(vpd -i RW_VPD -l 2>/dev/null | grep "omahaserver" | cut -d'"' -f2)

    # Check if update-engine is actually running
    ue_running=$(status update-engine 2>/dev/null | grep -c "running")

    # Check if override file exists
    override_exists=0
    [ -f /etc/init/update-engine.override ] && override_exists=1

    if [ -n "$vpd_val" ] && [ "$override_exists" -eq 1 ]; then
        niaub_state="${GREEN}BLOCKED (Full)${NC}"
    elif [ -n "$vpd_val" ] || [ "$override_exists" -eq 1 ]; then
        niaub_state="${YELLOW}PARTIAL${NC}"
    else
        niaub_state="${RED}NOT BLOCKED${NC}"
    fi
}

show_menu() {
    get_status
    clear
    echo -e "${CYAN}==================================================${NC}"
    echo -e "${CYAN}            UPDATE MANAGEMENT UTILITY              ${NC}"
    echo -e "${CYAN}        Version: 2.0 | Author: CriticalHD         ${NC}"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " STATUS:  ${op_display}"
    echo -e " UPDATES: ${niaub_state}"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " ${YELLOW}1)${NC} Block Updates (Persistent)"
    echo -e " ${YELLOW}2)${NC} Unblock Updates"
    echo -e " ${YELLOW}3)${NC} View Credits"
    echo -e " ${YELLOW}e)${NC} Exit"
    echo -e "${CYAN}--------------------------------------------------${NC}"
    echo -ne "${BLUE}Select an option: ${NC}"
}

block_updates() {
    echo -e "\n${YELLOW}Stopping update-engine...${NC}"
    stop update-engine >/dev/null 2>&1
    sleep 1

    echo -e "${YELLOW}Writing VPD redirect (blocks omaha server)...${NC}"
    vpd -i RW_VPD -s "omahaserver=http://127.0.0.1"

    echo -e "${YELLOW}Disabling update-engine service (persists across reboots)...${NC}"
    echo "manual" > /etc/init/update-engine.override

    echo -e "${YELLOW}Purging update cache...${NC}"
    rm -rf /var/lib/update_engine/prefs/*

    echo -e "${YELLOW}Resetting partition priority...${NC}"
    /usr/sbin/chromeos-setgoodkernel >/dev/null 2>&1

    # Verify
    vpd_check=$(vpd -i RW_VPD -l 2>/dev/null | grep "omahaserver")
    override_check=0
    [ -f /etc/init/update-engine.override ] && override_check=1

    if [ -n "$vpd_check" ] && [ "$override_check" -eq 1 ]; then
        echo -e "${GREEN}Updates fully blocked and will stay blocked after reboot.${NC}"
    else
        echo -e "${RED}WARNING: Something may not have applied correctly. Check manually.${NC}"
    fi
    sleep 3
}

unblock_updates() {
    echo -e "\n${YELLOW}Removing update-engine override...${NC}"
    rm -f /etc/init/update-engine.override

    echo -e "${YELLOW}Removing VPD redirect...${NC}"
    vpd -i RW_VPD -d "omahaserver"

    echo -e "${YELLOW}Purging update cache...${NC}"
    rm -rf /var/lib/update_engine/prefs/*

    echo -e "${YELLOW}Starting update-engine...${NC}"
    start update-engine >/dev/null 2>&1
    sleep 1

    vpd_check=$(vpd -i RW_VPD -l 2>/dev/null | grep "omahaserver")
    override_check=0
    [ -f /etc/init/update-engine.override ] && override_check=1

    if [ -z "$vpd_check" ] && [ "$override_check" -eq 0 ]; then
        echo -e "${GREEN}Updates unblocked. System will check for updates normally.${NC}"
    else
        echo -e "${RED}WARNING: Not fully unblocked. Run again or check manually.${NC}"
    fi
    sleep 3
}

show_credits() {
    clear
    echo -e "${CYAN}==========================================${NC}"
    echo -e "${YELLOW}                CREDITS                   ${NC}"
    echo -e "${CYAN}==========================================${NC}"
    echo -e "Concept:   NIAUB"
    echo -e "Scripting: CriticalHD/neonnebula"
    echo -e "Features:  Partition reset + Cache reset + AUB"
    echo -e "${CYAN}==========================================${NC}"
    read -rp "Press Enter to return to menu..." < /dev/tty
}

while true; do
    show_menu
    read -r choice < /dev/tty
    case "$choice" in
        1) block_updates ;;
        2) unblock_updates ;;
        3) show_credits ;;
        e|E) echo -e "\n${BLUE}Exiting...${NC}"; exit 0 ;;
        *) echo -e "\n${RED}Invalid option.${NC}"; sleep 1 ;;
    esac
done
