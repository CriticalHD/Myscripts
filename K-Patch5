#!/bin/bash

VERSION="v27.0.0"
CYAN='\033[0;36m'; NC='\033[0m'; RED='\033[0;31m'; GREEN='\033[0;32m'; BLUE='\033[0;34m'

echo -e "${CYAN}ChromeOS Kernel Patch Script — Version ${VERSION}${NC}"

WORKDIR="/tmp/kernel_patch"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"

KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

DEV_FW_SCRIPT="/mnt/stateful_partition/vboot/bin/make_dev_firmware.sh"

# -----------------------------
# Detect dev firmware
# -----------------------------
echo -e "${BLUE}[*] Checking firmware state...${NC}"

FW_STATUS=$(crossystem dev_boot_signed_only 2>/dev/null)

if [ "$FW_STATUS" != "0" ]; then
    echo -e "${YELLOW}[!] Dev firmware not enabled.${NC}"

    if [ -f "$DEV_FW_SCRIPT" ]; then
        echo -e "${BLUE}[*] Running make_dev_firmware.sh...${NC}"

        sudo bash "$DEV_FW_SCRIPT" --no-modify-hwid --no-modify-gbb

        echo -e "${GREEN}[✔] Dev firmware script executed.${NC}"
        echo -e "${YELLOW}[!] You MUST reboot after firmware install.${NC}"
        echo "Run the script again after reboot."
        exit 0
    else
        echo -e "${RED}[!] make_dev_firmware.sh not found!${NC}"
        exit 1
    fi
else
    echo -e "${GREEN}[✔] Dev firmware already enabled.${NC}"
fi

# -----------------------------
# Detect vbutil
# -----------------------------
if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] No vbutil_kernel or futility found!${NC}"
    exit 1
fi

# -----------------------------
# Backup kernels
# -----------------------------
echo -e "${BLUE}[*] Backing up kernels...${NC}"
sudo dd if=$KERN_A of=kernel_A_backup.bin bs=4M status=progress
sudo dd if=$KERN_B of=kernel_B_backup.bin bs=4M status=progress

# -----------------------------
# Flags
# -----------------------------
FLAGS=(0 0 0 0 0 0 0)
NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
DESCRIPTIONS=(
"Enable developer/debug mode"
"Disable rootfs verification"
"Allow unsigned modules"
"Disable module locking"
"Disable kernel security"
"Disable SELinux"
"Ignore dm-verity errors"
)

CMDLINE_FILE="$WORKDIR/cmdline.txt"
touch "$CMDLINE_FILE"

# -----------------------------
# Menu
# -----------------------------
show_menu() {
    clear
    echo -e "${CYAN}Kernel Patch Menu — ${VERSION}${NC}"
    for i in {0..6}; do
        status="OFF"; color=$RED
        [ "${FLAGS[$i]}" -eq 1 ] && status="ON" && color=$GREEN
        echo -e "${color}$((i+1))) [${status}] ${NAMES[$i]} - ${DESCRIPTIONS[$i]}${NC}"
    done
    echo "-----------------------------------"
    echo "m = manual edit | p = proceed | e = exit"
}

while true; do
    show_menu
    printf "Choice: "
    read -r choice < /dev/tty
    choice=$(echo "$choice" | tr -d '[:space:]')
    [[ -z "$choice" ]] && continue

    case "$choice" in
        1) FLAGS[0]=$((1-FLAGS[0])) ;;
        2) FLAGS[1]=$((1-FLAGS[1])) ;;
        3) FLAGS[2]=$((1-FLAGS[2])) ;;
        4) FLAGS[3]=$((1-FLAGS[3])) ;;
        5) FLAGS[4]=$((1-FLAGS[4])) ;;
        6) FLAGS[5]=$((1-FLAGS[5])) ;;
        7) FLAGS[6]=$((1-FLAGS[6])) ;;
        m) nano "$CMDLINE_FILE" ;;
        p) break ;;
        e) exit 0 ;;
    esac
done

# -----------------------------
# Generate cmdline
# -----------------------------
> "$CMDLINE_FILE"
for i in {0..6}; do
    if [ "${FLAGS[$i]}" -eq 1 ]; then
        key="${NAMES[$i]}"
        if [ "$key" == "dm_verity.error_behavior" ]; then
            echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE"
        else
            echo -n "$key " >> "$CMDLINE_FILE"
        fi
    fi
done
echo "" >> "$CMDLINE_FILE"

echo -e "${GREEN}[*] Final cmdline:${NC}"
cat "$CMDLINE_FILE"

# -----------------------------
# Dump kernels (fresh copy)
# -----------------------------
sudo dd if=$KERN_A of=kernel_A.bin bs=4M status=progress
sudo dd if=$KERN_B of=kernel_B.bin bs=4M status=progress

# -----------------------------
# Repack
# -----------------------------
repack_kernel() {
    IN="$1"
    OUT="$2"

    echo -e "${BLUE}[*] Repacking $IN...${NC}"

    $VBUTIL --repack "$OUT" \
        --oldblob "$IN" \
        --config "$CMDLINE_FILE" \
        --keyblock "$KEYBLOCK" \
        --signprivate "$PRIVKEY" \
        --version 1

    if [ ! -f "$OUT" ]; then
        echo -e "${RED}[!] Repack failed${NC}"
        exit 1
    fi
}

repack_kernel kernel_A.bin new_kernel_A.bin
repack_kernel kernel_B.bin new_kernel_B.bin

# -----------------------------
# Flash
# -----------------------------
echo -e "${BLUE}[*] Flashing kernels...${NC}"
sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
sync

echo -e "${GREEN}[✔] Done. Reboot.${NC}"
