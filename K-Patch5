#!/bin/bash
set -e

VERSION="v39.0.0"
AUTHOR="CriticalHD/neonnebula"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
RED='\033[0;31m'
B='\033[1;31m'
NC='\033[0m'

echo -e "${CYAN}ChromeOS K-Patch Script — Version ${VERSION} — ${AUTHOR}${NC}"

WORKDIR="/tmp/kpatch_work"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

BACKUP_DIR="/mnt/stateful_partition/backups"
mkdir -p "$BACKUP_DIR"

SSD_SCRIPT="/usr/share/vboot/bin/make_dev_ssd.sh"
FW_SCRIPT="/usr/share/vboot/bin/make_dev_firmware.sh"

CMDLINE_FILE="$WORKDIR/cmdline.txt"

# Detect disk
ROOTDEV=$(rootdev -s)
DISK=$(echo "$ROOTDEV" | sed 's/p*[0-9]*$//')

echo -e "${GREEN}[*] Root device:${NC} $ROOTDEV"
echo -e "${GREEN}[*] Using disk:${NC} $DISK"

# Kernel Options
KERNEL_FLAGS=(0 0 0 0 0 0 0)
KERNEL_NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
KERNEL_DESCRIPTIONS=("Enable debug mode" "Disable rootfs verification" "Allow unsigned modules (DANGEROUS)" "Disable module locking (DANGEROUS)" "Disable security (DANGEROUS)" "Disable SELinux (DANGEROUS)" "Ignore dm-verity errors")
KERNEL_COLORS=("$GREEN" "$GREEN" "$YELLOW" "$YELLOW" "$YELLOW" "$YELLOW" "$GREEN")

# Firmware Options
declare -A FW_OPTIONS=(
  [1]="Apply Dev Firmware"
  [2]="Enable Early Console"
  [3]="Enable Console Output"
)
declare -A FW_SELECTED

kernel_menu() {
    while true; do
        clear
        echo -e "${CYAN}Kernel Options — ${VERSION}${NC}"
        echo "------------------"
        for i in "${!KERNEL_NAMES[@]}"; do
            mark="[ ]"
            [[ ${KERNEL_FLAGS[$i]} -eq 1 ]] && mark="[x]"
            echo -e "$((i+1))) ${KERNEL_COLORS[$i]}${KERNEL_NAMES[$i]}${NC} $mark - ${KERNEL_DESCRIPTIONS[$i]}"
        done
        echo "------------------"
        echo "ENTER = continue | e = exit"
        read -r choice < /dev/tty

        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ "$choice" == "e" ]] && exit 0
        [[ -z "$choice" ]] && break

        case "$choice" in
            1|2|3|4|5|6|7)
                idx=$((choice-1))
                KERNEL_FLAGS[$idx]=$((1-KERNEL_FLAGS[$idx]))
                ;;
        esac
    done

    > "$CMDLINE_FILE"
    for i in "${!KERNEL_FLAGS[@]}"; do
        if [[ ${KERNEL_FLAGS[$i]} -eq 1 ]]; then
            key="${KERNEL_NAMES[$i]}"
            [[ "$key" == "dm_verity.error_behavior" ]] \
                && echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE" \
                || echo -n "$key " >> "$CMDLINE_FILE"
        fi
    done
    echo "" >> "$CMDLINE_FILE"

    echo -e "${GREEN}[*] Final cmdline:${NC}"
    cat "$CMDLINE_FILE"
}

firmware_menu() {
    while true; do
        clear
        echo -e "${CYAN}Firmware Options — ${VERSION}${NC}"
        echo "------------------"
        for i in "${!FW_OPTIONS[@]}"; do
            mark="[ ]"
            [[ ${FW_SELECTED[$i]} == "true" ]] && mark="[x]"
            echo -e "$i) ${BLUE}${FW_OPTIONS[$i]}${NC} $mark"
        done
        echo "------------------"
        echo "ENTER = continue | e = exit"
        read -r choice < /dev/tty

        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ "$choice" == "e" ]] && exit 0
        [[ -z "$choice" ]] && break

        if [[ "$choice" =~ ^[1-3]$ ]]; then
            [[ ${FW_SELECTED[$choice]} == "true" ]] && FW_SELECTED[$choice]=false || FW_SELECTED[$choice]=true
        fi
    done
}

fix_gpt() {
    echo -e "${BLUE}[*] Checking GPT kernel types...${NC}"
    if ! cgpt show "$DISK" | grep -q "kernel"; then
        echo -e "${YELLOW}[!] Fixing kernel partition types...${NC}"
        sudo cgpt add -i 2 -t kernel "$DISK"
        sudo cgpt add -i 4 -t kernel "$DISK"
    else
        echo -e "${GREEN}[*] GPT looks fine${NC}"
    fi
}

create_fake_editor() {
    FAKE_EDITOR="$WORKDIR/fake_editor.sh"

    cat > "$FAKE_EDITOR" << 'EOF'
#!/bin/bash
CUSTOM_CONFIG="config.txt"
if [[ -f "$CUSTOM_CONFIG" ]]; then
    cp "$CUSTOM_CONFIG" "$1"
fi
exit 0
EOF

    chmod +x "$FAKE_EDITOR"
}

patch_everything() {
    echo -e "${GREEN}[*] Backing up firmware...${NC}"
    flashrom -p internal -r "$BACKUP_DIR/full_backup.bin"

    if [[ ${FW_SELECTED[1]} == "true" ]]; then
        echo -e "${BLUE}[*] Applying dev firmware...${NC}"
        sudo "$FW_SCRIPT" --nomod_hwid
    fi

    fix_gpt

    cp "$CMDLINE_FILE" "$WORKDIR/config.txt"
    cd "$WORKDIR"

    create_fake_editor

    SSD_FLAGS="--edit_config -f"
    [[ ${FW_SELECTED[2]} == "true" ]] && SSD_FLAGS="$SSD_FLAGS --enable_earlycon"
    [[ ${FW_SELECTED[3]} == "true" ]] && SSD_FLAGS="$SSD_FLAGS --enable_console"

    echo -e "${BLUE}[*] Using EDIT_CONFIG method:${NC} $SSD_FLAGS"

    if ! sudo EDITOR="$WORKDIR/fake_editor.sh" "$SSD_SCRIPT" $SSD_FLAGS; then
        echo -e "${RED}[!] edit_config failed — falling back to set_config...${NC}"

        sudo "$SSD_SCRIPT" \
            --set_config config.txt \
            -f
    fi
}

# Run
kernel_menu
firmware_menu

echo -e "${B}WARNING: This can brick your device${NC}"
echo -n "Continue? (y/N): "
read confirm < /dev/tty
[[ ! "$confirm" =~ ^[Yy]$ ]] && exit 1

patch_everything

echo -e "${GREEN}DONE — reboot now${NC}"
