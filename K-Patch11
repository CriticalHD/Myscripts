#!/bin/bash
set -e

VERSION="v46.0.0"
AUTHOR="CriticalHD/neonnebula"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
RED='\033[0;31m'
B='\033[1;31m'
NC='\033[0m'

echo -e "${CYAN}ChromeOS K-Patch Script — Version ${VERSION} — ${AUTHOR}${NC}"

WORKDIR="/tmp/kpatch_work"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

BACKUP_DIR="/mnt/stateful_partition/backups"
mkdir -p "$BACKUP_DIR"

# --------------------------
# Copy binaries to stateful_partition
# --------------------------
SSD_SCRIPT="/mnt/stateful_partition/make_dev_ssd.sh"
FW_SCRIPT="/mnt/stateful_partition/make_dev_firmware.sh"

for f in "/usr/share/vboot/bin/make_dev_ssd.sh" "/usr/share/vboot/bin/make_dev_firmware.sh"; do
    if [[ ! -f "/mnt/stateful_partition/$(basename $f)" ]]; then
        echo -e "${YELLOW}[*] Copying $(basename $f) to stateful partition...${NC}"
        sudo cp "$f" /mnt/stateful_partition/
        sudo chmod +x "/mnt/stateful_partition/$(basename $f)"
    fi
done

# --------------------------
# Remount stateful RW+exec
# --------------------------
echo -e "${YELLOW}[*] Remounting /mnt/stateful_partition RW+exec...${NC}"
sudo mount -o remount,rw,exec /mnt/stateful_partition
echo -e "${GREEN}[*] /mnt/stateful_partition is writable and executable${NC}"

CMDLINE_FILE="$WORKDIR/cmdline.txt"

# --------------------------
# Kernel Options
# --------------------------
KERNEL_FLAGS=(0 0 0 0 0 0 0)
KERNEL_NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
KERNEL_DESCRIPTIONS=("Enable developer/debug mode" "Turn off rootfs verification" "Allow unsigned modules (DANGEROUS)" "Disable module locking (DANGEROUS)" "Disable extra kernel security (DANGEROUS)" "Disable SELinux enforcement (DANGEROUS)" "Ignore dm-verity errors on boot")
KERNEL_COLORS=("$GREEN" "$GREEN" "$YELLOW" "$YELLOW" "$YELLOW" "$YELLOW" "$GREEN")

# --------------------------
# Firmware Options
# --------------------------
declare -A FW_OPTIONS=(
  [1]="Apply Dev Firmware"
  [2]="Enable Early Console"
  [3]="Enable Console Output"
)
declare -A FW_SELECTED

# --------------------------
# Kernel menu
# --------------------------
kernel_menu() {
    while true; do
        clear
        echo -e "${CYAN}ChromeOS Kernel Patch — Version ${VERSION} — ${AUTHOR}${NC}"
        echo -e "${B}Legend:${NC} ${GREEN}Safe${NC} | ${YELLOW}Dangerous${NC}"
        echo "------------------"
        for i in "${!KERNEL_NAMES[@]}"; do
            mark="[ ]"
            [[ ${KERNEL_FLAGS[$i]} -eq 1 ]] && mark="[x]"
            echo -e "$((i+1))) ${KERNEL_COLORS[$i]}${KERNEL_NAMES[$i]}${NC} $mark - ${KERNEL_DESCRIPTIONS[$i]}"
        done
        echo "------------------"
        echo -n "Choice (number to toggle, ENTER to continue, e to exit): "
        read -r choice < /dev/tty

        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ "$choice" == "e" ]] && exit 0
        [[ -z "$choice" ]] && break

        if [[ "$choice" =~ ^[1-7]$ ]]; then
            idx=$((choice-1))
            KERNEL_FLAGS[$idx]=$((1-KERNEL_FLAGS[$idx]))
        fi
    done
}

# --------------------------
# Firmware menu
# --------------------------
firmware_menu() {
    while true; do
        clear
        echo -e "${CYAN}ChromeOS Firmware Menu — Version ${VERSION} — ${AUTHOR}${NC}"
        echo "------------------"
        for i in "${!FW_OPTIONS[@]}"; do
            mark="[ ]"
            [[ ${FW_SELECTED[$i]} == "true" ]] && mark="[x]"
            echo -e "$i) ${BLUE}${FW_OPTIONS[$i]}${NC} $mark"
        done
        echo "------------------"
        echo -n "Choice (number to toggle, ENTER to continue, e to exit): "
        read -r choice < /dev/tty

        choice=$(echo "$choice" | tr -d '[:space:]')
        [[ "$choice" == "e" ]] && exit 0
        [[ -z "$choice" ]] && break

        if [[ "$choice" =~ ^[1-3]$ ]]; then
            [[ ${FW_SELECTED[$choice]} == "true" ]] && FW_SELECTED[$choice]=false || FW_SELECTED[$choice]=true
        fi
    done
}

# --------------------------
# Fake editor
# --------------------------
create_fake_editor() {
FAKE_EDITOR="/mnt/stateful_partition/kpatch_editor.sh"
cat > "$FAKE_EDITOR" << 'EOF'
#!/bin/bash
BASE="/tmp/kpatch_work/config.txt"
PART=$(basename "$1" | awk -F. '{print $NF}')
if [[ -f "$BASE.$PART" ]]; then
    cp "$BASE.$PART" "$1"
fi
exit 0
EOF
chmod +x "$FAKE_EDITOR"
}

# --------------------------
# Build per-partition cmdline
# --------------------------
build_partition_cmdlines() {
    echo -e "${BLUE}[*] Building per-partition cmdlines...${NC}"

    > "$WORKDIR/config.txt.2"
    > "$WORKDIR/config.txt.4"

    for i in "${!KERNEL_FLAGS[@]}"; do
        if [[ ${KERNEL_FLAGS[$i]} -eq 1 ]]; then
            key="${KERNEL_NAMES[$i]}"
            [[ "$key" == "dm_verity.error_behavior" ]] \
                && echo -n "dm_verity.error_behavior=ignore " >> "$WORKDIR/config.txt.2" \
                || echo -n "$key " >> "$WORKDIR/config.txt.2"
            [[ "$key" == "dm_verity.error_behavior" ]] \
                && echo -n "dm_verity.error_behavior=ignore " >> "$WORKDIR/config.txt.4" \
                || echo -n "$key " >> "$WORKDIR/config.txt.4"
        fi
    done
    echo "" >> "$WORKDIR/config.txt.2"
    echo "" >> "$WORKDIR/config.txt.4"

    echo -e "${GREEN}[*] Partition cmdlines built:${NC}"
    cat "$WORKDIR/config.txt.2"
}

# --------------------------
# Verify kernel changes
# --------------------------
verify_kernel_changes() {
    echo -e "${BLUE}[*] Verifying kernel A/B changes...${NC}"

    for part in 2 4; do
        current=$(sudo vbutil_kernel --get_config /dev/mmcblk0p$part 2>/dev/null || echo "")
        desired=$(cat "$WORKDIR/config.txt.$part")
        if [[ "$current" == "$desired" ]]; then
            echo -e "${YELLOW}[!] Kernel partition $part config is identical to desired cmdline${NC}"
        else
            echo -e "${GREEN}[*] Kernel partition $part will be updated${NC}"
        fi
    done
}

# --------------------------
# Patch firmware & SSD
# --------------------------
patch_everything() {
    echo -e "${GREEN}[*] Backing up firmware...${NC}"
    flashrom -p internal -r "$BACKUP_DIR/full_backup.bin"

    if [[ ${FW_SELECTED[1]} == "true" ]]; then
        echo -e "${BLUE}[*] Applying dev firmware...${NC}"
        sudo "$FW_SCRIPT" --nomod_hwid
    fi

    build_partition_cmdlines
    create_fake_editor
    verify_kernel_changes

    SSD_FLAGS="--edit_config -f"
    [[ ${FW_SELECTED[2]} == "true" ]] && SSD_FLAGS="$SSD_FLAGS --enable_earlycon"
    [[ ${FW_SELECTED[3]} == "true" ]] && SSD_FLAGS="$SSD_FLAGS --enable_console"

    echo -e "${BLUE}[*] Running make_dev_ssd.sh...${NC}"
    sudo EDITOR="$FAKE_EDITOR" "$SSD_SCRIPT" $SSD_FLAGS
}

# --------------------------
# Run
# --------------------------
kernel_menu
firmware_menu

echo -e "${B}WARNING: This can brick your device${NC}"
echo -n "Continue? (y/N): "
read confirm < /dev/tty
[[ "$confirm" != "y" && "$confirm" != "Y" ]] && exit 1

patch_everything

echo -e "${GREEN}DONE — reboot now${NC}"
