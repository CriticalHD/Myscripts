#!/usr/bin/env bash
set -e

# =======================
# K-Patch Menu Script (VT2-Compatible)
# =======================

# Colors
Y="\033[1;33m"  # Yellow
G="\033[1;32m"  # Green
C="\033[1;36m"  # Cyan
R="\033[0;31m"  # Red
B="\033[1;31m"  # Bright Red
N="\033[0m"     # Reset

# Folders
VBOOT_BASE='/usr/share/vboot'
DEFAULT_KEYS_FOLDER="$VBOOT_BASE/devkeys"
DEFAULT_BACKUP_FOLDER='/mnt/stateful_partition/backups'
[ ! -d "$DEFAULT_BACKUP_FOLDER" ] && mkdir -p "$DEFAULT_BACKUP_FOLDER"

# Logging
log_info() { printf "${G}Info: %b${N}\n" "$*"; }
log_warn() { printf "${Y}Warning: %b${N}\n" "$*"; }
log_error() { printf "${B}Error: %b${N}\n" "$*"; }
fail() { log_error "$*"; exit 1; }
[ "$EUID" -ne 0 ] && fail "Please run as root"

# =======================
# Patchable Options
# =======================
declare -A OPTIONS=(
  [1]="Remove RootFS Verification"
  [2]="Enable Developer Mode / Dev Keys"
  [3]="Enable Early Console / Serial"
  [4]="Disable SELinux / Security"
  [5]="Custom GBB Flags"
  [6]="Enable Recovery Partition Mods"
  [7]="Modify TPM / Rollback Enforcement"
  [8]="Modify Hardware ID / Allow Cross-Device Boot"
)

# Default selection array
declare -A SELECTED_OPTIONS
GBB_FLAGS=""
KERNEL_PARTITIONS="2 4"

# =======================
# Interactive VT2 Menu
# =======================
kpatch_menu() {
    while true; do
        echo -e "${Y}=== K-Patch Menu ===${N}"
        echo -e "${C}Type numbers separated by spaces to toggle options, press Enter when done:${N}"
        echo

        for i in $(seq 1 ${#OPTIONS[@]}); do
            mark="[ ]"
            [[ ${SELECTED_OPTIONS[$i]} == "true" ]] && mark="[x]"
            echo -e "${G}$i)${N} ${OPTIONS[$i]} $mark"
        done

        echo -n "Enter selection (or press Enter to finish): "
        read input
        [[ -z "$input" ]] && break

        for num in $input; do
            if [[ ${OPTIONS[$num]} ]]; then
                if [[ ${SELECTED_OPTIONS[$num]} == "true" ]]; then
                    SELECTED_OPTIONS[$num]=false
                else
                    SELECTED_OPTIONS[$num]=true
                fi
            else
                echo -e "${R}Ignoring invalid selection: $num${N}"
            fi
        done
        echo
    done

    # If Custom GBB is selected, ask for hex
    [[ ${SELECTED_OPTIONS[5]} == "true" ]] && {
        echo -n "Enter custom GBB flags in hex (e.g., 0x9a31): "
        read GBB_FLAGS
    }

    # Ask for kernel partitions
    echo -n "Kernel partitions to patch (default 2 4): "
    read ans
    KERNEL_PARTITIONS="${ans:-2 4}"
}

# =======================
# Backup Firmware
# =======================
backup_firmware() {
    log_info "Backing up full firmware..."
    flashrom -p host -r "$DEFAULT_BACKUP_FOLDER/full_backup.bin"
    log_info "Backup saved to $DEFAULT_BACKUP_FOLDER/full_backup.bin"
}

# =======================
# Patch Firmware / GBB
# =======================
patch_firmware() {
    backup_firmware

    [[ ${SELECTED_OPTIONS[2]} == "true" ]] && log_info "Applying dev keys..." && \
        make_dev_firmware.sh --keys "$DEFAULT_KEYS_FOLDER" --force_backup true

    local gbb_opts=""
    [[ ${SELECTED_OPTIONS[1]} == "true" ]] && gbb_opts="$gbb_opts --remove_rootfs_verification"
    [[ ${SELECTED_OPTIONS[6]} == "true" ]] && gbb_opts="$gbb_opts --allow_recovery_mod"
    [[ ${SELECTED_OPTIONS[7]} == "true" ]] && gbb_opts="$gbb_opts --disable_tpm_rollback"
    [[ ${SELECTED_OPTIONS[8]} == "true" ]] && gbb_opts="$gbb_opts --nomod_hwid"

    # Apply SELinux or custom GBB flags
    [[ ${SELECTED_OPTIONS[4]} == "true" || -n "$GBB_FLAGS" ]] && \
        log_info "Flashing GBB flags $GBB_FLAGS" && \
        futility gbb -s --flash --flags="${GBB_FLAGS:-0x9a31}"

    # Apply combined options
    if [[ -n "$gbb_opts" ]]; then
        log_info "Applying GBB options: $gbb_opts"
        make_dev_ssd.sh $gbb_opts
    fi
}

# =======================
# Patch Kernel
# =======================
patch_kernel() {
    local opts="--keys $DEFAULT_KEYS_FOLDER"
    [[ ${SELECTED_OPTIONS[1]} == "true" ]] && opts="$opts --remove_rootfs_verification"
    [[ ${SELECTED_OPTIONS[3]} == "true" ]] && opts="$opts --enable_earlycon true --enable_console true"
    opts="$opts --partitions $KERNEL_PARTITIONS"

    log_info "Patching kernel with options: $opts"
    make_dev_ssd.sh $opts
}

# =======================
# Main
# =======================
main() {
    kpatch_menu

    echo -e "${B}Warning: This can brick your device!${N}"
    echo -n "Continue? (y/N): "
    read confirm
    [[ ! "$confirm" =~ ^[Yy]$ ]] && { echo "Aborting..."; exit 1; }

    patch_firmware
    patch_kernel

    log_info "Done! Firmware and kernel patched with selected options."
}

main
