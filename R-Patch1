#!/bin/bash

VERSION="v2.2.0-debug"
AUTHOR="CriticalHD/neonnebula"

CYAN='\033[0;36m'
WHITE='\033[1;37m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

clear
echo -e "${CYAN}[*] Debugging TPM + Sysinfo...${NC}"
echo

echo -e "${YELLOW}== TPMC PATH ==${NC}"
which tpmc || echo "tpmc NOT FOUND"

echo
echo -e "${YELLOW}== TPM VERSION ==${NC}"
tpmc tpmver 2>&1 || echo "FAILED"

echo
echo -e "${YELLOW}== KERNVER RAW (0x1008) ==${NC}"
tpmc read 0x1008 9 2>&1 || echo "FAILED"

echo
echo -e "${YELLOW}== FWMP RAW (0x100A) ==${NC}"
tpmc read 0x100A 5 2>&1 || echo "FAILED"

echo
echo -e "${YELLOW}== FWID ==${NC}"
cat /sys/class/platform/chromeos_acpi/FWID 2>/dev/null || \
cat /proc/device-tree/firmware/chromeos/firmware-version 2>/dev/null || \
echo "FAILED"

echo
echo -e "${YELLOW}== GSC VERSION ==${NC}"
gsctool -a -f 2>&1 | tail -n1 || echo "FAILED"

echo
echo -e "${YELLOW}== GSC TYPE ==${NC}"
/opt/kvs/bin/is_ti50 2>&1 || echo "FAILED"

echo
echo -e "${CYAN}Press Enter to exit...${NC}"
read < /dev/tty
