#!/bin/bash

PATCH_FLAG="/var/rpatch_fw_patched"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m"

INDEX="0x1008"
WORKDIR="/tmp/rpatch_work"

trim_newline() { echo -n "$1" | tr -d '\n'; }

getTpmVersion()  { trim_newline "$(tpmc tpmver 2>/dev/null)"; }
getGSCType()     { [[ "$(tpmc tpmver 2>/dev/null)" == "1.2" ]] && echo "preCr50" || (gsctool -a -I 2>/dev/null | grep -qi AllowUnverifiedRo && echo "ti50" || echo "cr50"); }
getKernver()     { output=$(tpmc read $INDEX 9 2>/dev/null); trim_newline "$output"; [[ "$output" == "" ]] && echo "UNKNOWN" || echo "$output"; }

is_fw_patched() { [[ -f "$PATCH_FLAG" ]]; }

detect_version() {
    first_byte=$(tpmc read $INDEX 1 2>/dev/null | awk '{print $1}')
    if [[ "$first_byte" == "02" ]]; then echo "V0"
    elif [[ "$first_byte" == "10" ]]; then echo "V1"
    else echo "UNKNOWN"; fi
}

to_le32() {
    local val=$1
    printf "%02x %02x %02x %02x" \
        $(( val & 0xFF )) \
        $(( (val >> 8) & 0xFF )) \
        $(( (val >> 16) & 0xFF )) \
        $(( (val >> 24) & 0xFF ))
}

crc8() {
    local data=("$@"); local crc=0
    for byte in "${data[@]}"; do
        b=$((16#$byte))
        for ((i=0;i<8;i++)); do
            mix=$(( (crc ^ b) & 1 ))
            crc=$(( crc >> 1 ))
            (( mix != 0 )) && crc=$(( crc ^ 0x8C ))
            b=$(( b >> 1 ))
        done
    done
    printf "%02x" $crc
}

build_struct() {
    local version=$1 kernver=$2
    if [[ "$version" == "V0" ]]; then
        local struct_version="02"
        local uid=("4c" "57" "52" "47")
        local kv=($(to_le32 "$kernver"))
        local reserved=("00" "00" "00")
        local crc="00"
        local full=("$struct_version" "${uid[@]}" "${kv[@]}" "${reserved[@]}" "$crc")
        full[11]=$(crc8 "${full[@]:0:11}")
    elif [[ "$version" == "V1" ]]; then
        local struct_version="10"
        local struct_size="28"
        local crc="00"
        local flags="00"
        local kv=($(to_le32 "$kernver"))
        local ec_hash=()
        for ((i=0;i<32;i++)); do ec_hash+=("00"); done
        local full=("$struct_version" "$struct_size" "$crc" "$flags" "${kv[@]}" "${ec_hash[@]}")
        full[2]=$(crc8 "${full[@]:3}")
    else
        echo -e "${RED}Unknown struct version${NC}"
        return 1
    fi
    echo "${full[@]}"
}

draw_header() {
    clear
    echo -e "${CYAN}╔══════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}        ${BOLD}R-Patch v6.0${NC}          ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}      By: CriticalHD          ${CYAN}║${NC}"
    echo -e "${CYAN}╠══════════════════════════════╣${NC}"

    if is_fw_patched; then
        echo -e "${CYAN}║${NC} Firmware: ${GREEN}[PATCHED]${NC}           ${CYAN}║${NC}"
    else
        echo -e "${CYAN}║${NC} Firmware: ${RED}[NOT PATCHED]${NC}       ${CYAN}║${NC}"
    fi

    echo -e "${CYAN}║${NC} TPM: $(getTpmVersion)  GSC: $(getGSCType)        ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC} Kernver: $(getKernver)   ${CYAN}║${NC}"
    echo -e "${CYAN}╚══════════════════════════════╝${NC}"
    echo
}

change_rollback() {
    if ! is_fw_patched; then
        echo -e "${RED}Firmware not patched. Patch firmware first (option 2).${NC}"
        echo "Press Enter to return..."
        read -r </dev/tty
        return
    fi

    local version=$(detect_version)
    [[ "$version" == "UNKNOWN" ]] && {
        echo -e "${RED}Cannot detect TPM struct version.${NC}"
        read -r </dev/tty
        return
    }

    echo -e "${CYAN}Detected struct version: $version${NC}"
    echo -e "${CYAN}Current kernver: $(getKernver)${NC}"
    echo
    echo -e "Select target kernver:"
    echo -e "  ${YELLOW}0)${NC} KV0 — Boots all versions"
    echo -e "  ${YELLOW}1)${NC} KV1 — Boots all versions"
    echo -e "  ${YELLOW}2)${NC} KV2 — Boots R112+"
    echo -e "  ${YELLOW}3)${NC} KV3 — Boots R120+"
    echo -e "  ${YELLOW}4)${NC} KV4 — Boots R125+"
    echo -e "  ${YELLOW}5)${NC} KV5 — Boots R133+"
    echo -e "  ${YELLOW}6)${NC} KV6"
    echo -e "  ${YELLOW}7)${NC} KV7"
    echo -e "  ${YELLOW}B)${NC} Back"
    echo
    echo -n "Choice: "
    read -r kvchoice </dev/tty

    [[ "$kvchoice" =~ ^[Bb]$ ]] && return
    [[ ! "$kvchoice" =~ ^[0-7]$ ]] && {
        echo -e "${RED}Invalid choice.${NC}"
        sleep 1
        return
    }

    # Build kernver value: kv N = 0x00010000 + N (except kv0 = 0x00000000)
    local kernver_val
    if [[ "$kvchoice" == "0" ]]; then
        kernver_val=0
    else
        kernver_val=$(( 0x00010000 + kvchoice ))
    fi

    local bytes=($(build_struct "$version" "$kernver_val"))
    [[ $? -ne 0 ]] && return

    echo
    echo -e "${CYAN}Struct bytes:${NC} ${bytes[*]}"
    echo -e "${YELLOW}Write KV${kvchoice} to TPM? (y/N):${NC} "
    read -r confirm </dev/tty
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && return

    sudo initctl stop trunksd 2>/dev/null
    sudo initctl stop tcsd 2>/dev/null

    tpmc write $INDEX "${bytes[@]}"
    local rc=$?

    sudo initctl start trunksd 2>/dev/null

    if [[ $rc -eq 0 ]]; then
        echo -e "${GREEN}Kernver set to KV${kvchoice} successfully!${NC}"
    else
        echo -e "${RED}Write failed (exit code $rc). Is firmware patched?${NC}"
    fi

    echo "Press Enter to continue..."
    read -r </dev/tty
}

patch_firmware() {
    echo -e "${CYAN}==============================${NC}"
    echo -e "${CYAN}     Firmware Patcher${NC}"
    echo -e "${CYAN}==============================${NC}"
    echo
    echo -e "${YELLOW}This will:${NC}"
    echo "  1. Dump firmware via flashrom"
    echo "  2. Patch platform hierarchy disable call"
    echo "  3. Re-sign with make_dev_firmware.sh"
    echo "  4. Flash back to device"
    echo
    echo -e "${RED}WARNING: This modifies your firmware. Incorrect use may brick your device.${NC}"
    echo -n "Continue? (y/N): "
    read -r confirm </dev/tty
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && return

    mkdir -p "$WORKDIR"

    echo -e "${CYAN}[1/4] Dumping firmware...${NC}"
    flashrom -p internal -r "$WORKDIR/firmware.bin" 2>&1
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}Flashrom dump failed!${NC}"
        read -r </dev/tty
        return
    fi
    echo -e "${GREEN}Firmware dumped.${NC}"

    echo -e "${CYAN}[2/4] Patching FW_MAIN_A and FW_MAIN_B...${NC}"

    # Extract FW_MAIN_A and FW_MAIN_B
    futility dump_fmap -x "$WORKDIR/firmware.bin" FW_MAIN_A FW_MAIN_B 2>/dev/null

    # Patch: replace TPM2 HierarchyControl command that disables platform hierarchy
    # Sequence: TPM_CC_HIERARCHY_CONTROL (0x00000121) with TPM_RH_PLATFORM (0x4000000C) state=NO (0x0000)
    # We patch the state byte from 0x00 (NO) to 0x01 (YES) to keep PH enabled
    python3 - "$WORKDIR/FW_MAIN_A" "$WORKDIR/FW_MAIN_A.patched" <<'EOF'
import sys

with open(sys.argv[1], 'rb') as f:
    data = bytearray(f.read())

# Search for HierarchyControl command disabling platform hierarchy
# TPM_CC_HIERARCHY_CONTROL = 0x00000121
# TPM_RH_PLATFORM = 0x4000000C
# state = NO = 0x0000
target = bytes([0x00, 0x00, 0x01, 0x21, 0x40, 0x00, 0x00, 0x0C])
count = 0
i = 0
while i < len(data) - len(target):
    if data[i:i+len(target)] == target:
        # Find the state bytes after the enable handle (4 more bytes ahead)
        state_offset = i + len(target) + 4
        if state_offset + 1 < len(data):
            if data[state_offset] == 0x00 and data[state_offset+1] == 0x00:
                print(f"Found PH disable call at offset 0x{i:08x}, patching state NO->YES")
                data[state_offset] = 0x00
                data[state_offset+1] = 0x01
                count += 1
    i += 1

if count == 0:
    print("WARNING: Pattern not found in FW_MAIN_A. Firmware may already be patched or pattern differs.")
else:
    print(f"Patched {count} occurrence(s).")

with open(sys.argv[2], 'wb') as f:
    f.write(data)
EOF

    python3 - "$WORKDIR/FW_MAIN_B" "$WORKDIR/FW_MAIN_B.patched" <<'EOF'
import sys

with open(sys.argv[1], 'rb') as f:
    data = bytearray(f.read())

target = bytes([0x00, 0x00, 0x01, 0x21, 0x40, 0x00, 0x00, 0x0C])
count = 0
i = 0
while i < len(data) - len(target):
    if data[i:i+len(target)] == target:
        state_offset = i + len(target) + 4
        if state_offset + 1 < len(data):
            if data[state_offset] == 0x00 and data[state_offset+1] == 0x00:
                print(f"Found PH disable call at offset 0x{i:08x}, patching state NO->YES")
                data[state_offset] = 0x00
                data[state_offset+1] = 0x01
                count += 1
    i += 1

if count == 0:
    print("WARNING: Pattern not found in FW_MAIN_B.")
else:
    print(f"Patched {count} occurrence(s).")

with open(sys.argv[2], 'wb') as f:
    f.write(data)
EOF

    echo -e "${GREEN}Patching done.${NC}"

    echo -e "${CYAN}[3/4] Re-signing firmware with make_dev_firmware.sh...${NC}"
    /usr/share/vboot/bin/make_dev_firmware.sh --nomod_hwid --nomod_gbb 2>&1
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}Firmware signing failed!${NC}"
        read -r </dev/tty
        return
    fi
    echo -e "${GREEN}Firmware signed.${NC}"

    echo
    echo -e "${RED}[4/4] Ready to flash patched firmware back to device.${NC}"
    echo -e "${RED}THIS IS THE POINT OF NO RETURN. Flash firmware? (y/N):${NC} "
    read -r flashconfirm </dev/tty
    [[ "$flashconfirm" != "y" && "$flashconfirm" != "Y" ]] && {
        echo "Aborted. No changes written."
        read -r </dev/tty
        return
    }

    flashrom -p internal -w "$WORKDIR/firmware.bin" 2>&1
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}Flash failed! Your device may still be okay if it wasn't interrupted.${NC}"
        read -r </dev/tty
        return
    fi

    touch "$PATCH_FLAG"
    echo -e "${GREEN}Firmware patched and flashed successfully!${NC}"
    echo -e "${YELLOW}Reboot for changes to take effect.${NC}"
    echo "Press Enter to continue..."
    read -r </dev/tty
}

# Main loop
while true; do
    draw_header

    if is_fw_patched; then
        echo -e "  ${YELLOW}1)${NC} Change Rollback (Kernver)"
    else
        echo -e "  ${RED}1) Change Rollback (Kernver) — Patch firmware first!${NC}"
    fi

    echo -e "  ${YELLOW}2)${NC} Patch Firmware"
    echo -e "  ${YELLOW}3)${NC} Exit"
    echo
    echo -n "Choice: "
    read -r choice </dev/tty

    case "$choice" in
        1) change_rollback ;;
        2) patch_firmware ;;
        3) exit 0 ;;
        *) echo -e "${RED}Invalid choice.${NC}"; sleep 1 ;;
    esac
done
