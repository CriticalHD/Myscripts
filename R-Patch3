#!/bin/bash

# ==============================
# R-Patch v5.3 (fixed menu)
# Author: CriticalHD/neonnebula
# ==============================

INDEX="0x1008"

# Colors
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
NC="\033[0m"

# ------------------------------
# CRC8
# ------------------------------
crc8() {
    local data=("$@")
    local crc=0
    for byte in "${data[@]}"; do
        b=$((16#$byte))
        for ((i=0;i<8;i++)); do
            mix=$(( (crc ^ b) & 1 ))
            crc=$(( crc >> 1 ))
            (( mix != 0 )) && crc=$(( crc ^ 0x8C ))
            b=$(( b >> 1 ))
        done
    done
    printf "%02x" $crc
}

# ------------------------------
# Convert u32 → little endian
# ------------------------------
to_le32() {
    local val=$1
    printf "%02x %02x %02x %02x" \
        $(( val & 0xFF )) \
        $(( (val >> 8) & 0xFF )) \
        $(( (val >> 16) & 0xFF )) \
        $(( (val >> 24) & 0xFF ))
}

# ------------------------------
# Detect struct version
# ------------------------------
detect_version() {
    local byte=$(tpmc read $INDEX 1 2>/dev/null | awk '{print $1}')
    [[ "$byte" == "02" ]] && echo "V0" && return
    [[ "$byte" == "10" ]] && echo "V1" && return
    echo "UNKNOWN"
}

# ------------------------------
# Build struct
# ------------------------------
build_struct() {
    local version=$1
    local kernver=$2

    if [[ "$version" == "V0" ]]; then
        struct_version="02"
        uid=("4c" "57" "52" "47")
        kv=($(to_le32 "$kernver"))
        reserved=("00" "00" "00")
        crc="00"
        full=("$struct_version" "${uid[@]}" "${kv[@]}" "${reserved[@]}" "$crc")
        crc_val=$(crc8 "${full[@]:0:11}")
        full[11]=$crc_val

    elif [[ "$version" == "V1" ]]; then
        struct_version="10"
        struct_size="28"
        crc="00"
        flags="00"
        kv=($(to_le32 "$kernver"))
        ec_hash=()
        for ((i=0;i<32;i++)); do ec_hash+=("00"); done
        full=("$struct_version" "$struct_size" "$crc" "$flags" "${kv[@]}" "${ec_hash[@]}")
        crc_val=$(crc8 "${full[@]:3}")
        full[2]=$crc_val

    else
        echo -e "${RED}Unknown struct version${NC}"
        return 1
    fi

    echo "${full[@]}"
}

# ------------------------------
# Write kernver
# ------------------------------
write_kernver() {
    echo
    version=$(detect_version)

    if [[ "$version" == "UNKNOWN" ]]; then
        echo -e "${RED}Cannot detect TPM struct version${NC}"
        sleep 2
        return
    fi

    echo -e "${CYAN}Detected version: $version${NC}"

    read -r -p "Enter new kernver (hex, e.g. 0x00010001): " val < /dev/tty

    if [[ "$val" =~ ^0x[0-9a-fA-F]+$ ]]; then
        kernver=$((val))
    else
        echo -e "${RED}Invalid number${NC}"
        sleep 1
        return
    fi

    bytes=($(build_struct "$version" "$kernver")) || return

    echo -e "${CYAN}Constructed struct:${NC}"
    printf "%s " "${bytes[@]}"
    echo -e "\n"

    read -r -p "Confirm write? (y/N): " c < /dev/tty
    [[ "$c" != "y" ]] && return

    tpmc write $INDEX "${bytes[@]}"
    echo -e "${GREEN}Write attempted.${NC}"

    read -r -p "Press Enter to return..." _ < /dev/tty
}

# ------------------------------
# DRAW MENU (no flicker)
# ------------------------------
draw_menu() {
    tput clear
    tput cup 0 0

    echo -e "${CYAN}==============================${NC}"
    echo -e "${CYAN}        R-Patch v5.3${NC}"
    echo -e "${CYAN}    by CriticalHD/neonnebula${NC}"
    echo -e "${CYAN}==============================${NC}"
    echo
    echo -e "${YELLOW}[1]${NC} Set kernver (auto-detect V0/V1)"
    echo -e "${YELLOW}[Q]${NC} Quit"
    echo
    echo -n "Choice: "
}

# ------------------------------
# MENU (FINAL FIX)
# ------------------------------
while true; do
    draw_menu

    # read SINGLE KEY (no enter, no spam, real TTY)
    IFS= read -rsn1 choice < /dev/tty

    case "$choice" in
        1)
            write_kernver
            ;;
        [Qq])
            tput clear
            exit 0
            ;;
        *)
            # show error without redraw spam
            echo
            echo -e "${RED}Invalid choice${NC}"
            sleep 0.8
            ;;
    esac
done
