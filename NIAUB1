#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

if [ "$EUID" -ne 0 ]; then
  echo -e "${RED}Please run this script with sudo.${NC}"
  exit
fi

get_status() {
    # We only run this when the menu starts or after an action
    current_op=$(update_engine_client --status 2>/dev/null | grep "CURRENT_OP" | cut -d'=' -f2)
    [ -z "$current_op" ] && current_op="IDLE"

    if [[ "$current_op" == "UPDATE_STATUS_IDLE" ]]; then
        op_display="${GREEN}$current_op${NC}"
    elif [[ "$current_op" == "UPDATE_STATUS_UPDATED_NEED_REBOOT" ]]; then
        op_display="${RED}⚠️ REBOOT PENDING${NC}"
    else
        op_display="${YELLOW}$current_op${NC}"
    fi

    vpd_val=$(vpd -i RW_VPD -l | grep "omahaserver" | cut -d'"' -f2)
    if [ -z "$vpd_val" ]; then
        niaub_state="${RED}DISABLED${NC}"
    else
        niaub_state="${GREEN}ENABLED${NC}"
    fi
}

show_menu() {
    # Using 'tput clear' once at the start to prevent the flashing loop
    tput clear
    echo -e "${CYAN}==================================================${NC}"
    echo -e "${CYAN}            NIAUB MANAGEMENT UTILITY              ${NC}"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " STATUS: $op_display"
    echo -e " NIAUB:  $niaub_state"
    echo -e "${CYAN}==================================================${NC}"
    echo -e " ${YELLOW}1)${NC} Enable NIAUB"
    echo -e " ${YELLOW}2)${NC} Disable NIAUB"
    echo -e " ${YELLOW}3)${NC} Refresh Status"
    echo -e " ${YELLOW}4)${NC} Exit"
    echo -e "${CYAN}--------------------------------------------------${NC}"
}

# Initial status pull
echo "Loading system status... (Please wait)"
get_status

while true; do
    show_menu
    read -r -p " Selection: " choice
    
    case "$choice" in
        1)
            echo -e "\nEnabling..."
            vpd -i RW_VPD -s "omahaserver=http://127.0.0.1"
            dump_vpd_log --force
            stop update-engine >/dev/null 2>&1
            rm -rf /var/lib/update_engine/prefs/*
            /usr/sbin/chromeos-setgoodkernel >/dev/null 2>&1
            start update-engine >/dev/null 2>&1
            get_status 
            ;;
        2)
            echo -e "\nDisabling..."
            vpd -i RW_VPD -d "omahaserver"
            dump_vpd_log --force
            stop update-engine >/dev/null 2>&1
            rm -rf /var/lib/update_engine/prefs/*
            start update-engine >/dev/null 2>&1
            get_status
            ;;
        3)
            echo "Refreshing..."
            get_status
            ;;
        4|e|E)
            echo "Exiting..."
            exit 0
            ;;
        "") 
            # Ignore empty Enter key presses to prevent "Invalid" spam
            continue 
            ;;
        *)
            echo -e "${RED}Invalid option.${NC}"
            sleep 1
            ;;
    esac
done
