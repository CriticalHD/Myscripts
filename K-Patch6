#!/bin/bash

VERSION="v30.0.0"

CYAN='\033[0;36m'; NC='\033[0m'
RED='\033[0;31m'; GREEN='\033[0;32m'
BLUE='\033[0;34m'; YELLOW='\033[1;33m'

echo -e "${CYAN}ChromeOS Kernel Patch Script — ${VERSION}${NC}"

WORKDIR="/tmp/kernel_patch"
mkdir -p "$WORKDIR"
cd "$WORKDIR"

DISK="/dev/mmcblk0"
KERN_A="/dev/mmcblk0p2"
KERN_B="/dev/mmcblk0p4"

KEYBLOCK="/usr/share/vboot/devkeys/kernel.keyblock"
PRIVKEY="/usr/share/vboot/devkeys/kernel_data_key.vbprivk"

DEV_FW_SCRIPT="/usr/share/vboot/bin/make_dev_firmware.sh"
DEV_FW_BIN="/usr/share/vboot/dev_firmware.bin"

if [ ! -f "$DEV_FW_BIN" ]; then
    echo -e "${YELLOW}[!] Dev firmware not installed${NC}"
    if [ -f "$DEV_FW_SCRIPT" ]; then
        echo -e "${BLUE}[*] Installing dev firmware...${NC}"
        sudo bash "$DEV_FW_SCRIPT" --no-modify-hwid --no-modify-gbb
        echo -e "${GREEN}Dev firmware installed. REBOOT now.${NC}"
        exit 0
    else
        echo -e "${RED}[!] make_dev_firmware.sh not found!${NC}"
        exit 1
    fi
else
    echo -e "${GREEN}Dev firmware already installed${NC}"
fi


if command -v vbutil_kernel >/dev/null 2>&1; then
    VBUTIL="vbutil_kernel"
elif command -v futility >/dev/null 2>&1; then
    VBUTIL="futility vbutil_kernel"
else
    echo -e "${RED}[!] vbutil_kernel or futility not found!${NC}"
    exit 1
fi

echo "Patch mode:"
echo "1) Only active kernel slot (safe)"
echo "2) Both kernels (riskier)"
read -rp "Choice [1/2]: " PATCH_MODE
if [[ "$PATCH_MODE" != "1" && "$PATCH_MODE" != "2" ]]; then
    echo -e "${RED}[!] Invalid choice.${NC}"
    exit 1
fi

ACTIVE=$(cgpt show $DISK | grep -E "KERN-A|KERN-B" | sort -k4 -nr | head -n1)
if echo "$ACTIVE" | grep -q "KERN-A"; then
    ACTIVE_PART=2
    ACTIVE_DEV=$KERN_A
    ACTIVE_NAME="KERN-A"
else
    ACTIVE_PART=4
    ACTIVE_DEV=$KERN_B
    ACTIVE_NAME="KERN-B"
fi

echo -e "${GREEN}[*] Active slot: $ACTIVE_NAME${NC}"

echo -e "${BLUE}[*] Backing up kernels...${NC}"
sudo dd if=$KERN_A of=kernel_A_backup.bin bs=4M status=progress
sudo dd if=$KERN_B of=kernel_B_backup.bin bs=4M status=progress

FLAGS=(0 0 0 0 0 0 0)
NAMES=("cros_debug" "disable_rootfs_verification" "module.sig_enforce" "lsm.module_locking" "security" "selinux" "dm_verity.error_behavior")
DESCRIPTIONS=(
"Enable debug mode"
"Disable rootfs verification"
"Allow unsigned modules"
"Disable module locking"
"Disable kernel security"
"Disable SELinux"
"Ignore dm-verity errors"
)

CMDLINE_FILE="$WORKDIR/cmdline.txt"

show_menu() {
    clear
    echo -e "${CYAN}Kernel Patch Menu — ${VERSION}${NC}"
    for i in {0..6}; do
        status="OFF"; color=$RED
        [ "${FLAGS[$i]}" -eq 1 ] && status="ON" && color=$GREEN
        echo -e "${color}$((i+1))) [${status}] ${NAMES[$i]} - ${DESCRIPTIONS[$i]}${NC}"
    done
    echo "-----------------------------------"
    echo "m = manual edit | p = proceed | e = exit"
}

while true; do
    show_menu
    printf "Choice: "
    read -r choice < /dev/tty
    choice=$(echo "$choice" | tr -d '[:space:]')
    case "$choice" in
        1) FLAGS[0]=$((1-FLAGS[0])) ;;
        2) FLAGS[1]=$((1-FLAGS[1])) ;;
        3) FLAGS[2]=$((1-FLAGS[2])) ;;
        4) FLAGS[3]=$((1-FLAGS[3])) ;;
        5) FLAGS[4]=$((1-FLAGS[4])) ;;
        6) FLAGS[5]=$((1-FLAGS[5])) ;;
        7) FLAGS[6]=$((1-FLAGS[6])) ;;
        m) nano "$CMDLINE_FILE" ;;
        p) break ;;
        e) exit 0 ;;
    esac
done

> "$CMDLINE_FILE"
for i in {0..6}; do
    if [ "${FLAGS[$i]}" -eq 1 ]; then
        key="${NAMES[$i]}"
        if [ "$key" == "dm_verity.error_behavior" ]; then
            echo -n "dm_verity.error_behavior=ignore " >> "$CMDLINE_FILE"
        else
            echo -n "$key " >> "$CMDLINE_FILE"
        fi
    fi
done
echo "" >> "$CMDLINE_FILE"

echo -e "${GREEN}[*] Cmdline:${NC}"
cat "$CMDLINE_FILE"

repack_kernel() {
    IN_DEV=$1
    OUT_FILE=$2
    echo -e "${BLUE}[*] Dumping $IN_DEV...${NC}"
    sudo dd if=$IN_DEV of=kernel.bin bs=4M status=progress
    echo -e "${BLUE}[*] Repacking $OUT_FILE...${NC}"
    $VBUTIL --repack "$OUT_FILE" \
        --oldblob kernel.bin \
        --config "$CMDLINE_FILE" \
        --keyblock "$KEYBLOCK" \
        --signprivate "$PRIVKEY" \
        --version 1
    if [ ! -f "$OUT_FILE" ]; then
        echo -e "${RED}[!] Repack failed${NC}"
        exit 1
    fi
}

if [ "$PATCH_MODE" == "1" ]; then
    # Only active
    repack_kernel "$ACTIVE_DEV" "new_kernel.bin"
    echo -e "${BLUE}[*] Flashing $ACTIVE_NAME...${NC}"
    sudo dd if=new_kernel.bin of=$ACTIVE_DEV bs=4M status=progress
    sync
    sudo cgpt add -i $ACTIVE_PART -P 15 -T 1 -S 1 $DISK
else
    # Both kernels
    repack_kernel "$KERN_A" "new_kernel_A.bin"
    repack_kernel "$KERN_B" "new_kernel_B.bin"
    echo -e "${BLUE}[*] Flashing KERN-A and KERN-B...${NC}"
    sudo dd if=new_kernel_A.bin of=$KERN_A bs=4M status=progress
    sudo dd if=new_kernel_B.bin of=$KERN_B bs=4M status=progress
    sync
    sudo cgpt add -i 2 -P 15 -T 1 -S 1 $DISK
    sudo cgpt add -i 4 -P 15 -T 1 -S 1 $DISK
fi

echo -e "${GREEN}Kernel patch complete. Reboot now.${NC}"
