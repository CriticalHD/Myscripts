#!/bin/bash

PATCH_FLAG="/var/rpatch_fw_patched"
INDEX="0x1008"
WORKDIR="/tmp/rpatch_work"

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m"

stop_tpm_daemon() {
    [[ "$(tpmc tpmver 2>/dev/null)" == "1.2" ]] \
        && sudo initctl stop tcsd 2>/dev/null \
        || sudo initctl stop trunksd 2>/dev/null
}

start_tpm_daemon() {
    [[ "$(tpmc tpmver 2>/dev/null)" == "1.2" ]] \
        && sudo initctl start tcsd 2>/dev/null \
        || sudo initctl start trunksd 2>/dev/null
}

get_info() {
    stop_tpm_daemon
    TPM_VER=$(tpmc tpmver 2>/dev/null | tr -d '\n')
    [[ -z "$TPM_VER" ]] && TPM_VER="?"
    GSC_TYPE=$([[ "$TPM_VER" == "1.2" ]] && echo "preCr50" || \
        (gsctool -a -I 2>/dev/null | grep -qi AllowUnverifiedRo && echo "ti50" || echo "cr50"))
    KERNVER=$(tpmc read $INDEX 9 2>/dev/null | tr -d '\n')
    [[ -z "$KERNVER" ]] && KERNVER="?"
    local fb=$(tpmc read $INDEX 1 2>/dev/null | awk '{print $1}')
    case "$fb" in
        "02") STRUCT_VER="V0" ;;
        "10") STRUCT_VER="V1" ;;
        *)    STRUCT_VER="?"  ;;
    esac
    start_tpm_daemon
}

is_fw_patched() { [[ -f "$PATCH_FLAG" ]]; }

to_le32() {
    local v=$1
    printf "%02x %02x %02x %02x" \
        $((v & 0xFF)) $(((v>>8) & 0xFF)) $(((v>>16) & 0xFF)) $(((v>>24) & 0xFF))
}

crc8() {
    local data=("$@") crc=0
    for byte in "${data[@]}"; do
        local b=$((16#$byte))
        for ((i=0;i<8;i++)); do
            local mix=$(( (crc ^ b) & 1 ))
            crc=$(( crc >> 1 ))
            (( mix )) && crc=$(( crc ^ 0x8C ))
            b=$(( b >> 1 ))
        done
    done
    printf "%02x" $crc
}

build_struct() {
    local ver=$1 kv=$2
    if [[ "$ver" == "V0" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local full=("02" "4c" "57" "52" "47" "${kv_b[@]}" "00" "00" "00" "00")
        full[11]=$(crc8 "${full[@]:0:11}")
    elif [[ "$ver" == "V1" ]]; then
        local kv_b=($(to_le32 "$kv"))
        local ec=()
        for ((i=0;i<32;i++)); do ec+=("00"); done
        local full=("10" "28" "00" "00" "${kv_b[@]}" "${ec[@]}")
        full[2]=$(crc8 "${full[@]:3}")
    else
        echo -e "${RED}Unknown struct version${NC}"; return 1
    fi
    echo "${full[@]}"
}

draw_header() {
    clear
    echo -e "${CYAN}┌─────────────────────────────┐${NC}"
    echo -e "${CYAN}│${NC}  ${BOLD}R-Patch v6.0${NC} · CriticalHD  ${CYAN}│${NC}"
    echo -e "${CYAN}├─────────────────────────────┤${NC}"
    if is_fw_patched; then
        echo -e "${CYAN}│${NC} FW:${GREEN}PATCHED${NC} TPM:${TPM_VER} GSC:${GSC_TYPE}"
    else
        echo -e "${CYAN}│${NC} FW:${RED}NOT PATCHED${NC} TPM:${TPM_VER} GSC:${GSC_TYPE}"
    fi
    echo -e "${CYAN}│${NC} KV: ${YELLOW}${KERNVER}${NC}"
    echo -e "${CYAN}└─────────────────────────────┘${NC}"
    echo
}

change_rollback() {
    if ! is_fw_patched; then
        echo -e "${RED}Patch firmware first (option 2).${NC}"
        read -r </dev/tty; return
    fi
    echo -e "${CYAN}Current KV: ${KERNVER} | Struct: ${STRUCT_VER}${NC}"
    echo -e " ${YELLOW}0${NC}) KV0  ${YELLOW}1${NC}) KV1  ${YELLOW}2${NC}) KV2(R112+)"
    echo -e " ${YELLOW}3${NC}) KV3(R120+)  ${YELLOW}4${NC}) KV4(R125+)"
    echo -e " ${YELLOW}5${NC}) KV5(R133+)  ${YELLOW}6${NC}) KV6  ${YELLOW}7${NC}) KV7"
    echo -e " ${YELLOW}B${NC}) Back"
    echo -n "> "; read -r kv </dev/tty
    [[ "$kv" =~ ^[Bb]$ ]] && return
    [[ ! "$kv" =~ ^[0-7]$ ]] && { echo -e "${RED}Invalid.${NC}"; sleep 1; return; }

    local kv_val
    [[ "$kv" == "0" ]] && kv_val=0 || kv_val=$(( 0x00010000 + kv ))

    local bytes=($(build_struct "$STRUCT_VER" "$kv_val"))
    [[ $? -ne 0 ]] && return

    echo -e "${YELLOW}Set KV to ${kv}? (y/N):${NC} "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    stop_tpm_daemon
    tpmc write $INDEX "${bytes[@]}"
    local rc=$?
    start_tpm_daemon

    [[ $rc -eq 0 ]] && echo -e "${GREEN}KV set to ${kv}.${NC}" \
                    || echo -e "${RED}Failed (code $rc).${NC}"
    get_info
    read -r </dev/tty
}

patch_firmware() {
    echo -e "${YELLOW}Patches fw to keep platform hierarchy enabled.${NC}"
    echo -e "${RED}Brick risk! Continue? (y/N):${NC} "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && return

    mkdir -p "$WORKDIR"

    echo -e "${CYAN}[1/4] python3...${NC}"
    if ! command -v python3 &>/dev/null; then
        dev_install --yes 2>/dev/null
        if ! command -v python3 &>/dev/null; then
            echo -e "${RED}python3 unavailable.${NC}"; read -r </dev/tty; return
        fi
    fi
    echo -e "${GREEN}OK${NC}"

    echo -e "${CYAN}[2/4] Dumping fw...${NC}"
    flashrom -p internal -r "$WORKDIR/fw.bin" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}Failed!${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}OK${NC}"

    echo -e "${CYAN}[3/4] Patching...${NC}"
    cd "$WORKDIR"
    futility dump_fmap -x fw.bin FW_MAIN_A FW_MAIN_B 2>/dev/null

    for region in FW_MAIN_A FW_MAIN_B; do
        python3 - "$WORKDIR/$region" "$WORKDIR/${region}.p" <<'EOF'
import sys
with open(sys.argv[1],'rb') as f: d=bytearray(f.read())
t=bytes([0x00,0x00,0x01,0x21,0x40,0x00,0x00,0x0C])
n=0
for i in range(len(d)-len(t)):
    if d[i:i+len(t)]==t:
        o=i+len(t)+4
        if o+1<len(d) and d[o]==0 and d[o+1]==0:
            d[o+1]=1; n+=1
print(f"{'Patched' if n else 'WARNING: no pattern found in'} {sys.argv[1]} ({n} hit(s))")
with open(sys.argv[2],'wb') as f: f.write(d)
EOF
        cp "${region}.p" "$region"
    done

    # Write patched regions back into fw.bin
    futility load_fmap "$WORKDIR/fw.bin" \
        FW_MAIN_A "$WORKDIR/FW_MAIN_A" \
        FW_MAIN_B "$WORKDIR/FW_MAIN_B" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}Failed to write patches into fw.bin!${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}OK${NC}"

    echo -e "${CYAN}[4/4] Signing...${NC}"
    /usr/share/vboot/bin/make_dev_firmware.sh --nomod_hwid --nomod_gbb 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}Signing failed!${NC}"; read -r </dev/tty; return; }
    echo -e "${GREEN}OK${NC}"

    echo -e "${RED}Flash? POINT OF NO RETURN (y/N):${NC} "; read -r c </dev/tty
    [[ "$c" != "y" && "$c" != "Y" ]] && { echo "Aborted."; read -r </dev/tty; return; }

    flashrom -p internal -w "$WORKDIR/fw.bin" 2>/dev/null
    [[ $? -ne 0 ]] && { echo -e "${RED}Flash failed!${NC}"; read -r </dev/tty; return; }

    touch "$PATCH_FLAG"
    echo -e "${GREEN}Done! Reboot to apply.${NC}"
    read -r </dev/tty
}

get_info

while true; do
    draw_header
    if is_fw_patched; then
        echo -e " ${YELLOW}1)${NC} Change Rollback"
    else
        echo -e " ${RED}1) Change Rollback [patch fw first]${NC}"
    fi
    echo -e " ${YELLOW}2)${NC} Patch Firmware"
    echo -e " ${YELLOW}3)${NC} Exit"
    echo -n "> "; read -r choice </dev/tty
    case "$choice" in
        1) change_rollback ;;
        2) patch_firmware ;;
        3) exit 0 ;;
        *) echo -e "${RED}Invalid.${NC}"; sleep 1 ;;
    esac
done
