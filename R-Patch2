#!/bin/bash

VERSION="v2.3.0"
AUTHOR="CriticalHD/neonnebula"

# Colors
CYAN='\033[0;36m'
WHITE='\033[1;37m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
RED='\033[0;31m'
NC='\033[0m'

# ==============================
# SAFE FUNCTIONS (no hanging)
# ==============================

get_fwid() {
    if [[ -f /sys/class/platform/chromeos_acpi/FWID ]]; then
        cat /sys/class/platform/chromeos_acpi/FWID 2>/dev/null
    elif [[ -f /proc/device-tree/firmware/chromeos/firmware-version ]]; then
        tr -d '\0' < /proc/device-tree/firmware/chromeos/firmware-version
    else
        echo "Unavailable"
    fi
}

get_tpmver() {
    tpmc tpmver 2>/dev/null || echo "Unavailable"
}

get_kernver() {
    # Try direct read (may fail on your device)
    RAW=$(timeout 4 tpmc read 0x1008 9 2>/dev/null)

    if [[ -z "$RAW" ]]; then
        echo "Blocked / Not accessible"
        return
    fi

    # Try simple parse fallback
    HEX=$(echo "$RAW" | grep -oE '[0-9a-fA-F]{8}' | head -n1)

    if [[ -z "$HEX" ]]; then
        echo "Unknown format"
    else
        echo "0x$HEX"
    fi
}

get_fwmp() {
    RAW=$(timeout 4 tpmc read 0x100A 5 2>/dev/null)

    [[ -z "$RAW" ]] && echo "Unavailable" && return

    BYTE=$(echo "$RAW" | grep -oE '[0-9a-fA-F]{2}' | head -n1)
    echo "0x$BYTE"
}

get_gscver() {
    if command -v gsctool >/dev/null; then
        gsctool -a -f 2>/dev/null | tail -n1 | awk '{print $2}'
    else
        echo "Not installed"
    fi
}

get_gsctype() {
    if [[ -x /opt/kvs/bin/is_ti50 ]]; then
        /opt/kvs/bin/is_ti50 2>/dev/null
    else
        echo "Unknown"
    fi
}

# ==============================
# MAIN LOOP
# ==============================

while true; do
    clear

    echo -e "${CYAN}======================================${NC}"
    echo -e "${WHITE}        R-Patch ${VERSION}${NC}"
    echo -e "${YELLOW}    by ${AUTHOR}${NC}"
    echo -e "${CYAN}======================================${NC}"
    echo

    echo -e "${BLUE}System Info:${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo -e "FWID:     ${WHITE}$(get_fwid)${NC}"
    echo -e "TPM Ver:  ${WHITE}$(get_tpmver)${NC}"
    echo -e "Kernver:  ${WHITE}$(get_kernver)${NC}"
    echo -e "FWMP:     ${WHITE}$(get_fwmp)${NC}"
    echo -e "GSC Ver:  ${WHITE}$(get_gscver)${NC}"
    echo -e "GSC Type: ${WHITE}$(get_gsctype)${NC}"
    echo -e "${BLUE}--------------------------------------${NC}"
    echo

    echo -e "${CYAN}[R] Refresh${NC}"
    echo -e "${CYAN}[Q] Quit${NC}"
    echo

    read -r -p "Enter choice: " choice < /dev/tty

    case "$choice" in
        [Qq]) exit 0 ;;
        [Rr]) ;;
    esac
done
